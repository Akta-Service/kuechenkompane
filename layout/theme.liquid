      .mrk-h1 { font-size: var(--mrk-h1-size-desktop); margin: var(--mrk-h1-margin-desktop); font-weight: {{ settings.mrk_h1_font_weight }}; }
      .mrk-h2 { font-size: var(--mrk-h2-size-desktop); margin: var(--mrk-h2-margin-desktop); font-weight: {{ settings.mrk_h2_font_weight }}; }
      .mrk-h3 { font-size: var(--mrk-h3-size-desktop); margin: var(--mrk-h3-margin-desktop); font-weight: {{ settings.mrk_h3_font_weight }}; }
      .mrk-h4 { font-size: var(--mrk-h4-size-desktop); margin: var(--mrk-h4-margin-desktop); font-weight: {{ settings.mrk_h4_font_weight }}; }
      .mrk-h5 { font-size: var(--mrk-h5-size-desktop); margin: var(--mrk-h5-margin-desktop); font-weight: {{ settings.mrk_h5_font_weight }}; }
      .mrk-h6 { font-size: var(--mrk-h6-size-desktop); margin: var(--mrk-h6-margin-desktop); font-weight: {{ settings.mrk_h6_font_weight }}; }

