      Shopify.cart_drawer = Shopify.cart_drawer || {};
      Shopify.cart_drawer.freeProduct1 = {
        title:     '{{ settings.cart_free_product_1.title }}',
        available: '{{ settings.cart_free_product_1.selected_or_first_available_variant.available }}',
