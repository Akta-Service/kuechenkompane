        .mrk-h4 { font-size: var(--mrk-h4-size-laptop); margin: var(--mrk-h4-margin-laptop); }
        .mrk-h5 { font-size: var(--mrk-h5-size-laptop); margin: var(--mrk-h5-margin-laptop); }
        .mrk-h6 { font-size: var(--mrk-h6-size-laptop); margin: var(--mrk-h6-margin-laptop); }
        .p-xl, .p-xl p       { font-size: {{ settings.p_xl_size_laptop }}px; }
        .p-large, .p-large p { font-size: {{ settings.p_large_size_laptop }}px; }
        .p-medium, .p-medium p { font-size: {{ settings.p_medium_size_laptop }}px; }
        .p-small, .p-small p { font-size: {{ settings.p_small_size_laptop }}px; }
        .p-x-small, .p-x-small p { font-size: {{ settings.p_xs_size_laptop }}px; }
      }

      /* Mobile breakpoint */
      @media (max-width: 767px) {
        .mrk-h1 { font-size: var(--mrk-h1-size-mobile); margin: var(--mrk-h1-margin-mobile); }
        .mrk-h2 { font-size: var(--mrk-h2-size-mobile); margin: var(--mrk-h2-margin-mobile); }
        .mrk-h3 { font-size: var(--mrk-h3-size-mobile); margin: var(--mrk-h3-margin-mobile); }
        .mrk-h4 { font-size: var(--mrk-h4-size-mobile); margin: var(--mrk-h4-margin-mobile); }
        .mrk-h5 { font-size: var(--mrk-h5-size-mobile); margin: var(--mrk-h5-margin-mobile); }
        .mrk-h6 { font-size: var(--mrk-h6-size-mobile); margin: var(--mrk-h6-margin-mobile); }
        .p-xl       { font-size: {{ settings.p_xl_size_mobile }}px; }
        .p-large    { font-size: {{ settings.p_large_size_mobile }}px; }
