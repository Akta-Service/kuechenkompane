       m-cart-drawer,
      .m-cart-drawer {
        display: none !important;
      }
      .m-cart-drawer--active {
        display: block !important;
      }

    
    </style>

    <!-- =============================================
         RENDER TYPOGRAPHY
    ============================================== -->
    {% render 'typegraphy' %}

    <!-- =============================================
         INLINE CRITICAL JS (must run early)
    ============================================== -->
    <script>
      /* 1. no-js → js class swap */
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
        if (window.Shopify && Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }

      /* 2. Real viewport height fix */
      (function setVh() {
        var vh = window.innerHeight * 0.01;
        document.documentElement.style.setProperty('--vh', vh + 'px');
        window.addEventListener('resize', function () {
          document.documentElement.style.setProperty('--vh', window.innerHeight * 0.01 + 'px');
        });
      })();

      /* 3. Defer Shopify checkout CSS */
      (function deferShopifyCheckoutCSS() {
        var interval = setInterval(function () {
          var link = document.querySelector('#shopify-accelerated-checkout-styles');
          if (link) {
            clearInterval(interval);
            link.media = 'print';
            link.onload = function () { this.media = 'all'; };
          }
        }, 100);
      })();

      /* 4. noscript style extractor */
      (function extractNoscriptStyles() {
        document.querySelectorAll('noscript').forEach(function (noscript) {
          noscript.querySelectorAll('style').forEach(function (style) {
            var s = document.createElement('style');
            s.textContent = style.textContent;
            document.head.appendChild(s);
          });
        });
      })();
    </script>

    <!-- =============================================
         PASSWORD PROTECTED COLLECTION JS
    ============================================== -->
    <script>
      (function () {
        var correctPassword = '{{ settings.password | escape }}';
        var collectionHandle = '{{ settings.collection_handle }}';
        var collectionKey = 'collectionAccess_' + collectionHandle;

        function lockScroll()   { document.body.classList.add('scroll-lock'); }
        function unlockScroll() { document.body.classList.remove('scroll-lock'); }

        function checkPasswordFactory(popup, passwordInput, errorEl) {
          return function () {
            if (!passwordInput) return;
            var userPassword = (passwordInput.value || '').toLowerCase();
            var correct = String(correctPassword || '').toLowerCase();
            if (userPassword === correct) {
              document.dispatchEvent(new Event('passwordCorrect'));
              try { localStorage.setItem(collectionKey, 'true'); } catch (e) {}
              if (popup) popup.style.display = 'none';
              unlockScroll();
            } else {
              if (errorEl) errorEl.style.display = 'block';
            }
          };
        }

        document.addEventListener('DOMContentLoaded', function () {
          var popup         = document.getElementById('password-popup');
          var passwordInput = document.getElementById('popup-password');
          var errorMessage  = document.getElementById('error-message');

          if (!popup) return;

          /* Move popup to body if needed */
          if (popup.parentElement !== document.body) {
            document.body.appendChild(popup);
          }

          if (localStorage.getItem(collectionKey) === 'true') {
            popup.style.display = 'none';
            unlockScroll();
          } else {
            lockScroll();
          }

          window.checkPassword = checkPasswordFactory(popup, passwordInput, errorMessage);

          if (passwordInput) {
            passwordInput.addEventListener('keydown', function (ev) {
              if (ev.key === 'Enter') { ev.preventDefault(); window.checkPassword(); }
            });
          }
        });
      })();
    </script>

    <!-- =============================================
         DEFERRED THIRD-PARTY SCRIPTS
         (Clarity + Ablyft load after 3s idle)
    ============================================== -->
    <script>
      (function () {
        function loadThirdParty() {
          /* Microsoft Clarity */
          (function (c, l, a, r, i, t, y) {
            c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
            t = l.createElement(r); t.async = 1;
            t.src = 'https://www.clarity.ms/tag/' + i;
            y = l.getElementsByTagName(r)[0];
            y.parentNode.insertBefore(t, y);
          })(window, document, 'clarity', 'script', 'tefbj2e4ie');

          /* Ablyft — loaded ONCE here only */
          var ablyft = document.createElement('script');
          ablyft.src = 'https://cdn.ablyft.com/s/75700830.js';
          ablyft.async = true;
          document.head.appendChild(ablyft);
        }

        /* Use requestIdleCallback if available, else 3s timeout */
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadThirdParty, { timeout: 3000 });
        } else {
          setTimeout(loadThirdParty, 3000);
        }
      })();
    </script>

