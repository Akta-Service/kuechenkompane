<div class="fertigung-grid" {{ block.shopify_attributes }}>
  {% content_for 'blocks' %}
</div>

<style>
  .fertigung-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 52px;
    border-bottom: 1px solid #e3dccc;
  }

  .fertigung-grid > .fertigung-item:nth-child(1) { animation-delay: .2s; }
  .fertigung-grid > .fertigung-item:nth-child(2) { animation-delay: .3s; }
  .fertigung-grid > .fertigung-item:nth-child(3) { animation-delay: .4s; }
  .fertigung-grid > .fertigung-item:nth-child(4) { animation-delay: .5s; }
  .fertigung-grid > .fertigung-item:nth-child(5) { animation-delay: .6s; }
  .fertigung-grid > .fertigung-item:nth-child(6) { animation-delay: .7s; }

  @media screen and (min-width: 861px) {
    .fertigung-grid > .fertigung-item:nth-child(3n+2),
    .fertigung-grid > .fertigung-item:nth-child(3n+3) {
      border-left: 1px solid #e3dccc;
    }
  }

  @media screen and (max-width: 860px) {
    .fertigung-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Fertigung grid",
  "tag": null,
  "blocks": [{ "type": "_fertigung-item" }],
  "settings": [],
  "presets": [
    {
      "name": "Fertigung grid",
      "category": "Layout",
      "blocks": [{ "type": "_fertigung-item" }, { "type": "_fertigung-item" }, { "type": "_fertigung-item" }]
    }
  ]
}
{% endschema %}
