{% if block.settings.heading != blank %}
  <h2 class="founder-heading" {{ block.shopify_attributes }}>
    {{ block.settings.heading }}
  </h2>
{% endif %}

<style>
  .founder-heading {
    margin: 0 0 18px;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.3;
    color: {{ block.settings.heading_color }};
  }

  @media screen and (max-width: 1149px) {
    .founder-heading {
      font-size: 22.4px;
    }
  }
</style>

{% schema %}
{
  "name": "Founder heading",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Genau dieses Gefühl wollen wir dir mit unseren Produkten geben."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    }
  ],
  "presets": [
    {
      "name": "Founder heading",
      "category": "Text"
    }
  ]
}
{% endschema %}