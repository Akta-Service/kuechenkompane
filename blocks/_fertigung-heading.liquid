{% if block.settings.heading != blank %}
  <h2 class="fertigung-heading" data-b2b-reveal style="animation-delay: .05s" {{ block.shopify_attributes }}>
    {{ block.settings.heading | newline_to_br }}
  </h2>
{% endif %}

<style>
  .fertigung-heading {
    font-size: clamp(30px, 4.4vw, 54px);
    margin: 22px 0 20px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -.01em;
    color: #1e1b15;
    max-width: 60ch;
  }
</style>

{% schema %}
{
  "name": "Fertigung heading",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Fertigung aus\neiner Hand"
    }
  ],
  "presets": [
    {
      "name": "Fertigung heading",
      "category": "Text"
    }
  ]
}
{% endschema %}
