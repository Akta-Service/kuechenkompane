<div class="kk-rechnung-card" data-b2b-reveal {{ block.shopify_attributes }}>
  {%- if block.settings.number != blank -%}
    <span class="kk-rechnung-card__number">{{ block.settings.number }}</span>
  {%- endif -%}

  <p class="kk-rechnung-card__text">
    {%- if block.settings.lead != blank -%}
      <strong>{{ block.settings.lead }}</strong>
    {%- endif %}
    {{ block.settings.text }}
  </p>
</div>

<style>
  .kk-rechnung-card {
    background: #ffffff08;
    border: 1px solid #ffffff1f;
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    flex-direction: column;
    border-radius: 12px;
    padding: 1.05rem 1.15rem;
  }
  
  .kk-rechnung-card__number {
    display: block;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.3;
    flex-shrink: 0;
    color: #fa8526;
  }

  .kk-rechnung-card__text {
    font-size: .92rem;
    line-height: 1.55;
    color: rgba(255,255,255,.78);
    margin: 0;
  }

  .kk-rechnung-card__text strong {
    color: #ffffff;
    font-weight: 600;
  }

  @media screen and (max-width: 759px) {
    .kk-rechnung-card {
      gap: .95rem;
      flex-direction: row;
    }
  }
</style>

{% schema %}
{
  "name": "KK Rechnung card",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "number",
      "label": "Number",
      "default": "1"
    },
    {
      "type": "text",
      "id": "lead",
      "label": "Lead (bold)",
      "default": "Das Lager zieht um."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Jede Palette, jeder Karton und jedes Kilogramm verursacht Transportkosten."
    }
  ],
  "presets": [
    {
      "name": "KK Rechnung card",
      "category": "Content"
    }
  ]
}
{% endschema %}
