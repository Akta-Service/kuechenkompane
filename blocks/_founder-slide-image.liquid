
<li class="splide__slide" {{ block.shopify_attributes }}>
  <div class="founder-slide-image">
    {% if block.settings.image != blank %}
      {{
        block.settings.image
        | image_url: width: 1400
        | image_tag: loading: 'lazy', alt: block.settings.alt_text, class: 'founder-slide-image__img'
      }}
    {% else %}
      <div class="founder-slide-image__placeholder">Add image</div>
    {% endif %}
  </div>
</li>

<style>
  .founder-slide-image {
    position: relative;
    overflow: hidden;
    background: #f2f2f2;
    aspect-ratio: 1 / 1;
  }

  .founder-slide-image__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .founder-slide-image__placeholder {
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666666;
  }
    li.splide__slide {
    list-style: none;
  }
  

  @media screen and (max-width: 1149px) {
    .founder-slide-image {
      aspect-ratio: 16 / 9;
    }
  }

  @media screen and (max-width: 749px) {
    .founder-slide-image {
      aspect-ratio: 1 / 1;
    }
  }
</style>

{% schema %}
{
  "name": "Founder slide image",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt text",
      "default": "Founder image"
    }
  ],
  "presets": [
    {
      "name": "Founder slide image",
      "category": "Media"
    }
  ]
}
{% endschema %}
