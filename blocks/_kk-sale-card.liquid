{%- liquid
  assign prod = block.settings.product
  assign overwrite = block.settings.overwrite

  assign card_image = prod.featured_image
  assign card_title = prod.title
  if prod != blank
    assign card_description = prod.description | strip_html | truncate: 80
  else
    assign card_description = ''
  endif

  assign card_price = ''
  assign card_old_price = ''
  assign card_save_amount = ''
  assign card_save_label = 'Sie sparen'

  if prod != blank
    assign card_price = prod.price | money
    if prod.compare_at_price > prod.price
      assign card_old_price = prod.compare_at_price | money
      assign card_save_amount = prod.compare_at_price | minus: prod.price | money
    endif
  endif

  if overwrite
    if block.settings.image != blank
      assign card_image = block.settings.image
    endif
    if block.settings.title != blank
      assign card_title = block.settings.title
    endif
    if block.settings.description != blank
      assign card_description = block.settings.description
    endif
  endif

  if block.settings.save_text != blank
    assign card_save_label = block.settings.save_text
  endif

  assign card_save = ''
  if card_save_amount != blank
    assign card_save = card_save_label | append: ' ' | append: card_save_amount
  endif

  assign card_link = prod.url
-%}

<div class="kk-sale-card" data-b2b-reveal {{ block.shopify_attributes }}>
  <div class="kk-sale-card__media">
    {%- if card_image != blank -%}
      <a href="{{  card_link }}">
        <img
          src="{{ card_image | image_url: width: 800 }}"
          alt="{{ card_title | escape }}"
          loading="lazy"
          width="{{ card_image.width }}"
          height="{{ card_image.height }}"
        >
      </a>
    {%- else -%}
      <div class="kk-sale-card__placeholder">Select a product</div>
    {%- endif -%}
  </div>

  <div class="kk-sale-card__body">
    {%- if card_title != blank -%}
      <h3 class="kk-sale-card__title">{{ card_title }}</h3>
    {%- endif -%}

    {%- if card_description != blank -%}
      <p class="kk-sale-card__description">{{ card_description }}</p>
    {%- endif -%}

    <div class="kk-sale-card__prices">
      {%- if card_price != blank -%}
        <span class="kk-sale-card__price">{{ card_price }}</span>
      {%- endif -%}
      {%- if card_old_price != blank -%}
        <s class="kk-sale-card__old-price">{{ card_old_price }}</s>
      {%- endif -%}
    </div>

    {%- if card_save != blank -%}
      <p class="kk-sale-card__save">{{ card_save }}</p>
    {%- endif -%}

    {%- if block.settings.button_label != blank -%}
      <a class="kk-sale-card__btn" href="{{ card_link }}">
        {{ block.settings.button_label }}
        <span aria-hidden="true">→</span>
      </a>
    {%- endif -%}
  </div>
</div>

<style>
  .kk-sale-card {
    background: #ffffff;
    border: 1px solid #eeeeee;
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow .25s ease, transform .25s ease, border-color .25s ease;
  }

  .kk-sale-card:hover {
    box-shadow: 0 22px 48px -20px rgba(22, 28, 18, .3);
    border-color: #fa8526;
  }

  .kk-sale-card__media {
    border-bottom: 1px solid #eeeeee;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kk-sale-card__media img {
    width: 100%;
    height: auto;
    display: block;
    background: #fff;
    display: block;
  }

  .kk-sale-card__placeholder {
    color: #444444;
    font-size: 13px;
  }

  .kk-sale-card__body {
    padding: 1.05rem 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    border-top: 1px solid #eeeeee;
  }

  .kk-sale-card__title {
    font-weight: 600;
    font-size: 1.18rem;
    line-height: 1.6;
    margin: 0 0 .25rem;
    color: #222222;
  }

  .kk-sale-card__description {
    font-size: .85rem;
    line-height: 1.5;
    margin: 0 0 .8rem;
    color: #444444;
  }

  .kk-sale-card__prices {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: .6rem;
    line-height: 1.6;
    margin: 0 0 .3rem;
  }

  .kk-sale-card__price {
    font-size: 1.45rem;
    font-weight: 800;
    color: #222222;
  }

  .kk-sale-card__old-price {
    font-size: 1rem;
    color: #e84e4e;
  }

  .kk-sale-card__save {
    font-size: .85rem;
    line-height: 1.5;
    margin: 0 0 .95rem;
    color: #222222;
  }

  .kk-sale-card__btn {
    background: #fa8526;
    margin-top: auto;
    min-height: 48px;
    padding: .7rem 1.2rem;
    font-size: .95rem;
    width: 100%;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    justify-content: center;
    padding: .9rem 2.2rem;
    border-radius: 9px;
    text-decoration: none;
    background: linear-gradient(160deg, #fa8526bb 0%, #fa8526 55%, #af550cff 130%);
    color: #ffffff;
    border: 1px solid rgba(250, 133, 38, 0.6);
    box-shadow: 0 12px 28px -12px #fa8526a6, inset 0 1px 0 rgba(255, 255, 255, .45);
    transition: transform .12s ease, box-shadow .2s ease, filter .2s ease;
    position: relative;
    overflow: hidden;
  }

  .kk-sale-card__btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.04);
  }

  @media (max-width: 640px ){
    .kk-sale-card__body {
      padding: .7rem .7rem .85rem ;
    }
    .kk-sale-card__title {
      font-size: .95rem;
      line-height: 1.25;
    }
    .kk-sale-card__description {
      font-size: .74rem;
      line-height: 1.4;
      margin-bottom: .4rem;
    }
    .kk-sale-card__price{
      font-size: 1.15rem;
      line-height: 1.3 !important;
    }

    .kk-sale-card__btn {
      padding: .5rem 0rem;
      gap: 4px;
      min-height: 40px;
      font-size: 14px;
    }
    .kk-sale-card__prices {
      gap: 0 !important;
    }
  }
</style>

{% schema %}
{
  "name": "KK Sale card",
  "tag": null,
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "overwrite",
      "label": "Overwrite product content",
      "default": false,
      "info": "Check to overwrite product content with the fields below. Empty fields keep the product value."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Fill only if you want to override the product image.",
      "visible_if": "{{ block.settings.overwrite }}"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "info": "Fill only if you want to override the product title.",
      "visible_if": "{{ block.settings.overwrite }}"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "info": "Fill only if you want to override the product description.",
      "visible_if": "{{ block.settings.overwrite }}"
    },
    {
      "type": "text",
      "id": "save_text",
      "label": "Save text",
      "info": "Label text only (e.g. \"Sie sparen\") — the amount is always calculated automatically from the product prices.",
      "default": "Sie sparen "
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Angebot sichern"
    }
  ],
  "presets": [
    {
      "name": "KK Sale card",
      "category": "Content"
    }
  ]
}
{% endschema %}
