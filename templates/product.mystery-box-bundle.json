          }
        },
        "review_UrnBr7": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/8.1.jpg",
            "mobile-image": "shopify://shop_images/8_65844908-de9a-44ab-92bf-f22858017065.jpg",
            "title": "Preis-Leistung Überragend!",
            "review": "Ich dachte erst, das ist Marketing – aber die Messer sind wirklich extrem hochwertig. Für den Preis absolut krank.",
            "author": "– Daniel K.",
            "verified-text": "Verifizierter Käufer"
          }
        },
        "review_mgaAy8": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/6.1.jpg",
            "mobile-image": "shopify://shop_images/6_3a67222c-ab89-4d1f-b29f-88d0a24f6b35.jpg",
            "title": "Allein ein Messer wäre schon teurer gewesen",
            "review": "Ich habe die kleine Box bestellt und schon das erste Messer fühlt sich wie ein High-End Produkt an. Wenn man bedenkt, was man normalerweise zahlt, ist das hier einfach unglaublich gut.",
            "author": "Stefan K.",
