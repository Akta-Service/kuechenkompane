            "mobile-image": "shopify://shop_images/7_9262083a-8635-468d-bf89-01874ccf6b51.jpg",
            "title": "Direkt im Einsatz – Unterschied sofort gemerkt",
            "review": "Habe die Messer direkt beim Kochen getestet und man merkt sofort den Unterschied. Schneidet butterweich, kein Vergleich zu meinen alten Messern. Absolute Empfehlung.",
            "author": "Laura S.",
            "verified-text": "Verifizierter Kauf"
          }
        },
        "review_GrqhUy": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/4.1.jpg",
            "mobile-image": "shopify://shop_images/4_d42239bc-6908-4c1b-81d4-da79cde2324f.jpg",
            "title": "Perfekte Mischung aus Überraschung & Qualität",
            "review": "Das Auspacken macht mega Spaß, aber noch besser ist die Qualität. Man merkt sofort, dass das keine billigen Messer sind. Fühlt sich einfach hochwertig an.",
