                "enable_loop": false,
                "image_radius": 12
              },
              "blocks": {
                "founder_slide_image_9eW3C7": {
                  "type": "_founder-slide-image",
                  "name": "Founder slide image",
                  "settings": {
                    "image": "shopify://shop_images/59bea942-ccd6-4f5b-8041-48e5a4e60364.png",
                    "alt_text": "Founder image"
