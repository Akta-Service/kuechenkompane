      "blocks": {
        "faq_jkYPLV": {
          "type": "faq",
          "settings": {
            "question": "Was bekomme ich in meiner Mystery Box?",
            "answer": "<p>Du erhältst je nach gewählter Box <strong>3, 5 oder 7 hochwertige Premium-Küchenmesser</strong> aus unserem Sortiment.</p><p>Darunter können sich befinden:</p><ul><li>Damast Chefmesser<br/></li><li>Damast Santoku Messer<br/></li><li>Damast Nakiri Messer<br/></li><li>Universalmesser und weitere Profi-Klingen<br/></li></ul><p><strong>Jede Box ist individuell zusammengestellt</strong> – genau das macht den Reiz aus.</p>"
          }
        },
        "faq_pDwHXa": {
          "type": "faq",
          "settings": {
            "question": "Wie hoch ist der Warenwert meiner Box?",
            "answer": "<p>Der Warenwert deiner Box liegt <strong>garantiert bei mindestens dem 3-fachen deines Kaufpreises.</strong></p><p>Je nach Größe sind Werte möglich von:</p><ul><li>S Box: bis zu <strong>899€</strong><br/></li><li>M Box: bis zu <strong>1.499€</strong><br/></li><li>L Box: bis zu <strong>2.099€</strong><br/></li></ul><p>Du bekommst also immer deutlich mehr, als du bezahlst.</p>"
          }
        },
        "faq_nQHFGw": {
          "type": "faq",
          "settings": {
            "question": "Kann ich meine Mystery Box zurückgeben?",
            "answer": "<p>Ja – du gehst <strong>kein Risiko ein.</strong></p><p>Du hast <strong>100 Tage Zeit</strong>, deine Messer zu testen.<br/><br/>Wenn du nicht zufrieden bist, erhältst du dein Geld zurück.</p><p>Einfach, sicher und ohne Haken.</p>"
          }
        },
        "faq_kQAWhE": {
          "type": "faq",
          "settings": {
            "question": "Wann kommt meine Mystery Box bei mir an?",
            "answer": "<p>Deine Mystery Box wird innerhalb von <strong>1–3 Werktagen</strong> geliefert.</p><p>Nach Versand erhältst du eine Sendungsverfolgung.</p><p>Du kannst dich also schon in wenigen Tagen auf dein Unboxing freuen.</p>"
          }
        }
      },
