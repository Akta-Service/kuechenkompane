    "apex_faqs_jx7hp6": {
      "type": "apex-faqs",
      "blocks": {
        "item_Y76Jjj": {
          "type": "item",
          "settings": {
            "faq_title": "Was genau bekomme ich in meiner Mystery Box?",
            "faq_body": "<p>Du erhältst je nach gewählter Box <strong>3, 5 oder 7 hochwertige Premium-Küchenmesser</strong> aus unserem Sortiment.<br/><br/>Jede Box wird individuell zusammengestellt – dadurch ist jede Lieferung einzigartig.</p>"
          }
        },
        "item_J7jdRT": {
          "type": "item",
          "settings": {
            "faq_title": "Wie hoch ist der tatsächliche Warenwert?",
            "faq_body": "<p>Der Warenwert deiner Box liegt <strong>garantiert bei mindestens dem 3-fachen deines Kaufpreises</strong>.<br/><br/>Je nach Box sind Werte von bis zu <strong>899€, 1.499€ oder 2.099€</strong> möglich.</p>"
          }
        },
        "item_V7NfBy": {
          "type": "item",
          "settings": {
            "faq_title": "Kann ich doppelte Messer erhalten?",
            "faq_body": "<p>Wir achten bei der Zusammenstellung darauf, dass jede Box <strong>eine sinnvolle Auswahl verschiedener Messertypen</strong> enthält.<br/><br/>Doppelte Messer werden in der Regel vermieden.</p><p>Vergiss außerdem nicht, sie <strong>gelegentlich zu schärfen und zu ölen</strong> - das macht den Unterschied.</p>"
          }
        },
        "item_Q9DGdb": {
          "type": "item",
          "settings": {
            "faq_title": "Ist die Qualität bei jeder Box gleich hoch?",
            "faq_body": "<p>Ja. Alle Messer stammen aus unserem Sortiment und erfüllen unsere <strong>hohen Qualitätsstandards</strong> – unabhängig davon, welche Box du erhältst.</p>"
          }
        },
        "item_xpq4qN": {
          "type": "item",
          "settings": {
            "faq_title": "Kann ich die Mystery Box zurückgeben?",
            "faq_body": "<p>Ja, du gehst <strong>kein Risiko ein</strong>.<br/><br/>Du kannst deine Bestellung innerhalb von <strong>100 Tagen testen</strong> und erhältst dein Geld zurück, wenn du nicht zufrieden bist.</p>"
          }
        },
        "item_XFGU6y": {
          "type": "item",
          "settings": {
            "faq_title": "Wann wird meine Bestellung geliefert?",
            "faq_body": "<p>Deine Mystery Box wird innerhalb von <strong>1–3 Werktagen</strong> geliefert.<br/><br/>Nach dem Versand erhältst du eine Sendungsverfolgung.</p>"
          }
        },
        "item_PNKhQY": {
          "type": "item",
          "settings": {
            "faq_title": "Warum bietet ihr eine Mystery Box an?",
            "faq_body": "<p>Mit der Mystery Box geben wir dir die Möglichkeit, unsere Produkte zu einem <strong>deutlich reduzierten Preis</strong> kennenzulernen.<br/><br/>Dabei kombinieren wir Überbestände und ausgewählte Modelle zu einem besonders attraktiven Angebot.</p>"
          }
        },
        "item_9JjGkE": {
          "type": "item",
          "settings": {
            "faq_title": "Für wen ist die Mystery Box geeignet?",
            "faq_body": "<p>Die Mystery Box ist ideal für alle, die <strong>hochwertige Küchenmesser zu einem starken Preis</strong> erhalten möchten –<br/><br/>egal ob Einsteiger oder Koch-Enthusiast.</p>"
          }
        }
      },
