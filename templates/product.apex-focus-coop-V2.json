    "trustpilot_testimonials_YbXp3E": {
      "type": "trustpilot-testimonials",
      "blocks": {
        "block_n66cBX": {
          "type": "block",
          "settings": {
            "tes_title": "Sehr hochwertige Verarbeitung",
            "tes_text": "Die Maserung ist wunderschön und jedes Brett sieht anders aus. Man merkt sofort, dass es echtes Olivenholz ist – massiv, schwer und extrem stabil.",
            "user_name": "Katharina M.",
            "date": "Vor 2 Stunden"
          }
        },
        "block_Cjk3qr": {
          "type": "block",
          "settings": {
            "tes_title": "100% Naturgefühl",
            "tes_text": "Ich liebe, dass es keine künstliche Beschichtung hat. Reines Holz, natürlich geölt und perfekt verarbeitet. Fühlt sich unglaublich hochwertig an.",
            "user_name": "Tobias R.",
            "date": "Vor 8 Stunden"
          }
        },
        "block_ncTrUJ": {
          "type": "block",
          "settings": {
            "tes_title": "Ideal für den täglichen Einsatz",
            "tes_text": "Wir nutzen die Bretter täglich – zum Schneiden von Gemüse und zum Servieren von Käse. Kaum Schnittspuren und sehr pflegeleicht.",
            "user_name": "Martina S.",
            "date": "Vor 19 Stunden"
          }
        },
        "block_tk6TF7": {
          "type": "block",
          "settings": {
            "tes_title": "Ein echtes Unikat",
            "tes_text": "Die Maserung ist einzigartig. Kein Brett gleicht dem anderen – genau das macht es so besonders. In unserer Küche ein echter Hingucker.",
            "user_name": "Daniel K.",
            "date": "Vor 25 Stunden"
          }
        },
        "block_qCCEJY": {
          "type": "block",
          "settings": {
            "tes_title": "Qualität, die überzeugt",
            "tes_text": "Ich war erst skeptisch, aber die Qualität hat mich wirklich überrascht. Sehr robust, keine Risse und nach dem Einölen sieht es wieder aus wie neu.",
            "user_name": "Stefan W.",
            "date": "Vor 47 Stunden"
          }
        },
        "block_AVgLTe": {
          "type": "block",
          "settings": {
            "tes_title": "Gut, Schnell, Zuverlässig",
            "tes_text": "Sehr gut, gesamte Bestellung hat die Erwartungen mehr als erfüllt. Probleme seitens DHL wurden sehr schnell von Küchenkompane gelöst.",
            "user_name": "Peter L.",
            "date": "Vor 52 Stunden"
          }
        }
      },
