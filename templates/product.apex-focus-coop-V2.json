    "apex_faqs_jx7hp6": {
      "type": "apex-faqs",
      "blocks": {
        "item_Y76Jjj": {
          "type": "item",
          "settings": {
            "faq_title": "Woher stammt das Olivenholz?",
            "faq_body": "<p>Unser Olivenholz stammt aus Griechenland. Verwendet wird ausschließlich Holz von Bäumen, die keine Früchte mehr tragen. Die Veredelung, das Schleifen und Ölen erfolgen sorgfältig in Deutschland.</p>"
          }
        },
        "item_J7jdRT": {
          "type": "item",
          "settings": {
            "faq_title": "Was bedeutet „Made in Germany“ bei diesem Produkt?",
            "faq_body": "<p>Das Rohmaterial kommt aus Griechenland. Die Weiterverarbeitung, Qualitätskontrolle, Veredelung und Endbehandlung erfolgen in Deutschland – nach höchsten handwerklichen Standards.</p>"
          }
        },
        "item_V7NfBy": {
          "type": "item",
          "settings": {
            "faq_title": "Ist jedes Schneidebrett wirklich ein Unikat?",
            "faq_body": "<p>Ja. Die charakteristische Maserung entsteht natürlich im Baum. Kein Stück gleicht dem anderen – jedes Brett ist ein echtes Einzelstück.</p>"
          }
        },
        "item_Q9DGdb": {
          "type": "item",
          "settings": {
            "faq_title": "Ist Olivenholz hygienisch?",
            "faq_body": "<p>Olivenholz besitzt eine sehr dichte Struktur und natürliche antibakterielle Eigenschaften. Es nimmt weniger Feuchtigkeit auf als viele andere Holzarten und ist daher besonders hygienisch im täglichen Einsatz.</p>"
          }
        },
        "item_xpq4qN": {
          "type": "item",
          "settings": {
            "faq_title": "Wie pflege ich mein Olivenholz-Brett richtig?",
            "faq_body": "<p>Einfach mit lauwarmem Wasser reinigen, gut trocknen lassen und regelmäßig mit etwas Speiseöl (z. B. Olivenöl) nachölen. Nicht spülmaschinengeeignet.</p>"
          }
        },
        "item_XFGU6y": {
          "type": "item",
          "settings": {
            "faq_title": "Ist das Brett spülmaschinengeeignet?",
            "faq_body": "<p>Nein. Wie jedes hochwertige Naturholz sollte es nicht in die Spülmaschine gegeben werden, da Hitze und Feuchtigkeit das Material beschädigen können.</p>"
          }
        },
        "item_cDC8UT": {
          "type": "item",
          "settings": {
            "faq_title": "Kann das Holz reißen?",
            "faq_body": "<p>Bei richtiger Pflege ist Olivenholz extrem widerstandsfähig. Wichtig ist, das Brett nicht dauerhaft Nässe oder starker Hitze auszusetzen und es gelegentlich nachzuölen.</p>"
          }
        },
        "item_PNKhQY": {
          "type": "item",
          "settings": {
            "faq_title": "Ist das Holz nachhaltig?",
            "faq_body": "<p>Ja. Das Holz stammt von alten, nicht mehr ertragreichen Olivenbäumen. Es wird kein Baum ausschließlich für unsere Produkte gefällt.</p>"
          }
        }
      },
