    "apex_faqs_jx7hp6": {
      "type": "apex-faqs",
      "blocks": {
        "item_Y76Jjj": {
          "type": "item",
          "settings": {
            "faq_title": "Was macht Küchenkompane Messer so besonders?",
            "faq_body": "<p>Unsere Messer verbinden kompromisslose Schärfe mit hochwertigem Design und einem unschlagbaren Preis-Leistungs-Verhältnis. Jedes Messer ist auf maximale Präzision ausgelegt – für ein neues Schneideerlebnis.</p>"
          }
        },
        "item_J7jdRT": {
          "type": "item",
          "settings": {
            "faq_title": "Aus welchem Material bestehen die Klingen?",
            "faq_body": "<p>Wir verwenden rostfreien 7CR17 Edelstahl, der für seine hohe Schnitthaltigkeit, Korrosionsbeständigkeit und Langlebigkeit bekannt ist.</p>"
          }
        },
        "item_V7NfBy": {
          "type": "item",
          "settings": {
            "faq_title": "Wie lange bleiben die Messer scharf?",
            "faq_body": "<p>Unsere Messer bleiben bei normaler Nutzung überdurchschnittlich lange scharf. Bei Bedarf lassen sie sich mit dem mitgelieferten 3-Stufen-Schärfer ganz einfach nachschärfen.</p>"
          }
        },
        "item_Q9DGdb": {
          "type": "item",
          "settings": {
            "faq_title": "Kann ich Küchenkompane Messer in der Spülmaschine reinigen?",
            "faq_body": "<p>Wir empfehlen die schonende Handwäsche, um Griff und Klinge langfristig zu schützen. Für maximale Lebensdauer: Bitte nach dem Reinigen direkt abtrocknen.</p>"
          }
        },
        "item_xpq4qN": {
          "type": "item",
          "settings": {
            "faq_title": "Warum sollte ich mich für Küchenkompane entscheiden?",
            "faq_body": "<p>Küchenkompane steht für Qualität, Schärfe, Stil und Kundennähe. Über 140.000 zufriedene Kund:innen vertrauen bereits auf unsere Produkte – und das nicht ohne Grund.</p>"
          }
        },
        "item_XFGU6y": {
          "type": "item",
          "settings": {
            "faq_title": "Gibt es eine Geld-zurück-Garantie oder ein Rückgaberecht?",
            "faq_body": "<p>Ja! Du kannst dein Produkt 100 Tage lang risikofrei testen. Solltest du nicht überzeugt sein, bekommst du dein Geld zurück.</p>"
          }
        },
        "item_cDC8UT": {
          "type": "item",
          "settings": {
            "faq_title": "Wie lange dauert der Versand? Gibt es Expressversand?",
            "faq_body": "<p>In der Regel dauert der Versand 1–3 Werktage. Je nach Aktion und Region bieten wir gelegentlich auch Expressversand an.<br/></p>"
          }
        },
        "item_PNKhQY": {
          "type": "item",
          "settings": {
            "faq_title": "Welche Zahlungsmethoden bietet Küchenkompane an?",
            "faq_body": "<p>Du kannst sicher und bequem mit PayPal, Kreditkarte, Klarna, Apple Pay, Google Pay und vielen weiteren Optionen zahlen.<br/></p>"
          }
        },
        "item_9JjGkE": {
          "type": "item",
          "settings": {
            "faq_title": "Gibt es eine Garantie auf die Produkte?",
            "faq_body": "<p>Ja, wir bieten eine 2-jährige Garantie auf alle Küchenkompane Produkte.</p>"
          }
        }
      },
