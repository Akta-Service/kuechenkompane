
{%- if product -%}
  <article class="black-friday-collection-card" role="listitem" aria-label="{{ product.title | escape }}">
    
    {%- assign compare_max = product.compare_at_price_max -%}
    {%- assign on_sale = false -%}
    {%- if compare_max and compare_max > product.price -%}
      {%- assign on_sale = true -%}
    {%- endif -%}

    {%- if on_sale and section.settings.show_on_sale -%}
      {%- assign discount = compare_max | minus: product.price -%}
      {%- assign pct = 0 -%}
      {%- if compare_max > 0 -%}
        {%- assign pct = discount | times: 100 | divided_by: compare_max -%}
      {%- endif -%}
      <div class="black-friday-collection-card__badge">
        {%- if sale_tag_text != blank -%}
          {{ sale_tag_text }}
        {%- else -%}
          -{{ pct }}%
        {%- endif -%}
      </div>
    {%- endif -%}
    
    <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
      <div class="black-friday-collection-card__media">
        {%- assign image = product.featured_image -%}
        {%- if image -%}
            <img
            src="{{ image | image_url: width: 226 , height: 283 }}"
            srcset="
              {{ image | image_url: width: 300 }} 300w,
              {{ image | image_url: width: 500 }} 500w,
              {{ image | image_url: width: 700 }} 700w,
              {{ image | image_url: width: 900 }} 900w
            "
            sizes="(max-width: 767px) 60vw, (max-width: 1023px) 40vw, 25vw"
            alt="{{ image.alt | default: product.title | escape }}"
            loading="{% if is_first %}eager{% else %}lazy{% endif %}"
            fetchpriority="{% if is_first %}high{% else %}auto{% endif %}"
            decoding="async"
            width="500"
            height="500"
            style="aspect-ratio: {{ image.aspect_ratio }};"
          >
        {%- endif -%}
      </div>

      <div class="black-friday-collection-card__title">{{ product.title | escape }}</div>

      <div class="black-friday-collection-card__price">
        {{ product.price | money }}
        {% if on_sale %}
          <span class="compare">{{ compare_max | money }}</span>
        {% endif %}
      </div>
    </a>

  </article>
{%- endif -%}