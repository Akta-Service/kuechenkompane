        ]
        {% endif %}
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
    {% endif %}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  ];
    console.log(menuItems);
</script>
