              fill="#454545"></path> 
          </svg>
        
        </div>
        <ul class="mobile--menu-sub-dropdown">
          ${grandChildrenHTML}
        </ul>
      </li>
    `;
    } else {
      return `
      <li class="mobile--menu-navigation-sub-item">
        <a href="${child.url}" class="mobile--menu-navigation-sub-item-wrapper">
          <img src="${child.image}" alt="${child.title}" class="mobile--menu-navigation-item-image">
          <span class="mobile--menu-item-sub-title">${child.title}</span>
        </a>
      </li>
    `;
    }
  };

  // Helper to render top-level item
