      text-align: center;
      border-radius: 12px;
      box-shadow: 0 3px 15px 6px #00000026;
      display: flex;
      flex-direction: column;
      position: relative;
      text-align: center;
    }
    .language--popup-close svg.Icon.Icon--close {
