          <div class="mobile--menu-sub-content">
            <ul class="mobile--menu-sub-navigation">
              ${childrenHTML}
            </ul>
          </div>
        </div>
      </li>
    `;
    } else {
      return `
      <li>
        <a class="mobile--menu-navigation-item" href="${item.url}">
          <span class="mobile--menu-item-title">${item.title}</span>
        </a>
      </li>
    `;
    }
  };

  // Render all menu items
  menuData.forEach((item) => {
    menuContainer.insertAdjacentHTML('beforeend', renderMenuItem(item));
  });
</script>


<script>
  const menuItems = [
  {% for link in linklists[section.settings.main_menu].links %}
