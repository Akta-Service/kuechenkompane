    flex-direction: column;
    left: 0;
    overflow: hidden;
    pointer-events: none;
    position: fixed;
    right: 0;
    top: 0;
    transform: translate(-100%);
    transition:  0.5s;
    z-index: 100;
    opacity: 0;
  }

  .menu--open {
    pointer-events: all;
    transform: translate(0);
    opacity: 1;


  }

