{% if block.settings.show_only_in_editor %}
  {% unless request.design_mode %}
    {% style %}
      body #floow-social-proof-{{ block.id }} { display: none; }
    {% endstyle %}
  {% endunless %}
{% endif %}

<style>
  #floow-social-proof-{{ block.id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    flex-wrap: wrap;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    text-decoration: none;
    cursor: {% if block.settings.open_modal %}pointer{% else %}default{% endif %};
  }
  #floow-social-proof-{{ block.id }} .floow-sp__avatars {
    display: flex;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  #floow-social-proof-{{ block.id }} .floow-sp__avatar {
    width: {{ block.settings.avatar_size }}px;
    height: {{ block.settings.avatar_size }}px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid {{ block.settings.avatar_border_color }};
    margin-left: -{{ block.settings.avatar_overlap }}px;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }
  #floow-social-proof-{{ block.id }} .floow-sp__avatar:first-child {
    margin-left: 0;
  }
  #floow-social-proof-{{ block.id }} .floow-sp__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #floow-social-proof-{{ block.id }} .floow-sp__avatar--placeholder {
    background-color: #e0d9d0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #floow-social-proof-{{ block.id }} .floow-sp__avatar--placeholder svg {
    width: 55%;
    height: 55%;
    fill: #b0a898;
  }
  #floow-social-proof-{{ block.id }} .floow-sp__text-group {
    display: flex;
    align-items: center;
    gap: {{ block.settings.text_gap }}px;
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }
  #floow-social-proof-{{ block.id }} .floow-sp__badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: 999px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    white-space: nowrap;
    margin-left: {{ block.settings.badge_offset }}px;
    position: relative;
    z-index: 1;
  }
  #floow-social-proof-{{ block.id }} .floow-sp__label {
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: {{ block.settings.label_font_weight }};
    white-space: nowrap;
  }

  #floow-sp-hidden-content-{{ block.id }} {
    display: none;
  }
  #floow-sp-hidden-content-{{ block.id }} .floow-sp-modal__header {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }
  #floow-sp-hidden-content-{{ block.id }} .floow-sp-modal__title {
    font-size: 22px;
    font-weight: 600;
    margin: 0;
    text-align: center;
  }
  #floow-sp-hidden-content-{{ block.id }} iframe {
    display: block;
    width: 100%;
    height: 4000px;
    border: none;
  }
</style>

<div class="floow-sp-trigger" id="floow-social-proof-{{ block.id }}" {{ block.shopify_attributes }}>
  {% assign has_any_avatar = false %}
  {% if block.settings.avatar_1 != blank or block.settings.avatar_2 != blank or block.settings.avatar_3 != blank %}
    {% assign has_any_avatar = true %}
  {% endif %}

  {% if has_any_avatar %}
    <div class="floow-sp__avatars">
      {% for i in (1..3) %}
        {% assign avatar_key = 'avatar_' | append: i %}
        {% assign avatar_img = block.settings[avatar_key] %}
        <div class="floow-sp__avatar">
          {% if avatar_img != blank %}
            <img
              src="{{ avatar_img | image_url: width: 120 }}"
              alt="Avatar {{ i }}"
              width="{{ block.settings.avatar_size }}"
              height="{{ block.settings.avatar_size }}"
              loading="lazy"
            >
          {% else %}
            <div class="floow-sp__avatar--placeholder">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <div class="floow-sp__text-group">
    {% if block.settings.badge_text != blank %}
      <span class="floow-sp__badge">{{ block.settings.badge_text }}</span>
    {% endif %}
    {% if block.settings.label != blank %}
      <span class="floow-sp__label">{{ block.settings.label }}</span>
    {% endif %}
  </div>
</div>

{% if block.settings.open_modal %}
  <div id="floow-sp-hidden-content-{{ block.id }}" class="floow-modal-hidden-content">
    <div class="floow-sp-modal__header">
      <p class="floow-sp-modal__title">{{ block.settings.modal_title | default: 'Das sagen unsere Kunden' }}</p>
    </div>
    {% if block.settings.modal_loox_url != blank %}
      <iframe
        id="floow-sp-modal-iframe-{{ block.id }}"
        src="{{ block.settings.modal_loox_url }}"
        frameborder="0"
        scrolling="no"
      ></iframe>
    {% endif %}
  </div>

  <script>
    (function() {
      var trigger = document.getElementById('floow-social-proof-{{ block.id }}');
      var hiddenContent = document.getElementById('floow-sp-hidden-content-{{ block.id }}');

      if (!trigger || !hiddenContent) return;

      trigger.addEventListener('click', function() {
        floowOpenModal(hiddenContent);
      });
    })();
  </script>
{% endif %}