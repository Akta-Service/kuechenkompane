{%- comment -%}
  ----------------------------------------------------------------------------------------------------------------------
  QUICK BUY SNIPPET
  ----------------------------------------------------------------------------------------------------------------------

  Zeigt einen "In den Warenkorb"-Button auf Produktkarten.
  - Einvarianten-Produkte: direktes Add-to-Cart via Shopify AJAX API
  - Mehrvarianten-Produkte: öffnet ein Modal zur Variantenauswahl

  Nutzt MCartDrawer.onCartDrawerUpdate() des Minimog-Themes zum Aktualisieren
  des Warenkorbs nach dem Hinzufügen.

  ********************************************
  Einbindung in der Produktkarte
  ********************************************

  {% render 'quick-buy', product: product %}

  ********************************************
  Unterstützte Variablen
  ********************************************

  * product  – Produkt-Objekt (Pflicht)
{%- endcomment -%}

{%- liquid
  assign has_variants = false
  if product.variants.size > 1
    assign has_variants = true
  endif
  assign first_variant = product.selected_or_first_available_variant
-%}

{%- capture button_label -%}
    <span>In den Warenkorb</span>
  {%- endcapture -%}

{%- if has_variants -%}
  <button
    type="button"
    class="fqb-btn floow-quick-add-button m-button m-button--primary"
    data-fqb-open="{{ product.id }}"
    aria-haspopup="dialog"
    aria-label="Variante wählen für {{ product.title | escape }}"
    {% unless first_variant.available %}
      disabled aria-disabled="true"
    {% endunless %}
  >
    {{- button_label -}}
  </button>

  <div
    class="fqb-modal"
    id="fqb-modal-{{ product.id }}"
    role="dialog"
    aria-modal="true"
    aria-label="Variante wählen"
    hidden
  >
    <div class="fqb-modal__backdrop" data-fqb-close="{{ product.id }}"></div>
    <div class="fqb-modal__box">
      <button
        type="button"
        class="fqb-modal__close"
        data-fqb-close="{{ product.id }}"
        aria-label="Schließen"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <p class="fqb-modal__title">{{ product.title | escape }}</p>

      {%- for option in product.options_with_values -%}
        <div class="fqb-modal__option-group">
          <p class="fqb-modal__option-label">{{ option.name | escape }}</p>
          <div class="fqb-modal__option-values">
            {%- for value in option.values -%}
              <button
                type="button"
                class="fqb-modal__option-btn"
                data-option-pos="{{ option.position }}"
                data-option-val="{{ value | escape }}"
              >
                {{- value | escape -}}
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}

      <script type="application/json" data-fqb-variants="{{ product.id }}">
        [
          {%- for variant in product.variants -%}
            {
              "id": {{ variant.id }},
              "available": {{ variant.available }},
              "options": [
                {%- for opt in variant.options -%}
                  {{ opt | json }}{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              ]
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      </script>

      <button
        type="button"
        class="fqb-modal__add-btn"
        data-fqb-add="{{ product.id }}"
        disabled
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13l-1.6 8H19M7 13L5.4 5M10 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z"/>
        </svg>
        <span>In den Warenkorb</span>
      </button>
    </div>
  </div>

{%- else -%}
  <button
    type="button"
    class="fqb-btn floow-quick-add-button m-button m-button--primary"
    data-fqb-single-add="{{ first_variant.id }}"
    aria-label="{{ product.title | escape }} in den Warenkorb legen"
    {% unless first_variant.available %}
      disabled aria-disabled="true"
    {% endunless %}
  >
    {{- button_label -}}
  </button>
{%- endif -%}

<style>
  /* ── Button ─────────────────────────────────────────────── */
  .fqb-btn {
    display: none;
    {% if request.design_mode %}
    display: flex;
    {% endif %}
    align-items: center;
    justify-content: center;
    gap: 5px;
    margin-bottom: 10px;
    @media(max-width: 768px) {
        font-size: 13px;
    }
  }

  /* ── Modal ───────────────────────────────────────────────── */
  .fqb-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  @media (min-width: 640px) {
    .fqb-modal { align-items: center; }
  }
  .fqb-modal[hidden] { display: none; }

  .fqb-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    cursor: pointer;
  }

  .fqb-modal__box {
    position: relative;
    background: #fff;
    border-radius: 16px 16px 0 0;
    padding: 24px 20px 28px;
    width: 100%;
    max-width: 480px;
    max-height: 90vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  @media (min-width: 640px) {
    .fqb-modal__box { border-radius: 16px; }
  }

  .fqb-modal__close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    cursor: pointer;
    color: #555;
    padding: 4px;
    line-height: 0;
  }
  .fqb-modal__close:hover { color: #111; }

  .fqb-modal__title {
    font-size: 16px;
    font-weight: 700;
    margin: 0;
    padding-right: 28px;
  }

  .fqb-modal__option-group { display: flex; flex-direction: column; gap: 8px; }

  .fqb-modal__option-label {
    font-size: 13px;
    font-weight: 600;
    color: #555;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .fqb-modal__option-values { display: flex; flex-wrap: wrap; gap: 8px; }

  .fqb-modal__option-btn {
    padding: 6px 14px;
    border: 1.5px solid #ddd;
    border-radius: 6px;
    background: #fff;
    font-size: 14px;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .fqb-modal__option-btn:hover { border-color: #111; }
  .fqb-modal__option-btn.is-selected {
    border-color: #111;
    background: #111;
    color: #fff;
  }
  .fqb-modal__option-btn.is-unavailable {
    opacity: 0.35;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  .fqb-modal__add-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 12px 16px;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, opacity 0.2s;
    margin-top: 4px;
  }
  .fqb-modal__add-btn:hover:not(:disabled) { background: #333; }
  .fqb-modal__add-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .fqb-modal__add-btn--loading { opacity: 0.7; pointer-events: none; }
</style>

<script>
  (function () {
    if (window.__fqbInit) return;
    window.__fqbInit = true;

    const ROOT_URL = window.Shopify?.routes?.root ?? '/';

    /* ── Warenkorb aktualisieren (Minimog API) ─────────────── */
    function refreshCart() {
      const drawer = document.querySelector('m-cart-drawer');
      if (drawer && typeof drawer.onCartDrawerUpdate === 'function') {
        drawer.onCartDrawerUpdate(true);
        if (typeof drawer.open === 'function') drawer.open();
      }
    }

    /* ── AJAX Add-to-Cart ───────────────────────────────────── */
    async function addToCart(variantId, btn) {
      btn.classList.add('fqb-btn--loading', 'fqb-modal__add-btn--loading');
      btn.disabled = true;

      try {
        const res = await fetch(`${ROOT_URL}cart/add.js`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ id: variantId, quantity: 1 }),
        });

        if (!res.ok) throw new Error('add-to-cart failed');
        refreshCart();
      } catch (err) {
        console.error('[quick-buy]', err);
      } finally {
        btn.classList.remove('fqb-btn--loading', 'fqb-modal__add-btn--loading');
        btn.disabled = false;
      }
    }

    /* ── Modal öffnen / schließen ───────────────────────────── */
    function openModal(productId) {
      const modal = document.getElementById(`fqb-modal-${productId}`);
      if (!modal) return;
      modal.hidden = false;
      document.documentElement.classList.add('prevent-scroll');
      modal.querySelector('.fqb-modal__close')?.focus();
    }

    function closeModal(productId) {
      const modal = document.getElementById(`fqb-modal-${productId}`);
      if (!modal) return;
      modal.hidden = true;
      document.documentElement.classList.remove('prevent-scroll');
    }

    /* ── Variantenlogik ─────────────────────────────────────── */
    function getVariants(productId) {
      const el = document.querySelector(`[data-fqb-variants="${productId}"]`);
      if (!el) return [];
      try {
        return JSON.parse(el.textContent);
      } catch {
        return [];
      }
    }

    function resolveVariant(productId, selectedOptions) {
      return getVariants(productId).find((v) => v.options.every((opt, i) => opt === selectedOptions[i])) ?? null;
    }

    function updateAddButton(modal, variant) {
      const btn = modal.querySelector('[data-fqb-add]');
      if (!btn) return;
      btn.disabled = !variant?.available;
    }

    function updateOptionButtons(modal, productId) {
      const groups = modal.querySelectorAll('.fqb-modal__option-group');
      const selectedOptions = [];

      groups.forEach((group, gi) => {
        const selected = group.querySelector('.fqb-modal__option-btn.is-selected');
        selectedOptions[gi] = selected?.dataset.optionVal ?? null;
      });

      /* Verfügbarkeit pro Option berechnen */
      groups.forEach((group, gi) => {
        group.querySelectorAll('.fqb-modal__option-btn').forEach((btn) => {
          const testOptions = [...selectedOptions];
          testOptions[gi] = btn.dataset.optionVal;

          if (testOptions.every((o) => o !== null)) {
            const variant = resolveVariant(productId, testOptions);
            btn.classList.toggle('is-unavailable', !variant?.available);
          }
        });
      });

      const variant = resolveVariant(productId, selectedOptions);
      updateAddButton(modal, variant);
      return variant;
    }

    /* ── Event-Delegation (document-level) ─────────────────── */
    document.addEventListener('click', function (e) {
      /* Button: öffnet Modal */
      const openBtn = e.target.closest('[data-fqb-open]');
      if (openBtn) {
        openModal(openBtn.dataset.fqbOpen);
        return;
      }

      /* Backdrop / Close: schließt Modal */
      const closeEl = e.target.closest('[data-fqb-close]');
      if (closeEl) {
        closeModal(closeEl.dataset.fqbClose);
        return;
      }

      /* Einzel-Variante: direktes Add-to-Cart */
      const singleBtn = e.target.closest('[data-fqb-single-add]');
      if (singleBtn) {
        addToCart(singleBtn.dataset.fqbSingleAdd, singleBtn);
        return;
      }

      /* Varianten-Option wählen */
      const optionBtn = e.target.closest('.fqb-modal__option-btn');
      if (optionBtn) {
        const group = optionBtn.closest('.fqb-modal__option-group');
        group.querySelectorAll('.fqb-modal__option-btn').forEach((b) => b.classList.remove('is-selected'));
        optionBtn.classList.add('is-selected');

        const modal = optionBtn.closest('.fqb-modal');
        const productId = modal?.id.replace('fqb-modal-', '');
        if (productId) updateOptionButtons(modal, productId);
        return;
      }

      /* Add-to-Cart aus Modal */
      const addBtn = e.target.closest('[data-fqb-add]');
      if (addBtn) {
        const productId = addBtn.dataset.fqbAdd;
        const modal = document.getElementById(`fqb-modal-${productId}`);
        if (!modal) return;

        const selectedOptions = [...modal.querySelectorAll('.fqb-modal__option-group')].map(
          (g) => g.querySelector('.fqb-modal__option-btn.is-selected')?.dataset.optionVal ?? null
        );

        const variant = resolveVariant(productId, selectedOptions);
        if (!variant?.available) return;

        addToCart(variant.id, addBtn).then(() => closeModal(productId));
        return;
      }
    });

    /* ESC schließt offenes Modal */
    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      document.querySelectorAll('.fqb-modal:not([hidden])').forEach((modal) => {
        closeModal(modal.id.replace('fqb-modal-', ''));
      });
    });
  })();
</script>
