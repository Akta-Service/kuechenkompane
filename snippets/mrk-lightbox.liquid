
{% unless mrk_lightbox_rendered %}
  {% assign mrk_lightbox_rendered = true %}

<style id="mrk-lb-style">
  .mrk-lb {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 2147483647 !important;
    background: rgba(0,0,0,.92);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    isolation: isolate;
    touch-action: none;
  }
  .mrk-lb.open { display: flex; }

  .mrk-lb-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    display: flex;
    align-items: center;
    padding: 12px 16px;
    gap: 8px;
    z-index: 2;
  }
  .mrk-lb-count {
    color: rgba(255,255,255,.7);
    font-size: 14px;
    margin-right: auto;
    font-family: sans-serif;
    user-select: none;
  }
  .mrk-lb-btn {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,.15);
    border: none; color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background .2s;
  }
  .mrk-lb-btn:hover { background: rgba(255,255,255,.28); }
  .mrk-lb-btn svg { width: 18px; height: 18px; pointer-events: none; }

  .mrk-lb-track {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    will-change: transform;
    touch-action: pan-y;
  }

  .mrk-lb-slide {
    min-width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .mrk-lb-slide img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    transform-origin: center;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
    display: block;
    will-change: transform;
  }

  .mrk-lb-arr {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 46px; height: 46px;
    border-radius: 50%;
    background: rgba(255,255,255,.15);
    border: none; color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background .2s;
  }
  .mrk-lb-arr:hover { background: rgba(255,255,255,.28); }
  .mrk-lb-arr svg { width: 22px; height: 22px; }
  .mrk-lb-prev { left: 14px; }
  .mrk-lb-next { right: 14px; }

  .mrk-lb-hint {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,.4);
    font-size: 12px;
    font-family: sans-serif;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    transition: opacity .3s;
  }

  @media (max-width: 600px) {
    .mrk-lb-arr { display: none; }
  }
</style>

<div id="mrk-lb" class="mrk-lb" role="dialog" aria-modal="true" aria-label="Image viewer">
  <div class="mrk-lb-bar">
    <span class="mrk-lb-count" id="mrk-lb-count"></span>
    <button class="mrk-lb-btn" id="mrk-lb-zout" aria-label="Zoom out">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/>
      </svg>
    </button>
    <button class="mrk-lb-btn" id="mrk-lb-zin" aria-label="Zoom in">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
      </svg>
    </button>
    <button class="mrk-lb-btn" id="mrk-lb-zreset" aria-label="Reset zoom">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>
      </svg>
    </button>
    <button class="mrk-lb-btn" id="mrk-lb-close" aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="mrk-lb-track" id="mrk-lb-track"></div>

  <button class="mrk-lb-arr mrk-lb-prev" id="mrk-lb-prev" aria-label="Previous image">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </button>
  <button class="mrk-lb-arr mrk-lb-next" id="mrk-lb-next" aria-label="Next image">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>

  <span class="mrk-lb-hint" id="mrk-lb-hint">Scroll to zoom &nbsp;·&nbsp; Swipe to navigate</span>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var lb = document.getElementById('mrk-lb');
    if (lb && lb.parentNode !== document.body) {
      document.body.appendChild(lb);
    }
  });
</script>

<script>
(function () {
  if (window.mrkLightboxInit) return;
  window.mrkLightboxInit = true;

  var lb        = document.getElementById('mrk-lb');
  var lbTrack   = document.getElementById('mrk-lb-track');
  var lbCount   = document.getElementById('mrk-lb-count');
  var lbHint    = document.getElementById('mrk-lb-hint');
  var btnClose  = document.getElementById('mrk-lb-close');
  var btnPrev   = document.getElementById('mrk-lb-prev');
  var btnNext   = document.getElementById('mrk-lb-next');
  var btnZin    = document.getElementById('mrk-lb-zin');
  var btnZout   = document.getElementById('mrk-lb-zout');
  var btnZreset = document.getElementById('mrk-lb-zreset');

  var idx = 0, imgs = [];
  var scale = 1, zx = 0, zy = 0;
  var MIN = 1, MAX = 4, STEP = 0.4;
  var trackX = 0;

  /* ── Slide width — scrollbar-safe ── */
  function getSlideWidth() {
    return lb.offsetWidth || window.innerWidth;
  }

  /* ── Track position ── */
  function setTrack(x, animate) {
    lbTrack.style.transition = animate
      ? 'transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94)'
      : 'none';
    lbTrack.style.transform = 'translateX(' + x + 'px)';
    trackX = x;
  }

  function snapTo(i, animate) {
    if (!imgs.length) return;
    idx = ((i % imgs.length) + imgs.length) % imgs.length;
    setTrack(-idx * getSlideWidth(), animate !== false);
    lbCount.textContent = (idx + 1) + ' / ' + imgs.length;
    btnPrev.style.display = imgs.length > 1 ? '' : 'none';
    btnNext.style.display = imgs.length > 1 ? '' : 'none';
    resetZoom(false);
  }

  /* ── Zoom (current slide only) ── */
  function currentImg() {
    var slide = lbTrack.children[idx];
    return slide ? slide.querySelector('img') : null;
  }

  function applyZoom(animate) {
    var img = currentImg();
    if (!img) return;
    img.style.transition = animate ? 'transform 0.2s ease' : 'none';
    img.style.transform  = 'translate(' + zx + 'px,' + zy + 'px) scale(' + scale + ')';
  }

  function resetZoom(animate) {
    scale = 1; zx = 0; zy = 0;
    applyZoom(animate !== false);
  }

  function clampZoom() {
    if (scale <= 1) { zx = 0; zy = 0; return; }
    var img = currentImg();
    if (!img) return;
    var r  = img.getBoundingClientRect();
    var ox = Math.max(0, (r.width  - window.innerWidth)  / 2);
    var oy = Math.max(0, (r.height - window.innerHeight) / 2);
    zx = Math.min(ox,  Math.max(-ox, zx));
    zy = Math.min(oy,  Math.max(-oy, zy));
  }

  /* ── Build slides ── */
  function buildSlides() {
    lbTrack.innerHTML = '';
    imgs.forEach(function(img) {
      var slide = document.createElement('div');
      slide.className = 'mrk-lb-slide';
      var el = document.createElement('img');
      el.src = img.src;
      el.alt = img.alt || '';
      el.draggable = false;
      slide.appendChild(el);
      lbTrack.appendChild(slide);
    });
  }

  /* ── Touch swipe ── */
  var tsX = 0, tsY = 0, tsT = 0;
  var tCurX = 0, tActive = false, tIsHoriz = null;

  function onTouchStart(e) {
    if (scale > 1) return;
    var t = e.touches ? e.touches[0] : e;
    tsX = t.clientX; tsY = t.clientY; tsT = Date.now();
    tCurX = 0; tActive = true; tIsHoriz = null;
    lbTrack.style.transition = 'none';
  }

  function onTouchMove(e) {
    if (!tActive || scale > 1) return;
    var t = e.touches ? e.touches[0] : e;
    var dx = t.clientX - tsX;
    var dy = t.clientY - tsY;

    if (tIsHoriz === null) {
      tIsHoriz = Math.abs(dx) > Math.abs(dy);
    }
    if (!tIsHoriz) return;
    if (e.cancelable) e.preventDefault();

    tCurX = dx;
    var resist = ((idx === 0 && dx > 0) || (idx === imgs.length - 1 && dx < 0)) ? 0.25 : 1;
    lbTrack.style.transform = 'translateX(' + (-idx * getSlideWidth() + dx * resist) + 'px)';
  }

  function onTouchEnd() {
    if (!tActive) return;
    tActive = false;

    var dt       = Date.now() - tsT;
    var velocity = Math.abs(tCurX) / dt;
    var threshold = getSlideWidth() * 0.25;
    var shouldSlide = Math.abs(tCurX) > threshold || velocity > 0.3;

    if (shouldSlide && tIsHoriz) {
      if (tCurX > 0 && idx > 0)                  snapTo(idx - 1, true);
      else if (tCurX < 0 && idx < imgs.length - 1) snapTo(idx + 1, true);
      else                                          snapTo(idx, true);
    } else {
      snapTo(idx, true);
    }
    tCurX = 0;
  }

  lbTrack.addEventListener('touchstart',  onTouchStart, { passive: true });
  lbTrack.addEventListener('touchmove',   onTouchMove,  { passive: false });
  lbTrack.addEventListener('touchend',    onTouchEnd);
  lbTrack.addEventListener('touchcancel', onTouchEnd);

  /* ── Mouse drag ── */
  var mDown = false, mSX = 0, mCX = 0;

  lbTrack.addEventListener('mousedown', function(e) {
    if (scale > 1) return;
    mDown = true; mSX = e.clientX; mCX = 0;
    lbTrack.style.transition = 'none';
    lbTrack.style.cursor = 'grabbing';
    e.preventDefault();
  });

  window.addEventListener('mousemove', function(e) {
    if (!mDown || scale > 1) return;
    mCX = e.clientX - mSX;
    var resist = ((idx === 0 && mCX > 0) || (idx === imgs.length - 1 && mCX < 0)) ? 0.25 : 1;
    lbTrack.style.transform = 'translateX(' + (-idx * getSlideWidth() + mCX * resist) + 'px)';
  });

  window.addEventListener('mouseup', function() {
    if (!mDown) return;
    mDown = false;
    lbTrack.style.cursor = '';
    if (Math.abs(mCX) > getSlideWidth() * 0.2) {
      if (mCX > 0 && idx > 0)                  snapTo(idx - 1, true);
      else if (mCX < 0 && idx < imgs.length - 1) snapTo(idx + 1, true);
      else                                        snapTo(idx, true);
    } else {
      snapTo(idx, true);
    }
    mCX = 0;
  });

  /* ── Zoom — mouse wheel ── */
  lb.addEventListener('wheel', function(e) {
    e.preventDefault();
    scale = Math.min(MAX, Math.max(MIN, scale + (e.deltaY < 0 ? STEP : -STEP)));
    if (scale <= 1) { zx = 0; zy = 0; }
    applyZoom(false);
  }, { passive: false });

  /* ── Zoom — pinch ── */
  var pinchD = 0, pinchS = 1;

  lb.addEventListener('touchstart', function(e) {
    if (e.touches.length === 2) {
      pinchD = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
      pinchS = scale;
    }
  }, { passive: true });

  lb.addEventListener('touchmove', function(e) {
    if (e.touches.length === 2) {
      e.preventDefault();
      var d = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY
      );
      scale = Math.min(MAX, Math.max(MIN, pinchS * (d / pinchD)));
      if (scale <= 1) { zx = 0; zy = 0; }
      applyZoom(false);
    }
  }, { passive: false });

  /* ── Zoom — pan (zoomed in) ── */
  var zdsx, zdsy, zdpx, zdpy;

  lb.addEventListener('mousedown', function(e) {
    if (scale <= 1) return;
    zdsx = e.clientX; zdsy = e.clientY; zdpx = zx; zdpy = zy;
  });

  window.addEventListener('mousemove', function(e) {
    if (scale <= 1 || !zdsx) return;
    zx = zdpx + (e.clientX - zdsx);
    zy = zdpy + (e.clientY - zdsy);
    clampZoom();
    applyZoom(false);
  });

  window.addEventListener('mouseup', function() { zdsx = null; });

  /* ── Double tap zoom ── */
  var lastTap = 0;

  lb.addEventListener('touchend', function(e) {
    if (e.touches.length !== 0) return;
    var now = Date.now();
    if (now - lastTap < 300) {
      scale > 1
        ? resetZoom(true)
        : (function() { scale = 2.5; applyZoom(true); })();
    }
    lastTap = now;
  });

  /* ── Hint auto-hide ── */
  var hintTimer;

  function showHint() {
    lbHint.style.opacity = '1';
    clearTimeout(hintTimer);
    hintTimer = setTimeout(function() { lbHint.style.opacity = '0'; }, 2500);
  }

  /* ── Open / Close ── */
  function open(imageArray, startIndex) {
    imgs = imageArray || [];
    buildSlides();
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';

    lbTrack.style.transition = 'none';
    lbTrack.style.transform  = 'translateX(0)';
    trackX = 0;

    /* scrollbar banda howar pore width newa */
    requestAnimationFrame(function() {
      snapTo(startIndex || 0, false);
    });

    showHint();
  }

  function close() {
    lb.classList.remove('open');
    document.body.style.overflow = '';
    resetZoom(false);
  }

  /* ── Controls ── */
  btnClose.addEventListener('click', close);
  lb.addEventListener('click', function(e) {
    if (e.target === lb) close();
  });
  btnPrev.addEventListener('click',   function(e) { e.stopPropagation(); snapTo(idx - 1, true); });
  btnNext.addEventListener('click',   function(e) { e.stopPropagation(); snapTo(idx + 1, true); });
  btnZin.addEventListener('click',    function(e) { e.stopPropagation(); scale = Math.min(MAX, scale + STEP); applyZoom(true); });
  btnZout.addEventListener('click',   function(e) { e.stopPropagation(); scale = Math.max(MIN, scale - STEP); if (scale <= 1) { zx = 0; zy = 0; } applyZoom(true); });
  btnZreset.addEventListener('click', function(e) { e.stopPropagation(); resetZoom(true); });

  document.addEventListener('keydown', function(e) {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape')      close();
    if (e.key === 'ArrowLeft')   snapTo(idx - 1, true);
    if (e.key === 'ArrowRight')  snapTo(idx + 1, true);
    if (e.key === '+' || e.key === '=') { scale = Math.min(MAX, scale + STEP); applyZoom(true); }
    if (e.key === '-') { scale = Math.max(MIN, scale - STEP); if (scale <= 1) { zx = 0; zy = 0; } applyZoom(true); }
  });

  window.addEventListener('resize', function() {
    if (lb.classList.contains('open')) snapTo(idx, false);
  });

  window.mrkLightbox = { open: open, close: close };
})();
</script>

{% endunless %}