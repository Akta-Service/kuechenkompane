<script>
document.addEventListener('DOMContentLoaded', function () {
  const wrapper = document.getElementById('countdown-global-{{ section.id }}');
  if (!wrapper) return;

  const el = wrapper.querySelector('.timer_clock');
  if (!el) return;

  const settings = {
    enabled: {{ section.settings.start_countdown | json }},
    notStartedText: {{ section.settings.not_started_text | json }},
    hours: Number({{ section.settings.set_hour | json }}),
    restart: {{ section.settings.restart_on | json }},
    startDatetime: {{ section.settings.start_datetime | json }}
  };

  if (!settings.enabled) {
    el.textContent = settings.notStartedText;
    return;
  }

  /* ===============================
     TIME CONSTANTS (GERMANY – CET)
  =============================== */

  const HOUR = 60 * 60 * 1000;
  const DURATION = settings.hours * HOUR;

  // Germany CET (no DST handling — stable)
  const UTC_OFFSET = 1 * HOUR;

  function parseGermanDate(str) {
    // "YYYY-MM-DD HH:MM"
    const [date, time] = str.split(' ');
    const [y, m, d] = date.split('-').map(Number);
    const [h, min] = time.split(':').map(Number);
    return Date.UTC(y, m - 1, d, h, min, 0) + UTC_OFFSET;
  }

  const START_TIME = parseGermanDate(settings.startDatetime);

  function getGermanNow() {
    return Date.now() + UTC_OFFSET;
  }

  function update() {
    const now = getGermanNow();

    // Not started yet
    if (now < START_TIME) {
      el.textContent = settings.notStartedText;
      return;
    }

    let diff;

    if (settings.restart) {
      const elapsed = now - START_TIME;
      const remainder = elapsed % DURATION;
      diff = DURATION - remainder;
    } else {
      diff = START_TIME + DURATION - now;
      if (diff < 0) diff = 0;
    }

    const d = Math.floor(diff / (1000 * 60 * 60 * 24));
    const h = Math.floor((diff / (1000 * 60 * 60)) % 24);
    const m = Math.floor((diff / (1000 * 60)) % 60);
    const s = Math.floor((diff / 1000) % 60);

    el.textContent =
      `${String(d).padStart(2, '0')}:` +
      `${String(h).padStart(2, '0')}:` +
      `${String(m).padStart(2, '0')}:` +
      `${String(s).padStart(2, '0')}`;
  }

  update();
  setInterval(update, 1000);
});
</script>
