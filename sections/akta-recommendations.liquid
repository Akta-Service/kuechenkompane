{%- liquid
assign product_id = product.id
assign animation_effect = settings.animations
assign animated = false
if animation_effect != 'none'
assign animated = true
if section.settings.animations != 'inherit'
assign animation_effect = section.settings.animations
endif
endif

assign remove_params = section.settings.remove_params

assign container = section.settings.container
if container == 'w-full'
assign container = 'container-full'
endif

assign classes = 'm-section m:block m-product-recommendations m-gradient m-color-' | append: section.settings.color_scheme
if section.settings.custom_class != blank
assign classes = classes | append: ' ' | append: section.settings.custom_class
endif
-%}{%- style -%}#m-section--{{section.id}}{--column-gap:{{section.settings.column_gap}}px;--column-gap-mobile:16px;--row-gap:{{section.settings.column_gap | plus:10}}px;--row-gap-mobile:30px;--items:{{section.settings.columns}};--section-padding-top:{{section.settings.padding_top}}px;--section-padding-bottom:{{section.settings.padding_bottom}}px;}#m-section--{{section.id}} .apex-grid-layout{display:grid;grid-template-columns:repeat({{section.settings.columns}},1fr);gap:var(--column-gap);}@media (max-width:1024px){#m-section--{{section.id}} .apex-grid-layout{grid-template-columns:repeat({{section.settings.columns | minus:1}},1fr);}}@media (max-width:768px){#m-section--{{section.id}} .apex-grid-layout{display:none!important;}#m-section--{{section.id}} .apex-splide-layout{display:block!important;}#m-section--{{section.id}} .splide{visibility:visible!important;opacity:1!important;}#m-section--{{section.id}} .splide__list{visibility:visible!important;}#m-section--{{section.id}} .splide__slide{visibility:visible!important;}}@media (min-width:769px){#m-section--{{section.id}} .apex-splide-layout{display:none!important;}}#m-section--{{section.id}} .splide__arrow{background:#fff;border:1px solid #e0e0e0;width:36px;height:36px;border-radius:50%;opacity:1;}#m-section--{{section.id}} .splide__arrow svg{fill:#000;width:14px;height:14px;}#m-section--{{section.id}} .splide__arrow:hover{background:#f5f5f5;}{%- endstyle -%}<section id="m-section--{{ section.id }}" class="{{ classes }} apex-recom">{{- 'section-' | append: section.id | append: '.css' | asset_url | stylesheet_tag -}}{%- assign recommendations_url = routes.product_recommendations_url| append: '?section_id='| append: section.id| append: '&product_id='| append: product_id| append: '&limit='| append: section.settings.limit-%}<div class="apex-recommendations-wrapper" data-url="{{ recommendations_url }}" data-loaded="false"><div class="{{ container }} m-section-my m-section-py"><div class="m-section__header m:text-{{ section.settings.text_align | default: 'left' }}"><h2 class="m-section__heading {{ section.settings.heading_size }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">{{ section.settings.heading | default: 'You Might Also Like' }}</h2></div><div class="apex-grid-layout">{% for block in section.blocks %}{% assign product = block.settings.product %}<div class="m:column">{% liquid
case settings.pcard_layout
when '1'
render 'product-card-1', product: product, index: forloop.index, animated: animated, animation_effect: animation_effect, remove_params: remove_params
when '2'
render 'product-card-2', product: product, index: forloop.index, animated: animated, animation_effect: animation_effect, remove_params: remove_params
when '3'
render 'product-card-3', product: product, index: forloop.index, animated: animated, animation_effect: animation_effect, remove_params: remove_params
when '4'
render 'product-card-4', product: product, index: forloop.index, animated: animated, animation_effect: animation_effect, remove_params: remove_params
when '5'
render 'product-card-5', product: product, index: forloop.index, animated: animated, animation_effect: animation_effect, remove_params: remove_params
endcase
%}</div>{% endfor %}</div><div class="apex-splide-layout"><div id="apex-splide--{{ section.id }}" class="splide" aria-label="Product recommendations"><div class="splide__track"><ul class="splide__list">{% for block in section.blocks %}{% assign product = block.settings.product %}<li class="splide__slide">{% liquid
case settings.pcard_layout
when '1'
render 'product-card-1', product: product, index: forloop.index, animated: animated, animation_effect: animation_effect, remove_params: remove_params
when '2'
render 'product-card-2', product: product, index: forloop.index, animated: animated, animation_effect: animation_effect, remove_params: remove_params
when '3'
render 'product-card-3', product: product, index: forloop.index, animated: animated, animation_effect: animation_effect, remove_params: remove_params
when '4'
render 'product-card-4', product: product, index: forloop.index, animated: animated, animation_effect: animation_effect, remove_params: remove_params
when '5'
render 'product-card-5', product: product, index: forloop.index, animated: animated, animation_effect: animation_effect, remove_params: remove_params
endcase
%}</li>{% endfor %}</ul></div></div></div></div></div></section><script>(function() {var SECTION_ID = '{{ section.id }}';var SPLIDE_ID = 'apex-splide--' + SECTION_ID;function mountSplide() {var el = document.getElementById(SPLIDE_ID);if (!el) return;if (el.classList.contains('is-initialized')) return;new Splide('#' + SPLIDE_ID, {type       : 'loop',perPage    : 1,perMove    : 1,gap        : '16px',padding    : { right: '30%' },speed            : 400,easing           : 'cubic-bezier(0.25, 1, 0.5, 1)',waitForTransition: false,updateOnMove     : true,touchAngle       : 30,touchPower       : 600,drag : 'free',snap : true,focus: 'center',flickPower: 400,flickMaxPages: 1,pagination : {{ section.settings.show_pagination | json }},arrows     : {{ section.settings.show_navigation | json }},}).mount();}function init() {if (typeof Splide !== 'undefined') {mountSplide();} else {var tries = 0;var interval = setInterval(function() {tries++;if (typeof Splide !== 'undefined') {clearInterval(interval);mountSplide();}if (tries > 20) clearInterval(interval);}, 200);}}if (document.readyState === 'loading') {document.addEventListener('DOMContentLoaded', init);} else {init();}document.addEventListener('shopify:section:load', function(e) {if (e.target.id === 'm-section--' + SECTION_ID) {setTimeout(init, 300);}});})();</script>
{% schema %}{"name":"Appex recommendations","settings":[{"type":"header","content":"General"},{"type":"select","id":"container","label":"Container type","default":"container","options":[{"value":"container-fluid","label":"Default"},{"value":"w-full","label":"Full width"},{"value":"container","label":"Use container box"}]},{"type":"color_scheme","id":"color_scheme","label":"Color scheme"},{"type":"checkbox","id":"remove_params","label":"Remove URL params","default":false,"info":"Remove param tracking in product URL"},{"type":"header","content":"Header settings"},{"type":"text","id":"heading","label":"Heading","default":"You Might Also Like","placeholder":"Product recommendations"},{"type":"select","id":"heading_size","label":"Heading size","default":"h3","options":[{"value":"h3","label":"Medium"},{"value":"h2","label":"Large"}]},{"type":"select","id":"text_align","label":"Text alignment","default":"left","options":[{"value":"left","label":"Left"},{"value":"center","label":"Center"}]},{"type":"header","content":"Grid settings"},{"type":"range","id":"limit","label":"Products to show","default":8,"min":3,"max":20},{"type":"range","id":"columns","label":"Products per row","default":4,"min":3,"max":8},{"type":"range","id":"column_gap","label":"Column gap","default":30,"min":0,"max":50,"step":2},{"type":"header","content":"Slider settings (Mobile only)"},{"type":"checkbox","id":"show_pagination","label":"Show pagination","default":false},{"type":"checkbox","id":"show_navigation","label":"Show navigation","default":true},{"type":"header","content":"Section Padding"},{"type":"range","id":"padding_top","label":"Padding Top","default":50,"min":0,"max":100,"step":2,"unit":"px"},{"type":"range","id":"padding_bottom","label":"Padding Bottom","default":50,"min":0,"max":100,"step":2,"unit":"px"},{"type":"header","content":"Custom Attributes"},{"type":"text","id":"custom_class","label":"Custom classes"},{"type":"header","content":"Animations"},{"type":"select","id":"animations","label":"Visible in the view animation","default":"inherit","options":[{"value":"inherit","label":"Inherit global setting"},{"value":"fade-in","label":"Fade in"},{"value":"fade-in-up","label":"Fade in up"},{"value":"fade-in-left","label":"Fade in left"},{"value":"fade-in-right","label":"Fade in right"}]}],"blocks":[{"type":"product","name":"Add Product","settings":[{"type":"product","id":"product","label":"Select Product"}]}],"presets":[{"name":"Appex recommendations"}]}{% endschema %}