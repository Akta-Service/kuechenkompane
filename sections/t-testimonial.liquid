
<style>

     .snow-{{ section.id }}.snow-testimonial {
       overflow: hidden;
       padding: 10vw 0 50px;
       {% if section.settings.bg_image != blank %}
         background-image: url({{ section.settings.bg_image | image_url }});
       {% endif %}
       background-size: cover;
       background-repeat: no-repeat;
     }

     .snow-{{ section.id }} .snow-testimonial-container {
       max-width: 1920px;
       margin: 0 auto;
       padding: 0 20px;
     }

     .snow-{{ section.id }} .snow-testimonial-head {
       text-align: center;
       margin-bottom: 60px;
     }

    
     .snow-{{ section.id }} .snow-testimonial-head__counter {
       margin: 0;
       padding: 5px 20px;
       font-family: 'Poppins', sans-serif;
       display: inline-block;
       background-color: {{ section.settings.heading_bg_color }};
       color: #000 !important; 
       font-size: 48px;
       font-weight: 800;
       line-height: 1.2;
     }

     .snow-{{ section.id }} .snow-testimonial-head__title1,
     .snow-{{ section.id }} .snow-testimonial-head__title2 {
       font-family: 'Poppins', sans-serif;
       font-size: 24px;
       font-weight: 700;
       margin-top: 10px;
       color: #1a1a1a;
     }


     .snow-{{ section.id }} .snow-testimonial-card {
       border-radius: 12px;
       text-align: center;
       padding: 30px 14px 20px;
       height: 100%;
       display: flex;
       flex-direction: column;
       align-items: center;
     }

     .snow-{{ section.id }} .splide__slide {
       height: auto;
       display: flex;
       flex-direction: column;
     }

     .snow-{{ section.id }} .snow-testimonial__ratings { font-size: 16px; font-weight: 700; margin-bottom: 10px; }
     .snow-{{ section.id }} .snow-testimonial__title { 
        font-family: 'Poppins', sans-serif;
        margin-bottom: 10px;
        text-align: center;
        font-size: 24px;
        font-weight: 700;
       }

     .snow-{{ section.id }} .snow-testimonial__quote { font-size: 14px; line-height: 1.6; margin-bottom: 10px; }
     .snow-{{ section.id }} .snow-testimonial__author {
       font-family: 'Poppins', sans-serif;
        margin-bottom: 10px;
        text-transform: uppercase;
        text-align: center;
        font-size: 14px;
        font-weight: 500;
        margin-top: auto;
      }

     .snow-{{ section.id }} .snow-testimonial__verified { font-size: 12px; color: #666; }

     .snow-{{ section.id }} .snow-testimonial__images img {
       width: auto;
       height: 220px;
       object-fit: contain;
       border-radius: 5px;
       margin-top: 10px;
     }


     .snow-{{ section.id }} .splide__track { margin: 0 60px; }
     
     .snow-{{ section.id }} .splide__arrow {
       all: unset;
       position: absolute;
       top: 50%;
       transform: translateY(-50%);
       width: 40px;
       height: 40px;
       background-color: {{ section.settings.arrow_bg }};
       border-radius: 50%;
       z-index: 10;
       opacity: 0.8;
       display: flex;
       align-items: center;
       justify-content: center;
       cursor: pointer;
       transition: 0.3s;
     }
     .snow-{{ section.id }} .splide__arrow--prev { left: 10px; }
     .snow-{{ section.id }} .splide__arrow--next { right: 10px; }
     .snow-{{ section.id }} .splide__arrow img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    
     .snow-{{ section.id }} .splide__pagination {
       position: static;
       margin-top: 30px;
       display: flex;
       justify-content: center;
       gap: 12px;
       width: 100%;
     }

     .snow-{{ section.id }} .splide__pagination__page {
       width: 20px !important;
       height: 20px !important;
       background:rgb(0, 0, 0) !important; 
       border: none !important;
       border-radius: 50% !important;
       opacity: 1 !important;
       cursor: pointer;
       transition: 0.3s ease;
       margin: 0 !important;
       padding: 0 !important;
       transform: scale(1) !important;
     }

   
     .snow-{{ section.id }} .splide__pagination__page.is-active {
       background: #007aff !important; 
       transform: scale(1.1) !important;
     }


     @media (max-width: 992px) {
       .snow-{{ section.id }} .snow-testimonial-head__counter { font-size: 36px; }
     }
     @media (max-width: 768px) {
       .snow-{{ section.id }} .splide__track { margin: 0; }
       .snow-{{ section.id }}.snow-testimonial { padding: 40px 0; }
       
     }
</style>

<section class="snow-testimonial snow-{{ section.id }} m-color-{{ section.settings.color_scheme }}">
  <div class="snow-testimonial-container">
    <div class="snow-testimonial-head">
      <h2 class="snow-testimonial-head__counter">{{ section.settings.heading }}</h2>
      <div class="snow-testimonial-head__title1">{{ section.settings.subheading1 }}</div>
      <div class="snow-testimonial-head__title2">{{ section.settings.subheading2 }}</div>
    </div>

    <div class="snow-testimonial-slider-wrapper" style="position: relative;">
      <div id="splide-snow-{{ section.id }}" class="splide">
        <div class="splide__track">
          <ul class="splide__list">
            {% for block in section.blocks %}
              <li class="splide__slide m-color-{{ section.settings.color_scheme_card }}" {{ block.shopify_attributes }}>
                <div class="snow-testimonial-card">
                  <div class="snow-testimonial__ratings">
                    {% if block.settings.star != blank %}
                      <div class="star" style="margin-bottom: 5px;">
                        <img src="{{ block.settings.star | img_url: 'master' }}" alt="Star" width="100">
                      </div>
                    {% endif %}
                    <span> {{ block.settings.rating }}</span>
                  </div>
                  <h4 class="snow-testimonial__title">{{ block.settings.title }}</h4>
                  <div class="snow-testimonial__quote">"{{ block.settings.quote }}"</div>
                  <div class="snow-testimonial__author">{{ block.settings.author }}</div>
                  <div class="snow-testimonial__verified">{{ block.settings.verified }}</div>
                  {% if block.settings.image != blank %}
                    <div class="snow-testimonial__images">
                      <img src="{{ block.settings.image | img_url: 'master' }}" alt="testimonial image" loading="lazy">
                    </div>
                  {% endif %}
                </div>
              </li>
            {% endfor %}
          </ul>
        </div>

        {% if section.settings.enable_navigation == 'true' %}
          <div class="splide__arrows">
            <button class="splide__arrow splide__arrow--prev" type="button">
              {% if section.settings.left_arrow != blank %}
                <img src="{{ section.settings.left_arrow | img_url: 'master' }}" alt="Prev">
              {% endif %}
            </button>
            <button class="splide__arrow splide__arrow--next" type="button">
              {% if section.settings.right_arrow != blank %}
                <img src="{{ section.settings.right_arrow | img_url: 'master' }}" alt="Next">
              {% endif %}
            </button>
          </div>
        {% endif %}

        {% if section.settings.enable_pagination == 'true' %}
          <div class="splide__pagination"></div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  function initSplide() {
    var el = document.querySelector('#splide-snow-{{ section.id }}');
    if (!el || el.classList.contains('is-initialized')) return;

    new Splide(el, {
      type             : 'loop',
      perPage          : 4,
      perMove          : 1,
      drag             : 'free',
      snap             : true,
      speed            : 600,
      gap              : '15px',
      easing           : 'cubic-bezier(0.25, 1, 0.5, 1)',
      autoplay         : true,
      interval         : 5000,
      waitForTransition: false,
      updateOnMove     : true,
      touchAngle       : 30,
      touchPower       : 600,
      pagination       : {{ section.settings.enable_pagination }},
      arrows           : {{ section.settings.enable_navigation }},
      breakpoints: {
        1200: {
          perPage: 3,
        },
        992: {
          perPage: 2,
        },
        768: {
          perPage      : 2,
          flickPower   : 400,
          flickMaxPages: 1,
        },
        576: {
          perPage      : 1,
          flickPower   : 400,
          flickMaxPages: 1,
        }
      }
    }).mount();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSplide);
  } else {
    initSplide();
  }

  document.addEventListener('shopify:section:load', function(e) {
    if (e.target.querySelector('#splide-snow-{{ section.id }}')) {
      setTimeout(initSplide, 300);
    }
  });
})();
</script>

{% schema %}
{
  "name": "Snow Testimonial Slider",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme" },
    { "type": "color_scheme", "id": "color_scheme_card", "label": "card Color scheme" },
    { "type": "text", "id": "heading", "label": "Main Heading", "default": "35,000+ Reviews" },
    { "type": "color", "id": "heading_bg_color", "label": "Heading Highlight Color", "default": "#074a97" },
    { "type": "text", "id": "subheading1", "label": "Subheading 1", "default": "Guaranteed Results" },
    { "type": "text", "id": "subheading2", "label": "Subheading 2", "default": "Millions of Happy Customers" },
    { "type": "image_picker", "id": "left_arrow", "label": "Left Arrow" },
    { "type": "image_picker", "id": "right_arrow", "label": "Right Arrow" },
    {
      "type": "select",
      "id": "enable_pagination",
      "label": "Enable Pagination",
      "default": "true",
      "options": [
        { "label": "Enable", "value": "true" },
        { "label": "Disable", "value": "false" }
      ]
    },
    {
      "type": "select",
      "id": "enable_navigation",
      "label": "Enable Navigation",
      "default": "true",
      "options": [
        { "label": "Enable", "value": "true" },
        { "label": "Disable", "value": "false" }
      ]
    },
    { "type": "color", "id": "arrow_bg", "label": "Arrow Bg Color", "default": "#074a97" },
    { "type": "image_picker", "id": "bg_image", "label": "Background Image" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "text", "id": "rating", "label": "Rating", "default": "5" },
        { "type": "image_picker", "id": "star", "label": "Ratings Star" },
        { "type": "text", "id": "title", "label": "Title", "default": "Worth every penny!" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Beautiful product!" },
        { "type": "text", "id": "author", "label": "Author Name", "default": "CATHALINA A." },
        { "type": "text", "id": "verified", "label": "Verified Text", "default": "Verified Purchase" },
        { "type": "image_picker", "id": "image", "label": "Testimonial Image" }
      ]
    }
  ],
  "presets": [{ "name": "Snow Testimonial Slider" }]
}
{% endschema %}



