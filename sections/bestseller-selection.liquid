<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  a {
    text-decoration: none;
  }

  .best-seller-area {
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  .best-seller-area .container {
    max-width: 1412px;
    margin: 0 auto;
    padding: 0 50px;
  }

  @media only screen and (max-width: 768px) {
    .best-seller-area .container {
      padding: 0 16px;
    }
  }

  .best-seller-heading {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }

  .best-seller-title {
    font-size: 24px;
    color: #1e1e1e;
    text-transform: uppercase;
    font-family: 'Pragmatica', sans-serif;
    font-weight: 400;
  }

  .best-sell-link {
    color: #1e1e1e;
    font-size: 14px;
    text-transform: uppercase;
    border-bottom: 1px solid #1e1e1e;
    transition: 0.3s;
  }

  .best-sell-link:hover {
    color: #635247;
  }

  .best-sell-product-item {
    cursor: pointer;
    width: 100%;
  }

  .best-sell-product-list {
    display: flex;
  }

  .product-img {
    position: relative;
    margin-bottom: 15px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease-in-out;
  }

  .product-img .hover-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
  }

  .product-img:hover .hover-img {
    opacity: 1;
  }

  .product-img:hover .default-img {
    opacity: 0;
  }

  .product-badge {
    position: absolute;
    bottom: 20px;
    left: 20px;
    background: #fff;
    padding: 2px 5px;
    border-radius: 4px;
  }

  .product-badge > span {
    font-size: 14px;
    color: #1e1e1e;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
  }

  .product-info {
    margin-bottom: 18px;
    min-height: 50px;
  }

  .product-info .product-title {
    color: #1e1e1e;
    text-transform: uppercase;
    font-weight: 400;
    font-size: 14px;
    line-height: 1;
    margin-bottom: 8px;
  }

  .product-info .regular-price {
    font-size: 14px;
    color: #1e1e1e;
  }

  .product-purchase-btn a {
    color: #fff;
    background: #1e1e1e;
    text-transform: uppercase;
    font-size: 14px;
    width: 100%;
    display: inline-block;
    padding: 14px 0;
    border-radius: 5px;
    text-align: center;
    transition: 0.3s;
  }

  .product-purchase-btn a:hover {
    background: #635247;
  }

  /* Splide arrows */
  .best-seller-area .splide__arrow {
    background: #fff;
    width: 35px;
    height: 35px;
    border-radius: 100%;
    opacity: 1;
    border: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .best-seller-area .splide__arrow:hover {
    background: #f5f5f5;
  }

  .best-seller-area .splide__arrow svg {
    fill: #1e1e1e;
    width: 10px;
    height: 10px;
  }

  .best-seller-area .splide__arrow--prev svg {
    transform: rotate(180deg);
  }

  .best-sell-product {
    overflow: visible;
  }

  @media (max-width: 767px) {
    .best-seller-area {
      margin-top: {{ section.settings.margin_top_mobile }}px;
      margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
    }
    .best-sell-product {
      overflow: hidden;
    }
  }

  /* ✅ FOUC fix — init হওয়ার আগে সঠিক layout */
  .best-sell-product:not(.is-initialized) .splide__list {
    display: flex;
    overflow: hidden;
    flex-wrap: nowrap;
  }

  .best-sell-product:not(.is-initialized) .splide__slide {
    flex: 0 0 calc(100% / 1.3);
    min-width: 0;
  }

  @media (min-width: 768px) {
    .best-sell-product:not(.is-initialized) .splide__slide {
      flex: 0 0 calc(100% / 3);
    }
  }

  @media (min-width: 992px) {
    .best-sell-product:not(.is-initialized) .splide__slide {
      flex: 0 0 calc(100% / 4);
    }
  }

  @media (min-width: 1281px) {
    .best-sell-product:not(.is-initialized) .splide__slide {
      flex: 0 0 calc(100% / 6);
    }
  }
</style>

<div class="best-seller-area">
  <div class="container">
    <div class="best-seller-heading">
      <h3 class="best-seller-title">{{ section.settings.sec_title }}</h3>
      <a href="{{ section.settings.all_btn_link }}" class="best-sell-link">{{ section.settings.all_btn }}</a>
    </div>

    <div class="best-sell-product splide best-seller-item">
      <div class="splide__track">
        <ul class="best-sell-product-list splide__list">
          {% if section.settings.collection != blank %}
            {% for product in section.settings.collection.products limit: section.settings.product_limit %}
              <li class="best-sell-product-item splide__slide">
                <div class="product-img">
                  <img
                    class="default-img"
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    srcset="
                      {{ product.featured_image | image_url: width: 200 }} 200w,
                      {{ product.featured_image | image_url: width: 300 }} 300w,
                      {{ product.featured_image | image_url: width: 400 }} 400w
                    "
                    sizes="(max-width: 576px) 70vw, (max-width: 991px) 33vw, 16vw"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                    loading="lazy"
                    alt="{{ product.featured_image.alt | escape | default: product.title }}"
                  >
                  {% if product.images[1] != blank %}
                    <img
                      class="hover-img"
                      src="{{ product.images[1] | image_url: width: 400 }}"
                      srcset="
                        {{ product.images[1] | image_url: width: 200 }} 200w,
                        {{ product.images[1] | image_url: width: 300 }} 300w,
                        {{ product.images[1] | image_url: width: 400 }} 400w
                      "
                      sizes="(max-width: 576px) 70vw, (max-width: 991px) 33vw, 16vw"
                      width="{{ product.images[1].width }}"
                      height="{{ product.images[1].height }}"
                      loading="lazy"
                      alt="{{ product.images[1].alt | escape | default: product.title }}"
                    >
                  {% endif %}
                  <div class="product-badge">
                    <span>
                      <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="16" height="16">
                        <path d="M0 0 C5.28 0 10.56 0 16 0 C16 5.28 16 10.56 16 16 C10.72 16 5.44 16 0 16 C0 10.72 0 5.44 0 0 Z " fill="#FDFBFB" transform="translate(0,0)"></path>
                        <path d="M0 0 C0 2.64 0 5.28 0 8 C-5.28 8 -10.56 8 -16 8 C-16 6.02 -16 4.04 -16 2 C-13.52093719 1.66587842 -11.04175822 1.33266565 -8.5625 1 C-7.85544922 0.90460937 -7.14839844 0.80921875 -6.41992188 0.7109375 C-1.11328125 0 -1.11328125 0 0 0 Z " fill="#FDFBFB" transform="translate(16,8)"></path>
                        <path d="M0 0 C4.62 0 9.24 0 14 0 C14 0.66 14 1.32 14 2 C9.38 2.33 4.76 2.66 0 3 C0 2.01 0 1.02 0 0 Z " fill="#CF867C" transform="translate(1,7)"></path>
                      </svg>
                      {{ product.variants.size }}
                      {{ section.settings.variant_text_1 }}
                    </span>
                  </div>
                </div>
                <div class="product-info">
                  <h3 class="product-title">{{ product.title }}</h3>
                  <span class="regular-price">{{ product.price | money }}</span>
                </div>
                <div class="product-purchase-btn">
                  <a href="{{ product.url }}">{{ section.settings.button_Text }}</a>
                </div>
              </li>
            {% endfor %}
          {% endif %}
        </ul>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var el = document.querySelector('.best-seller-item');
  if (!el || !window.Splide) return;

  function initSlider() {
    var w = window.innerWidth;

    if (w <= 767) {
      new Splide(el, {
        type       : 'loop',
        perPage    : 1,
        gap        : 12,
        arrows     : false,
        pagination : false,
        drag       : 'free',
        flickPower : 300,
        padding    : { right: '30%' },
      }).mount();
    } else if (w <= 991) {
      new Splide(el, {
        perPage    : 3,
        gap        : 10,
        arrows     : true,
        pagination : false,
        drag       : true,
      }).mount();
    } else if (w <= 1280) {
      new Splide(el, {
        perPage    : 4,
        gap        : 10,
        arrows     : true,
        pagination : false,
        drag       : true,
      }).mount();
    } else {
      new Splide(el, {
        perPage    : 6,
        gap        : 10,
        arrows     : true,
        pagination : false,
        drag       : true,
      }).mount();
    }
  }

  if (document.readyState === 'complete') {
    initSlider();
  } else {
    window.addEventListener('load', initSlider);
  }
});
</script>

{% schema %}
{
  "name": "Bestseller Selection",
  "settings": [
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin Top",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Margin Top (Mobile)",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margin Bottom (Mobile)",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "text",
      "id": "sec_title",
      "label": "Section Title",
      "default": "Best Sellers"
    },
    {
      "type": "url",
      "id": "all_btn_link",
      "label": "All Products Button Link"
    },
    {
      "type": "text",
      "id": "all_btn",
      "label": "All Products Button Text",
      "default": "View All"
    },
    {
      "type": "header",
      "content": "Select Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "number",
      "id": "product_limit",
      "label": "Number of Products",
      "default": 10
    },
    {
      "type": "text",
      "id": "variant_text_1",
      "label": "Variant Text",
      "default": "shades"
    },
    {
      "type": "text",
      "id": "button_Text",
      "label": "Button Text",
      "default": "add to bag"
    }
  ],
  "presets": [{ "name": "Bestseller Selection" }]
}
{% endschema %}