
<style>.black-friday-collection--{{section.id}}{background:{{section.settings.bg_color}};padding:{{section.settings.section_padding_top}}px 0 {{section.settings.section_padding_bottom}}px;margin:0 0 {{section.settings.section_margin_bottom}}px;overflow:hidden;}.black-friday-collection--{{section.id}} .black-friday-collection__header{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:{{section.settings.header_margin_bottom}}px;}.black-friday-collection--{{section.id}} .black-friday-collection__title{font-size:{{section.settings.title_font_size}}px;font-weight:600;color:{{section.settings.title_color}};}.black-friday-collection--{{section.id}} .black-friday-collection__cta{display:flex;align-items:center;gap:12px;}.black-friday-collection--{{section.id}} .black-friday-collection__cta a{background:{{section.settings.btn_bg_color}};color:{{section.settings.btn_text_color}};padding:{{section.settings.btn_padding_v}}px {{section.settings.btn_padding_h}}px;text-decoration:none;font-weight:600;font-size:{{section.settings.btn_font_size}}px;border-radius:{{section.settings.btn_border_radius}}px;}.black-friday-collection--{{section.id}} .black-friday-collection-card{background:{{section.settings.card_bg_color}};box-sizing:border-box;text-align:center;position:relative;padding:10px 0 26px;transition:transform .15s ease;height:100%;border-radius:{{section.settings.card_border_radius}}px;}.black-friday-collection--{{section.id}} .black-friday-collection-card__media{width:100%;max-height:200px;height:100%;display:flex;align-items:center;justify-content:center;margin-bottom:12px;background:{{section.settings.card_bg_color}};border-radius:{{section.settings.card_border_radius}}px;overflow:hidden;aspect-ratio:{{section.settings.image_aspect_ratio}};}.black-friday-collection--{{section.id}} .black-friday-collection-card__media img{max-width:100%;max-height:100%;object-fit:{{section.settings.image_fit}};display:block;}.black-friday-collection--{{section.id}} .black-friday-collection-card__badge{position:absolute;right:0;top:0;background:{{section.settings.badge_bg_color}};color:{{section.settings.badge_text_color}};padding:6px 8px;font-weight:600;font-size:12px;border-radius:0 {{section.settings.card_border_radius}}px 0 {{section.settings.card_border_radius}}px;}.black-friday-collection--{{section.id}} .black-friday-collection-card__title{font-weight:500;margin:6px 0 4px;padding:0 20px;color:{{section.settings.card_title_color}};font-size:{{section.settings.card_title_font_size}}px;transition:all .3s ease;}.black-friday-collection--{{section.id}} .black-friday-collection-card:hover .black-friday-collection-card__title{color:{{section.settings.card_title_hover_color}};}.black-friday-collection--{{section.id}} .black-friday-collection-card__price{font-weight:700;margin-top:6px;font-size:15px;color:{{section.settings.card_price_color}};}.black-friday-collection--{{section.id}} .black-friday-collection-card__price .compare{color:{{section.settings.card_compare_color}};text-decoration:line-through;font-weight:500;margin-left:8px;font-size:13px;}.black-friday-collection--{{section.id}} .splide__list{list-style:none;padding:0;margin:0;display:flex;align-items:stretch;}.black-friday-collection--{{section.id}} .splide__track{overflow:hidden!important;}.black-friday-collection--{{section.id}} .splide__slide{display:flex;flex-direction:column;}.black-friday-collection--{{section.id}} .custom-container{overflow:visible!important;}.black-friday-collection--{{section.id}} .splide{overflow:visible!important;position:relative;visibility:visible!important;}.black-friday-collection--{{section.id}} .splide:not(.is-initialized){opacity:0;}.black-friday-collection--{{section.id}} .splide.is-initialized{opacity:1;transition:opacity 0.3s ease;}@media (min-width:768px){.black-friday-collection--{{section.id}} .black-friday-collection-card__media{max-height:280px;}.black-friday-collection--{{section.id}} .splide__track{-webkit-overflow-scrolling:touch;}}@media (max-width:767px){.black-friday-collection--{{section.id}} .black-friday-collection__header{justify-content:center;}.black-friday-collection--{{section.id}} .black-friday-collection__cta{display:none;}.black-friday-collection--{{section.id}} .black-friday-collection-card__title{font-size:{{section.settings.card_title_font_size | minus:2}}px;}}</style>
{%- assign col_setting = section.settings.collection -%}{%- if col_setting != blank -%}{%- for product in col_setting.products limit: 2 -%}{%- if product.featured_image -%}<link rel="preload" as="image" href="{{ product.featured_image | image_url: width: 600 }}" imagesrcset="{{ product.featured_image | image_url: width: 300 }} 300w, {{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w" imagesizes="(max-width: 768px) 100vw, 25vw">{%- endif -%}{%- endfor -%}{%- else -%}{%- for block in section.blocks limit: 2 -%}{%- if block.type == 'product' and block.settings.product != blank -%}{%- assign product = all_products[block.settings.product] -%}{%- if product.featured_image -%}<link rel="preload" as="image" href="{{ product.featured_image | image_url: width: 600 }}" imagesrcset="{{ product.featured_image | image_url: width: 300 }} 300w, {{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w" imagesizes="(max-width: 768px) 100vw, 25vw">{%- endif -%}{%- endif -%}{%- endfor -%}{%- endif -%}<section class="black-friday-collection black-friday-collection--{{ section.id }}" aria-label="{{ section.settings.heading | escape }}"><div class="custom-container"><div class="black-friday-collection__header"><h2 class="black-friday-collection__title">{{ section.settings.heading }}</h2><div class="black-friday-collection__cta">{% if section.settings.badge_text != blank %}<div style="font-weight:700;color:{{ section.settings.badge_bg_color }};font-size:16px">{{ section.settings.badge_text }}</div>{% endif %}{% if section.settings.button_text != blank %}<a href="{{ section.settings.button_link }}" class="black-friday-collection__button">{{ section.settings.button_text }}</a>{% endif %}</div></div><div id="bfc-splide-{{ section.id }}" class="splide"><div class="splide__track"><ul class="splide__list">{%- assign col_setting = section.settings.collection -%}{%- if col_setting != blank -%}{%- for product in col_setting.products limit: section.settings.limit_products -%}<li class="splide__slide">{% render 'black-friday-collection-card',product: product,sale_tag_text: section.settings.sale_tag_text,show_on_sale: section.settings.show_on_sale,is_first: forloop.first%}</li>{%- endfor -%}{%- else -%}{%- assign rendered_any = false -%}{%- for block in section.blocks -%}{%- if block.type == 'product' and block.settings.product != blank -%}{%- assign product = all_products[block.settings.product] -%}{%- if product -%}<li class="splide__slide" {{ block.shopify_attributes }}>{% render 'black-friday-collection-card',product: product,sale_tag_text: section.settings.sale_tag_text,show_on_sale: section.settings.show_on_sale,is_first: forloop.first%}</li>{%- assign rendered_any = true -%}{%- endif -%}{%- endif -%}{%- endfor -%}{%- unless rendered_any -%}<li style="padding:18px;color:#777">Add products via blocks or select a collection in the section settings.</li>{%- endunless -%}{%- endif -%}</ul></div></div></div></section><script>(function () {function initSplide() {var el = document.querySelector('#bfc-splide-{{ section.id }}');if (!el || el.classList.contains('is-initialized')) return;new Splide(el, {type             : '{{ section.settings.slider_type }}',perPage          : {{ section.settings.slides_desktop }},perMove          : 1,gap              : '{{ section.settings.slide_gap }}px',speed            : {{ section.settings.slider_speed }},arrows           : {{ section.settings.show_arrows }},pagination       : {{ section.settings.show_pagination }},autoplay         : {{ section.settings.autoplay }},interval         : {{ section.settings.autoplay_speed }},waitForTransition: false,updateOnMove     : true,touchAngle       : 30,touchPower       : 600,breakpoints: {1299: {perPage: {{ section.settings.slides_desktop | minus: 1 }},},1023: {perPage: {{ section.settings.slides_tablet }},},767: {perPage      : 1,padding      : { right: '{{ section.settings.peek_mobile }}%' },gap          : '10px',drag         : 'free',snap         : true,flickPower   : 400,flickMaxPages: 1,},499: {perPage      : 1,padding      : { right: '{{ section.settings.peek_mobile_sm }}%' },gap          : '10px',drag         : 'free',snap         : true,flickPower   : 400,flickMaxPages: 1,}}}).mount();}if (document.readyState === 'loading') {document.addEventListener('DOMContentLoaded', initSplide);} else {initSplide();}document.addEventListener('shopify:section:load', function(e) {if (e.target.querySelector('#bfc-splide-{{ section.id }}')) {setTimeout(initSplide, 300);}});})();</script>
