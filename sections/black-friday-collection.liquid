":"Slide (with rewind)"},{"value":"loop","label":"Loop (infinite)"}],"default":"slide"},{"type":"range","id":"slider_speed","label":"Transition Speed (ms)","min":200,"max":1200,"step":50,"default":600},{"type":"range","id":"slide_gap","label":"Gap Between Slides (px)","min":4,"max":40,"step":2,"default":12},{"type":"header","content":"─── Slides Per View ───"},{"type":"range","id":"slides_desktop","label":"Desktop (≥1024px)","min":2,"max":6,"step":1,"default":4},{"type":"range","id":"slides_tablet","label":"Tablet (768–1023px)","min":1,"max":4,"step":1,"default":2},{"type":"range","id":"peek_mobile","label":"Peek Mobile ≤767px (%)","min":10,"max":60,"step":5,"default":35},{"type":"range","id":"peek_mobile_sm","label":"Peek Mobile Small ≤499px (%)","min":10,"max":50,"step":5,"default":25},{"type":"header","content":"─── Navigation Controls ───"},{"type":"checkbox","id":"show_arrows","label":"Show Arrow Buttons","default":false},{"type":"checkbox","id":"show_pagination","label":"Show Pagination Dots","default":false},{"type":"checkbox","id":"autoplay","label":"Enable Autoplay","default":false},{"type":"range","id":"autoplay_speed","label":"Autoplay Interval (ms)","min":1500,"max":9000,"step":500,"default":4000}],"blocks":[{"type":"product","name":"Product","settings":[{"type":"product","id":"product","label":"Choose Product"}]}],"presets":[{"name":"Black Friday Collection"}]}{% endschema %}