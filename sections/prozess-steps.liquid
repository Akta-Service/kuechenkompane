<section class="prozess-section" id="prozess-{{ section.id }}">
  {% render 'b2b-reveal' %}

  <div class="prozess-wrapper">
    <div class="prozess-steps">
      {% content_for 'blocks' %}
    </div>
  </div>

  <style>
    .prozess-section {
      background: #eae5da;
      padding-bottom: clamp(64px,9vw,128px);
    }

    .prozess-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .prozess-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid #e3dccc;
    }

    .prozess-steps > .prozess-step {
      border-right: 1px solid #e3dccc;
    }

    .prozess-steps > .prozess-step:last-of-type {
      border-right: none;
    }

    .prozess-steps > .prozess-step:nth-child(1) { animation-delay: .2s; }
    .prozess-steps > .prozess-step:nth-child(2) { animation-delay: .3s; }
    .prozess-steps > .prozess-step:nth-child(3) { animation-delay: .4s; }
    .prozess-steps > .prozess-step:nth-child(4) { animation-delay: .5s; }
    .prozess-steps > .prozess-step:nth-child(5) { animation-delay: .6s; }
    .prozess-steps > .prozess-step:nth-child(6) { animation-delay: .7s; }

    @media screen and (max-width: 760px) {
      .prozess-steps {
        grid-template-columns: 1fr 1fr;
      }

      .prozess-steps > .prozess-step {
        border-right: none;
      }
      .prozess-steps > .prozess-step:nth-of-type(1),
      .prozess-steps > .prozess-step:nth-of-type(3) {
        border-right: 1px solid #e3dccc;
      }
      {% comment %} .prozess-steps > .prozess-step:nth-of-type(3) ,
      .prozess-steps > .prozess-step:nth-of-type(4) {
        border-top: 1px solid #e3dccc;
      } {% endcomment %}
    }
  </style>
</section>

{% schema %}
{
  "name": "Prozess Steps",
  "blocks": [{ "type": "_prozess-step" }],
  "presets": [
    {
      "name": "Prozess Steps",
      "category": "Content",
      "blocks": [
        {
          "type": "_prozess-step",
          "settings": {
            "step_label": "01 — Anfrage",
            "title": "Sie konfigurieren",
            "description": "Stufe, Art, Branding und Menge übermitteln — oder Ihre eigene Spezifikation."
          }
        },
        {
          "type": "_prozess-step",
          "settings": {
            "step_label": "02 — Muster",
            "title": "Muster & Angebot",
            "description": "Wir fertigen ein Muster mit Ihrem Branding und legen ein verbindliches Angebot vor."
          }
        },
        {
          "type": "_prozess-step",
          "settings": {
            "step_label": "03 — Freigabe",
            "title": "Sie geben frei",
            "description": "Nach Ihrer Freigabe von Muster, Gravur und Verpackung starten wir die Serie."
          }
        },
        {
          "type": "_prozess-step",
          "settings": {
            "step_label": "04 — Serie",
            "title": "Fertigung & Lieferung",
            "description": "Reproduzierbare Serienqualität, termingerecht geliefert — neutral oder gebrandet."
          }
        }
      ]
    }
  ]
}
{% endschema %}
