{% comment %}
  Marquee Announcement Bar Section
  - Scrolling text marquee with blocks
  - Settings: bg color, text color, padding, speed, separator, font size
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    width: 100%;
    position: relative;
  }

  .marquee-{{ section.id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    overflow: hidden;
    width: 100%;
  }

  .marquee-track-{{ section.id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    animation: marquee-scroll-{{ section.id }} {{ section.settings.speed }}s linear infinite;
    {% if section.settings.direction == 'right' %}
      animation-direction: reverse;
    {% endif %}
    will-change: transform;
  }

  .marquee-track-{{ section.id }}:hover {
    {% if section.settings.pause_on_hover %}
      animation-play-state: paused;
    {% endif %}
  }

  .marquee-item-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    letter-spacing: {{ section.settings.letter_spacing }}px;
    text-transform: {{ section.settings.text_transform }};
    padding: 0 {{ section.settings.item_spacing }}px;
    text-decoration: none;
  }

  .marquee-item-{{ section.id }}:hover {
    color: {{ section.settings.text_color }};
    opacity: 0.8;
  }

  .marquee-separator-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    color: {{ section.settings.separator_color }};
    font-size: {{ section.settings.font_size }}px;
    padding: 0 {{ section.settings.separator_spacing }}px;
    user-select: none;
  }

  @keyframes marquee-scroll-{{ section.id }} {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
{%- endstyle -%}

{%- liquid
  assign has_blocks = false
  if section.blocks.size > 0
    assign has_blocks = true
  endif
-%}

{%- if has_blocks -%}
  <div class="marquee-{{ section.id }}" role="marquee" aria-label="Announcements">
    <div class="marquee-track-{{ section.id }}">
      {%- comment %} Render twice for seamless looping {% endcomment -%}
      {%- for _loop in (1..3) -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'announcement' -%}

            {%- assign item_tag = 'span' -%}
            {%- assign item_attrs = '' -%}
            {%- if block.settings.link != blank -%}
              {%- assign item_tag = 'a' -%}
              {%- assign item_attrs = block.settings.link -%}
            {%- endif -%}

            {%- if item_tag == 'a' -%}
              <a
                href="{{ block.settings.link }}"
                class="marquee-item-{{ section.id }}"
                {{ block.shopify_attributes }}
              >
            {%- else -%}
              <span class="marquee-item-{{ section.id }}" {{ block.shopify_attributes }}>
            {%- endif -%}

              {%- if block.settings.icon != blank -%}
                <span style="margin-right:6px; display:inline-flex; align-items:center;">
                  {{ block.settings.icon }}
                </span>
              {%- endif -%}

              {{ block.settings.text }}

            {%- if item_tag == 'a' -%}</a>{%- else -%}</span>{%- endif -%}

            {%- unless forloop.last -%}
              <span class="marquee-separator-{{ section.id }}" aria-hidden="true">
                {{ section.settings.separator }}
              </span>
            {%- endunless -%}

          {%- endif -%}
        {%- endfor -%}

        {%- comment %} Separator between the two copies for seamless loop {% endcomment -%}
        <span class="marquee-separator-{{ section.id }}" aria-hidden="true">
          {{ section.settings.separator }}
        </span>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Marquee Bar",  
  "class": "marquee-announcement-section",
  "settings": [
    {
      "type": "header",
      "content": "====Colors==="
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f9c0c0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "====Spacing===="
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Item spacing",
      "min": 8,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "====Typography===="
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0.5
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text case",
      "options": [
        { "value": "none",       "label": "Default" },
        { "value": "uppercase",  "label": "UPPERCASE" },
        { "value": "lowercase",  "label": "lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "====Separator===="
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator character",
      "default": "+++"
    },
    {
      "type": "range",
      "id": "separator_spacing",
      "label": "Separator spacing",
      "min": 4,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "====Animation===="
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed (faster = lower)",
      "min": 2, 
      "max": 120,
      "step": 2,
      "unit": "s",
      "default": 30
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll direction",
      "options": [
        { "value": "left",  "label": "Left (default)" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on orders over €40"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon / Emoji (optional)",
          "info": "Paste an emoji or SVG icon code, e.g. 🎁",
          
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Gratis Magnesium ab 40€",
            "icon": "🎁"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "Vorkaufsrecht auf Neuprodukte"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "Kostenloser Versand ab 50€"
          }
        }
      ]
    }
  ]
}
{% endschema %}
