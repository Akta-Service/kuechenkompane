          "type": "richtext",
          "id": "text",
          "default": "<p>Jede Klinge entsteht in Handarbeit bei erfahrenen japanischen Schmiedemeistern — Lage für Lage gefaltet, von Hand geschliffen und gehärtet. So entstehen Schärfe, Charakter und ein Damastmuster, das kein Messer dem anderen gleichen lässt.</p>",
          "label": "Description Text"
        }
      ]
    },
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "kanji",
          "label": "Kanji / Icon Character",
          "default": "手",
          "info": "Displayed above the title (e.g. 手, 層, 匠)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title",
          "default": "Handgeschmiedet"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Feature Description",
          "default": "Jede Klinge einzeln von Meisterhand geschmiedet."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "B2b Craftsmanship",
      "blocks": [
        { "type": "kicker" },
        { "type": "heading" },
        { "type": "text" },
        {
          "type": "feature",
          "settings": {
            "kanji": "手",
            "title": "Handgeschmiedet",
            "description": "Jede Klinge einzeln von Meisterhand geschmiedet."
          }
        },
        {
          "type": "feature",
          "settings": {
            "kanji": "層",
            "title": "Gefaltete Lagen",
            "description": "Damast in vielen Lagen gefaltet — für Struktur und Schnitt."
          }
        },
        {
          "type": "feature",
          "settings": {
            "kanji": "匠",
            "title": "Meistertradition",
            "description": "Können, das über Generationen weitergegeben wird."
          }
        }
      ]
    }
  ]
}
{% endschema %}
