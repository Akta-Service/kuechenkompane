<style>
  .kk-benefit-bar {
    background: {{ section.settings.section_bg }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    border-top: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
    border-bottom: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
  }

  .kk-benefit-bar .kk-benefit-container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 15px;
  }

  @media (max-width: 575px){
    {% if section.settings.mobile_layout == 'grid' %}
      .kk-benefit-bar .kk-benefit-container {
        padding: 0;
      }
    {% endif %}
  }

  .kk-benefit-bar .kk-benefit-splide {
    overflow: visible;
  }

  .kk-benefit-bar .kk-benefit-splide .splide__track {
    overflow: hidden;
  }

  .kk-benefit-bar .kk-benefit-grid {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .kk-benefit-bar .kk-benefit-item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.icon_gap }}px;
  }

  .kk-benefit-bar .kk-benefit-icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    flex: 0 0 {{ section.settings.icon_size }}px;
    color: {{ section.settings.icon_color }};
    display: flex;
  }

  .kk-benefit-bar .kk-benefit-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .kk-benefit-bar .kk-benefit-title {
    margin: 0;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size }}px;
    font-weight: 800;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .kk-benefit-bar .kk-benefit-subtitle {
    margin: 3px 0 0;
    color: {{ section.settings.subtitle_color }};
    font-size: {{ section.settings.subtitle_size }}px;
    font-weight: 500;
    line-height: 1.2;
  }

  /* ── Mobile: SLIDER mode ── */
  {% if section.settings.mobile_layout == 'slider' %}
  @media screen and (max-width: 575px) {
    .kk-benefit-bar .kk-benefit-item {
      justify-content: flex-start;
    }

    .kk-benefit-bar .kk-benefit-title {
      font-size: {{ section.settings.mobile_title_size }}px;
    }

    .kk-benefit-bar .kk-benefit-subtitle {
      font-size: {{ section.settings.mobile_subtitle_size }}px;
    }

    .kk-benefit-bar .splide__slide {
      display: flex;
      justify-content: center;
    }

    .kk-benefit-bar .kk-benefit-item {
      justify-content: center;
      text-align: left;
      width: auto;
      margin: 0 auto;
    }
  }
  {% endif %}

  /* ── Mobile: GRID mode ── */
  {% if section.settings.mobile_layout == 'grid' %}
  @media screen and (max-width: 575px) {
    .kk-benefit-bar {
      padding: {{ section.settings.mobile_padding_top }}px 0 {{ section.settings.mobile_padding_bottom }}px;
    }

    /* Splide-er wrapper gulo reset kore debo */
    .kk-benefit-bar .kk-benefit-splide,
    .kk-benefit-bar .kk-benefit-splide .splide__track,
    .kk-benefit-bar .kk-benefit-splide .splide__list {
      overflow: visible !important;
      transform: none !important;
    }

    .kk-benefit-bar .kk-benefit-grid {
      display: grid !important;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border-left: {{ section.settings.mobile_grid_divider_width }}px solid {{ section.settings.mobile_grid_divider_color }};
      border-top: {{ section.settings.mobile_grid_divider_width }}px solid {{ section.settings.mobile_grid_divider_color }};
    }

    .kk-benefit-bar .kk-benefit-item {
      justify-content: flex-start;
      width: 100% !important;
      padding: {{ section.settings.mobile_grid_item_padding }}px;
      background: {{ section.settings.mobile_grid_item_bg }};
      border-radius: 0;
      box-sizing: border-box;
      border-right: {{ section.settings.mobile_grid_divider_width }}px solid {{ section.settings.mobile_grid_divider_color }};
      border-bottom: {{ section.settings.mobile_grid_divider_width }}px solid {{ section.settings.mobile_grid_divider_color }};
    }

    .kk-benefit-bar .kk-benefit-title {
      font-size: {{ section.settings.mobile_title_size }}px;
    }

    .kk-benefit-bar .kk-benefit-subtitle {
      font-size: {{ section.settings.mobile_subtitle_size }}px;
    }
  }
  {% endif %}

  /* ── Mobile: SLIDER mode padding ── */
  {% if section.settings.mobile_layout == 'slider' %}
  @media screen and (max-width: 575px) {
    .kk-benefit-bar {
      padding: {{ section.settings.mobile_padding_top }}px 0 {{ section.settings.mobile_padding_bottom }}px;
    }
  }
  {% endif %}
</style>

<section class="kk-benefit-bar">
  <div class="kk-benefit-container">
    <div id="kk-benefit-splide-{{ section.id }}" class="splide kk-benefit-splide">
      <div class="splide__track">
        <ul class="kk-benefit-grid splide__list">
          {%- for block in section.blocks -%}
            <li class="kk-benefit-item splide__slide" {{ block.shopify_attributes }}>
              {%- if block.settings.icon_svg != blank -%}
                <div class="kk-benefit-icon">{{ block.settings.icon_svg }}</div>
              {%- endif -%}
              <div class="kk-benefit-content">
                {%- if block.settings.title != blank -%}
                  <h3 class="kk-benefit-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.subtitle != blank -%}
                  <p class="kk-benefit-subtitle">{{ block.settings.subtitle }}</p>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  var splideInstance;
  var mobileLayout = '{{ section.settings.mobile_layout }}';

  function initSplide() {
    var el = document.querySelector('#kk-benefit-splide-{{ section.id }}');
    if (!el) return;

    if (typeof Splide === 'undefined') {
      setTimeout(initSplide, 100);
      return;
    }

    /* Grid mode-e mobile breakpoint-e Splide disable */
    var mobile575 = mobileLayout === 'grid'
      ? { destroy: true }
      : {
          perPage: 1,
          padding: { right: '30%' },
          gap: '12px',
          drag: 'free',
          snap: true,
          flickPower: 400,
          flickMaxPages: 1
        };

    if (!splideInstance) {
      splideInstance = new Splide(el, {
        type: 'slide',
        perPage: 4,
        perMove: 1,
        gap: '{{ section.settings.item_gap }}px',
        arrows: false,
        pagination: false,
        drag: false,
        waitForTransition: false,
        updateOnMove: true,
        breakpoints: {
          1024: {
            perPage: 3,
            gap: '16px',
            drag: 'free',
            snap: true,
            flickPower: 400,
            flickMaxPages: 1
          },
          575: mobile575
        }
      }).mount();

      el.classList.add('is-initialized');
    } else {
      splideInstance.refresh();
    }
  }

  function refreshSplide() {
    setTimeout(function () {
      initSplide();
      if (splideInstance) splideInstance.refresh();
    }, 200);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', refreshSplide);
  } else {
    refreshSplide();
  }

  window.addEventListener('load', refreshSplide);
  window.addEventListener('resize', refreshSplide);

  document.addEventListener('shopify:section:load', function(e) {
    if (e.target.querySelector('#kk-benefit-splide-{{ section.id }}')) {
      refreshSplide();
    }
  });
})();
</script>

