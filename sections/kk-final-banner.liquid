<style>
  #shopify-section-{{ section.id }} {
    /* Everything inside here is scoped to this section only */

    .final {
      background: #324a34;
      color: #EDEEE8;
      text-align: center;
      padding: 3.2rem 1.1rem;
    }

    .final h2 {
      font-weight: 600;
      font-size: clamp(1.7rem, 4.6vw, 2.3rem);
      margin: 0 auto 0.7rem;
      max-width: 22ch;
      color: #fff;
    }

    .final p {
      color: #C9CDBF;
      font-size: 1rem;
      max-width: 30rem;
      margin: 0 auto 1.5rem;
    }

    .btn {
      font-weight: 700;
      font-size: 1.04rem;
      letter-spacing: .02em;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      justify-content: center;
      min-height: 54px;
      padding: 0.9rem 2.2rem;
      border-radius: 9px;
      text-decoration: none;
      background: #fa8526;
      color: #fff;
      border: 1px solid rgba(156,123,46,.55);
      box-shadow: 0 12px 28px -12px rgba(156,123,46,.65), inset 0 1px 0 rgba(255,255,255,.45);
      transition: transform .12s ease, box-shadow .2s ease, filter .2s ease;
      position: relative;
      overflow: hidden;
      margin:0;
    }

    .btn:hover {
      transform: translateY(-2px);
      filter: brightness(1.04);
    }

    .btn--shine::after {
      content: "";
      position: absolute;
      top: 0;
      left: -60%;
      width: 36%;
      height: 100%;
      background: linear-gradient(120deg, transparent, rgba(255,255,255,.42), transparent);
      transform: skewX(-20deg);
      animation: shine 3.6s infinite;
    }



    .reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity .6s ease, transform .6s ease;
    }

    .reveal.in {
      opacity: 1;
      transform: none;
    }

    .button-group {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      margin-top: 1.5rem;
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; transition: none }
      .btn--shine::after { display: none }
    }
    @media (max-width: 640px) {
        .btn {
            width: 100%;
        }
    }
  }

  @keyframes shine {
      0% { left: -60% }
      55% { left: 135% }
      100% { left: 135% }
  }
</style>

<section class="final">
  <div class="reveal {% if section.index == 1 %}in{% endif %}">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'heading' %}
          <h2 {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>

        {% when 'paragraph' %}
          <p {{ block.shopify_attributes }}>{{ block.settings.text }}</p>

        {% when 'button' %}
          {% if forloop.first %}
            <div class="button-group">
          {% endif %}
          {% if block.settings.button_text != blank %}
            <a class="btn btn--shine" href="{{ block.settings.button_link }}" {{ block.shopify_attributes }}>
              {{ block.settings.button_text }}
              <span aria-hidden="true">→</span>
            </a>
          {% endif %}
          {% if forloop.last %}
            </div>
          {% endif %}
      {% endcase %}
    {% endfor %}
  </div>
</section>

<script>
  (function () {
    if (window.revealObserverInitialized) return;
    window.revealObserverInitialized = true;

    function initReveal() {
      const revealElements = document.querySelectorAll('.reveal:not(.in)');
      if (!revealElements.length) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2 }
      );

      revealElements.forEach((el) => observer.observe(el));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initReveal);
    } else {
      initReveal();
    }
    document.addEventListener('shopify:section:load', initReveal);
  })();
</script>

{% schema %}
{
  "name": "Final Banner",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading",
          "default": "Der Umzug ist fast abgeschlossen."
        }
      ]
    },
    {
      "type": "paragraph",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Sobald die letzten Bestände geräumt sind, enden die Aktionspreise endgültig."
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Zu den Angeboten"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Final Banner",
      "blocks": [{ "type": "heading" }, { "type": "paragraph" }, { "type": "button" }]
    }
  ]
}
{% endschema %}
