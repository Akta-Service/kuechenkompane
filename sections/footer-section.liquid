<style>
  :root {
    --beige: #fbf6f4;
    --dark-green: #22432A;
    --heading-green: #36503f;
    --muted: #585a5880;
    --accent: #f56709;
    --bottom-dark: #173a2b;
  }

  /* Layout */
  #footer-fixed-{{ section.id }} {
    background: #eeeff8;
    color: var(--dark-green);
    border-top: 2px solid #e4e5df;
  }
  #footer-fixed-{{ section.id }} .footer-container {
    max-width: 1560px;
    margin-right: auto;
    margin-left: auto;
    padding-right: 60px;
    padding-left: 60px;
  }
  #footer-fixed-{{ section.id }} .footer-top.m-footer--block {
    display: grid;
    grid-template-columns: 1fr 3fr;
    gap: 30px;
    align-items: start;
    padding: 80px 0 60px;
  }

  /* Brand column */
  #footer-fixed-{{ section.id }} .brand-column {
    max-width: 260px;
  }
  .footer-circle {
    margin-bottom: 50px;
  }
  #footer-fixed-{{ section.id }} .footer-circle svg {
    width: 24px;
    height: 24px;
  }
  #footer-fixed-{{ section.id }} .footer-logo {
    width: 140px;
    height: auto;
    display: block;
    margin-bottom: 12px;
  }
  #footer-fixed-{{ section.id }} .footer-text-logo {
    font-size: 38px;
    color: var(--heading-green);
    letter-spacing: -0.5px;
    margin-bottom: 8px;
  }
  #footer-fixed-{{ section.id }} .footer-tagline {
    color: #c3c3c3;
    font-size: 14px;
    margin-bottom: 24px;
    max-width: 130px;
    width: 100%;
    letter-spacing: normal;
    line-height: 18px;
  }

  /* Social */
  #footer-fixed-{{ section.id }} .social-row {
    display: flex;
    gap: 14px;
    margin-top: 10px;
  }
  #footer-fixed-{{ section.id }} .social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    text-decoration: none;
    color: var(--accent);
    background: transparent;
    border: none;
  }
  #footer-fixed-{{ section.id }} .social svg {
    display: block;
  }

  /* Columns */
  #footer-fixed-{{ section.id }} .columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 26px;
  }
  #footer-fixed-{{ section.id }} .col-head {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    background: transparent;
    border: none;
    font-weight: 500;
    letter-spacing: normal;
    color: var(--muted);
    font-size: 14px;
  }
  #footer-fixed-{{ section.id }} .newsletter .col-head {
    cursor: normal;
  }
  #footer-fixed-{{ section.id }} .col-head .chev {
    font-size: 14px;
    color: var(--muted);
    transition: transform 0.35s ease;
    display: none;
  }
  #footer-fixed-{{ section.id }} .col-body {
    max-height: none;
    transition: max-height 0.35s ease;
  }
  /* Make only accordion columns clip when collapsed */
  #footer-fixed-{{ section.id }} [data-accordion] .col-body {
    overflow: hidden;
    padding-top: 8px;
  }
  #footer-fixed-{{ section.id }} .col-body ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  #footer-fixed-{{ section.id }} .col-body a {
    color: var(--dark-green);
    text-decoration: none;
    font-size: 16px;
    letter-spacing: normal;
    text-transform: capitalize;
  }

  /* Newsletter */
  #footer-fixed-{{ section.id }} .newsletter .news-sub {
    color: var(--dark-green);
    margin-bottom: 10px;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: normal;
  }
  #footer-fixed-{{ section.id }} .news-row {
    position: relative;
    width: fit-content;
  }
  #footer-fixed-{{ section.id }} input[type="email"] {
    padding: 15px 50px 15px 15px;
    border: 1px solid #22432a33;
    font-size: 16px;
    max-width: 240px;
    width: 100%;
    height: 47px;
    letter-spacing: normal;
    text-align: left;
    background: transparent;
    display: inline-block;
  }
  #footer-fixed-{{ section.id }} .news-btn {
    color: #fff;
    border: none;
    font-weight: 700;
    cursor: pointer;
    position: absolute;
    top: 50%;
    right: 18px;
    transform: translateY(-50%);
    padding: 3px 2px;
    font-size: 16px;
    line-height: 1;
  }
  button.news-btn path {
    fill: #324739;
  }
  #footer-fixed-{{ section.id }} .news-feedback {
    margin-top: 8px;
    font-size: 13px;
    color: var(--dark-green);
  }
  #footer-fixed-{{ section.id }} .col-body a.referral {
    display: inline-block;
    margin-top: 12px;
    padding: 10px 16px;
    border-radius: 24px;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    font-weight: 500;
    text-transform: capitalize;
    line-height: 16px;
    letter-spacing: normal;
    max-width: 200px;
    width: 100%;
  }
  #footer-fixed-{{ section.id }} .refer-text {
    margin-top: 28px;
    margin-bottom: 0px;
    line-height: 1;
    font-size: 14px;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #585a5880;
  }
  /* Trust row */
  #footer-fixed-{{ section.id }} .trust-row {
    padding: 30px 0;
    border-top: 1px solid rgba(0, 0, 0, 0.04);
  }

  #footer-fixed-{{ section.id }} .trust-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  #footer-fixed-{{ section.id }} .trust-text {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--dark-green);
  }
  #footer-fixed-{{ section.id }} span.review-text {
    font-size: 17px;
  }
  span.review-star svg ,
  span.review-logo svg {
    height: 20px;
    width: fit-content;
  }
  #footer-fixed-{{ section.id }} span.review-number {
    font-size: 14px;
    text-decoration: underline;
  }
  #footer-fixed-{{ section.id }} .trust-text:hover span.review-number {
    text-decoration: none;
  }
  #footer-fixed-{{ section.id }} .trust-right {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  #footer-fixed-{{ section.id }} .payment-icon {
    display: inline-flex;
    gap: 2px;
  }
  #footer-fixed-{{ section.id }} .payment-icon img {
    max-width: 300px;
    width: 100%;
  }
  #footer-fixed-{{ section.id }} .payment-icon svg {
    max-height: 25px;
    width: 100%;
    max-width: 50px;
    fill: #324739;
  }
  /* Bottom dark bar */
  #footer-fixed-{{ section.id }} .footer-bottom {
    background: #324a34;
    color: #fff;
  }
  #footer-fixed-{{ section.id }} .bottom-wrap {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: center;
    padding: 26px 0;
    flex-wrap: wrap;
  }
  #footer-fixed-{{ section.id }} .copyright {
    color: rgba(255, 255, 255);
    font-size: 14px;
  }
  #footer-fixed-{{ section.id }} .bottom-links ul {
    list-style: none;
    display: flex;
    gap: 22px;
    margin: 0;
    padding: 0;
  }
  #footer-fixed-{{ section.id }} .bottom-links a {
    color:rgba(255, 255, 255, 0.71);
    text-decoration: none;
    font-weight: 500;
    font-size: 13px;
    text-transform: uppercase;
  }

  /* Responsive */

  @media (max-width: 1100px) {
    #footer-fixed-{{ section.id }} .footer-top.m-footer--block {
      grid-template-columns: 1fr;
    }
    #footer-fixed-{{ section.id }} .columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 1023px) {
    #footer-fixed-{{ section.id }} .footer-top.m-footer--block {
      padding: 40px 0 18px;
    }
    #footer-fixed-{{ section.id }} .columns {
      grid-template-columns: 1fr;
      gap: 0;
    }

    #footer-fixed-{{ section.id }} .brand-column {
      margin: 0 auto;
      text-align: center;
    }

    #footer-fixed-{{ section.id }} .col:first-child {
      border-top: 1px solid #ddd;
    }

    #footer-fixed-{{ section.id }} .col {
      border-bottom: 1px solid #ddd;
    }

    #footer-fixed-{{ section.id }}  .footer-logo {
      margin: 12px auto 0;
    }

    #footer-fixed-{{ section.id }}  .footer-tagline {
      margin: 10px auto 14px;
      max-width: 130px;
    }

    #footer-fixed-{{ section.id }}  .social-row {
      justify-content: center;
    }

    /* Original display rules (kept) */
    #footer-fixed-{{ section.id }} .col-body {
      display: none;
    }
    #footer-fixed-{{ section.id }} .col-head[aria-expanded="true"] + .col-body,
    #footer-fixed-{{ section.id }} .col-head[aria-expanded="true"] ~ .col-body {
      display: block;
    }

    /* Override so everything stays display:block and we only use max-height
       for accordion animation. Newsletter is always open. */
    #footer-fixed-{{ section.id }} [data-accordion] .col-body,
    #footer-fixed-{{ section.id }} .newsletter .col-body {
      display: block;
    }


    #footer-fixed-{{ section.id }} .col-body ul {
      padding-bottom: 14px;
    }

    #footer-fixed-{{ section.id }} .col-head {
      cursor: pointer;
      padding: 15px 0;
    }

    #footer-fixed-{{ section.id }} .col-head .chev {
      display: inline-flex;
    }
    #footer-fixed-{{ section.id }} .col-head[aria-expanded="true"] .chev {
      transform: rotate(180deg);
    }
    #footer-fixed-{{ section.id }} .newsletter {
      margin-top: 10px;
    }
  }
  @media (max-width: 849px) {
    #footer-fixed-{{ section.id }} .footer-top.m-footer--block {
      padding: 40px 0 18px;
    }
    #footer-fixed-{{ section.id }} .trust-wrapper {
      flex-direction: column;
      gap: 30px;
    }
    #footer-fixed-{{ section.id }} .bottom-wrap {
      flex-direction: column;
      justify-content: center;
      gap: 30px;
    }
  }
  @media (max-width: 767px) {
    #footer-fixed-{{ section.id }} .bottom-links ul {
      gap: 16px;
      flex-direction: column;
      align-items: center;
    }
    #footer-fixed-{{ section.id }} .bottom-wrap {
      padding: 56px 0 40px;
    }
      #footer-fixed-{{ section.id }} [data-accordion] .col-body {
    padding-top: 0;
   }
  }
  @media (max-width: 575px) {
    #footer-fixed-{{ section.id }} .review-number ,
    #footer-fixed-{{ section.id }} .review-logo {
      display: none;
    }
    #footer-fixed-{{ section.id }} .copyright {
      text-align: center;
    }
  }

  .visually-hidden {
    position: absolute !important;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<section
  id="footer-fixed-{{ section.id }}"
  class="footer-fixed"
  role="contentinfo"
  aria-label="Site footer"
>
  <div class="custom-container">
    <div class="footer-top m-footer--block">
      <!-- Brand / logo & socials -->
      <div class="brand-column">
        {% if section.settings.logo != blank %}
          <img
            src="{{ section.settings.logo | img_url: '300x' }}"
            alt="{{ section.settings.logo_alt | escape }}"
            class="footer-logo"
          >
        {% else %}
          <div class="footer-text-logo">
            {{ section.settings.text_logo }}
          </div>
        {% endif %}

        {% if section.settings.tagline != blank %}
          <p class="footer-tagline">{{ section.settings.tagline }}</p>
        {% endif %}

        {% if section.settings.show_social %}
          {% render 'social-media-links' %}
        {% endif %}
      </div>

      <!-- Menus + Newsletter -->
      <div class="columns">
        {%- for block in section.blocks -%}
          {%- if block.type == 'menu_column' -%}
            <div class="col" data-accordion {{ block.shopify_attributes }}>
              <button class="col-head" aria-expanded="true">
                <span>{{ block.settings.heading }}</span>
                <span class="chev">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                  >
                    <path d="M2 8H14" stroke="#22432A" stroke-width="1.25"></path>
                    <path d="M8 2V14" stroke="#22432A" stroke-width="1.25"></path>
                  </svg>
                </span>
              </button>

              <nav class="col-body" aria-label="{{ block.settings.heading }}">
                {% assign menu = linklists[block.settings.menu] %}
                {% if menu %}
                  <ul>
                    {% for link in menu.links %}
                      <li>
                        <a href="{{ link.url }}">{{ link.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </nav>
            </div>
          {%- endif -%}
        {%- endfor -%}
        {% if section.settings.showform %}
          <!-- Newsletter column – NEVER accordion (no data-accordion) -->
          <div class="newsletter">
            <button class="col-head">
              <span>{{ section.settings.news_heading }}</span>
            </button>

            <div class="col-body">
              <p class="news-sub">{{ section.settings.news_sub }}</p>

              <form
                id="footer-news-{{ section.id }}"
                class="newsletter-form"
                method="post"
                action="/contact#newsletter"
                accept-charset="UTF-8"
                novalidate
              >
                <input type="hidden" name="form_type" value="customer">
                <input type="hidden" name="utf8" value="✓">
                <label
                  for="footer-email-{{ section.id }}"
                  class="visually-hidden"
                >
                  Email
                </label>
                <div class="news-row">
                  <input
                    id="footer-email-{{ section.id }}"
                    name="contact[email]"
                    type="email"
                    placeholder="{{ section.settings.news_placeholder }}"
                    required
                  >
                  <button type="submit" class="news-btn" aria-label="Subscribe">
                    {{ section.settings.news_button_text }}
                  </button>
                </div>
                <p class="news-feedback" aria-live="polite"></p>
              </form>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
  <!-- Trust / payment row -->
  <div class="trust-row">
    <div class="custom-container">
      <div class="trust-wrapper">
        <div class="trust-left">
          {% if section.settings.trust_text != blank %}
            <a href="{{ section.settings.trust_link }}" class="trust-text">
              <span class="review-text">{{ section.settings.trust_text1 }}</span>
              <span class="review-star">{{ section.settings.trust_star }}</span>
              <span class="review-number">{{ section.settings.trust_text }}</span>
              <span class="review-logo">{{ section.settings.trust_review }}</span>
            </a>
          {% endif %}
        </div>
        <div class="trust-right">
          {% for block in section.blocks %}
            {% if block.type == 'payment_icons' and block.settings.payment_icon != blank %}
              <div
                class="payment-icon"
                {{ block.shopify_attributes }}
              >
                <img src="{{ block.settings.payment_icon | img_url: '480x480' }}" alt="Payment icons">
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="custom-container">
      <div class="bottom-wrap">
        <div class="copyright">
          {{ section.settings.copyright_text }}
        </div>

        {% if section.blocks.size > 0 %}
          <nav class="bottom-links" aria-label="Footer legal">
            <ul>
              {% for block in section.blocks %}
                {% if block.type == 'bottom_link' %}
                  <li {{ block.shopify_attributes }}>
                    {% if block.settings.footer_bottom_url != blank %}
                      <a href="{{ block.settings.footer_bottom_url }}">
                        {{ block.settings.footer_bottom_link }}
                      </a>
                    {% else %}
                      <span>{{ block.settings.footer_bottom_link }}</span>
                    {% endif %}
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </nav>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('footer-fixed-{{ section.id }}');
    if (!root) return;

    var MOBILE_BREAKPOINT = '(max-width: 1023px)';
    var accs = root.querySelectorAll('[data-accordion]');

    function isMobile() {
      return window.matchMedia(MOBILE_BREAKPOINT).matches;
    }

    function closePanel(body, btn, animate) {
      btn.setAttribute('aria-expanded', 'false');

      if (!animate) {
        body.style.maxHeight = '0px';
        return;
      }

      // Start from current height for a smooth collapse
      var startHeight = body.scrollHeight;
      body.style.maxHeight = startHeight + 'px';

      requestAnimationFrame(function () {
        body.style.maxHeight = '0px';
      });
    }

    function openPanel(body, btn, animate) {
      btn.setAttribute('aria-expanded', 'true');
      var targetHeight = body.scrollHeight + 'px';

      if (!animate) {
        body.style.maxHeight = targetHeight;
        return;
      }

      body.style.maxHeight = targetHeight;
    }

    function setAccordionState() {
      var mobile = isMobile();

      accs.forEach(function (wrapper) {
        var btn = wrapper.querySelector('.col-head');
        var body = wrapper.querySelector('.col-body');
        if (!btn || !body) return;

        if (mobile) {
          // On mobile: start all menu columns closed
          body.style.transition = 'max-height 0.3s ease';
          closePanel(body, btn, false);
        } else {
          // On desktop: all open, no height restriction
          btn.setAttribute('aria-expanded', 'true');
          body.style.transition = '';
          body.style.maxHeight = 'none';
        }
      });
    }

    // Click handler – mobile only, with max-height animation
    accs.forEach(function (wrapper) {
      var btn = wrapper.querySelector('.col-head');
      var body = wrapper.querySelector('.col-body');
      if (!btn || !body) return;

      btn.addEventListener('click', function () {
        if (!isMobile()) return;

        var open = btn.getAttribute('aria-expanded') === 'true';
        if (open) {
          closePanel(body, btn, true);
        } else {
          openPanel(body, btn, true);
        }
      });
    });

    // Initial state
    setAccordionState();

    // Recalculate on resize
    var rt;
    window.addEventListener('resize', function () {
      clearTimeout(rt);
      rt = setTimeout(setAccordionState, 150);
    });

    /* Newsletter Ajax */
    var form = root.querySelector('.newsletter-form');
    if (form) {
      var feedback = form.querySelector('.news-feedback');

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (!feedback) return;
        feedback.textContent = '';

        var email = form.querySelector('input[type="email"]');
        if (!email || !email.value) {
          feedback.textContent = 'Please enter a valid email address.';
          return;
        }

        var data = new FormData(form);
        fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'text/html' },
        })
          .then(function (res) {
            if (res.ok) {
              feedback.textContent = "Thanks — you're subscribed!";
              form.reset();
            } else {
              feedback.textContent = 'There was a problem. Please try again.';
            }
          })
          .catch(function () {
            feedback.textContent = 'Network error. Please try again.';
          });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "text", "id": "logo_alt", "label": "Logo alt text", "default": "Site logo" },
    { "type": "textarea", "id": "text_logo", "label": "Text logo (fallback)", "default": "snuggs" },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline / short description",
      "default": "We want to simplify periods, for good."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Icons"
    },

    { "type": "text", "id": "news_heading", "label": "Newsletter heading", "default": "NEWSLETTER" },
    { "type": "textarea", "id": "news_sub", "label": "Newsletter subtext", "default": "Subscribe to our newsletter" },
    { "type": "text", "id": "news_placeholder", "label": "Newsletter placeholder", "default": "Enter email" },
    { "type": "html", "id": "news_button_text", "label": "Subscribe button text", "default": "→" },

    {
      "type": "url",
      "id": "trust_link",
      "label": "Trust / review URL"
    },
    {
      "type": "text",
      "id": "trust_text1",
      "label": "Trust / review text",
      "default": "Excellent"
    },
    {
      "type": "html",
      "id": "trust_star",
      "label": "Trust / review Sart"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust / review text",
      "default": "3,951 reviews on"
    },
    {
      "type": "html",
      "id": "trust_review",
      "label": "Trust / review Logo"
    },

    {
      "type": "textarea",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© 2025 snuggswear s.r.o. All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "showform",
      "label": "show the News Later"
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "PRODUCTS"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "payment_icons",
      "name": "Payment icons",
      "settings": [
        {
          "type": "image_picker",
          "id": "payment_icon",
          "label": "Payment icon"
        }
      ]
    },
    {
      "type": "bottom_link",
      "name": "Bottom link",
      "settings": [
        {
          "type": "text",
          "id": "footer_bottom_link",
          "label": "Link text"
        },
        {
          "type": "url",
          "id": "footer_bottom_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "Footer",
      "category": "Footer"
    }
  ]
}
{% endschema %}
