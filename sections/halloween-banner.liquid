<style>
    /* common css end  */
    .announcement-container {
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 15px;
    }

    .announcement-bar.bar-{{section.id}} {
      padding-top: {{ section.settings.pt}}px;
      padding-bottom: {{ section.settings.pb}}px;
      position: relative;
      {% if section.settings.bg_type == 'image' and section.settings.bg_img != blank %}
        background: url({{ section.settings.bg_img | image_url }});
        background-position: center;
        background-size: cover;
        background-repeat: no-repeat;
      {% elsif section.settings.bg_type == 'color' %}
        background-color: {{ section.settings.bg_color }};
      {% endif %}
    }

    .announcement-bar-content {
      text-align: center;
    }

    .announcement-bar.bar-{{section.id}}  .announcement-bar-content {
      color: #fff;

    }
    .announcement-bar.bar-{{section.id}}  .announcement-bar-content strong{

      letter-spacing: 1.5px;
     }
    .announcement-bar.bar-{{section.id}}  .announcement-bar-content p{
      font-family: 'Encode Sans Condensed' !important;
      letter-spacing: 1.5px;
     }


    .announcement-bar.bar-{{section.id}} .ann_title{
      font-size: {{- section.settings.ann_title_size -}}px;
      letter-spacing: 1.5px;
      background: linear-gradient(90deg, #ebe4c7 -73.4%, #d6b436 100.65%, #1e1e1e 0%);
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-family: 'Montserrat';
      font-weight: 900;

    }
    .announcement-bar-content strong {

      line-height: 1;
    }

    .announcement-bar-content p {
      font-size: {{ section.settings.text_size }}px;
      line-height: 1;
      font-weight:400;

    }
  @media only screen and (max-width: 768px){
      .announcement-bar.bar-{{section.id}}  .announcement-bar-content p {
        font-size: {{ section.settings.text_size_m }}px;
      }
      .announcement-bar.bar-{{section.id}}   .ann_title{
        font-size: {{- section.settings.ann_title_size_m -}}px;
      }
    .announcement-bar.bar-{{section.id}} {
      padding-top: {{ section.settings.pt}}px;
      padding-bottom: {{ section.settings.pb}}px;
       {% if section.settings.bg_type == 'image' and section.settings.bg_img_mobile != blank %}
        background: url({{ section.settings.bg_img_mobile | image_url }});
        background-size: auto !important;
        background-position: center;
      {% elsif section.settings.bg_type == 'color' %}
        background-color: {{ section.settings.bg_color }};
      {% endif %}
    }
  }

  {% if section.settings.sticky_top %}
  .apex-Announcement-sticky-1{
    position: sticky;
    top: 0;
    z-index: 99;
  }
  {% endif %}


   {% if section.settings.button_position == 'right_side' %}
      .announcement-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
      }
    {% endif %}
    .button-wrap.button-bottom {
      text-align: center;
       margin-top: 10px;
    }

  .button-wrap a {
      border: 1px solid #ddd;
      padding: 2px 14px;
      display: inline-block;
      border-radius: 5px;
      font-size: 12px;
      margin-bottom: -1%;
  }

  .announcement-bar-content p a {
      text-decoration: underline;
  }
</style>
{% comment %}
  Determine which announcement block to show:
  - If a block is targeted to the current page/template, use that (high priority)
  - Otherwise, use the default section settings
{% endcomment %}

{% assign current_block = null %}
{% assign show_announcement = false %}

{% for block in section.blocks %}
  {% if block.settings.collection != blank and collection and block.settings.collection.handle == collection.handle %}
    {% assign current_block = block %}
    {% assign show_announcement = true %}
  {% elsif block.settings.product != blank and product and block.settings.product.handle == product.handle %}
    {% assign current_block = block %}
    {% assign show_announcement = true %}
  {% elsif block.settings.page != blank and page and block.settings.page.handle == page.handle %}
    {% assign current_block = block %}
    {% assign show_announcement = true %}
  {% endif %}
{% endfor %}

{% assign hide_announcement = false %}

{% for p in section.settings.target_products %}
  {% if p.handle == product.handle %}
    {% assign hide_announcement = true %}
  {% endif %}
{% endfor %}

{% assign hide_page_header = false %}
{% assign hide_pages = section.settings.hide_header_pages | strip | split: ',' %}
{% for hide_page_handle in hide_pages %}
  {% assign hide_page_handle_trimmed = hide_page_handle | strip %}
  {% if page and page.handle == hide_page_handle_trimmed %}
    {% assign hide_page_header = true %}
  {% endif %}
{% endfor %}

{% unless hide_page_header %}
  {% if hide_announcement == false %}
    <div class="announcement-bar bar-{{ section.id }} m-color-{{ section.settings.color_scheme }}">
      <div class="announcement-container">
        <div class="announcement-bar-content">
          <strong class="ann_title">
            {% if show_announcement %}
              {{ current_block.settings.ann_title }}
            {% else %}
              {{ section.settings.ann_title }}
            {% endif %}
          </strong>

          {% if show_announcement %}
            {{ current_block.settings.text }}
          {% else %}
            {{ section.settings.text }}
          {% endif %}
        </div>

        {% if show_announcement %}
          {% assign btn_show = current_block.settings.show_button %}
          {% assign btn_pos = current_block.settings.button_position %}
          {% assign btn_link = current_block.settings.btn_link %}
          {% assign btn_text = current_block.settings.btn_text %}
        {% else %}
          {% assign btn_show = section.settings.show_button %}
          {% assign btn_pos = section.settings.button_position %}
          {% assign btn_link = section.settings.btn_link %}
          {% assign btn_text = section.settings.btn_text %}
        {% endif %}

        {% if btn_show and btn_pos == 'right_side' %}
          <div class="button-wrap button-right">
            <a href="{{ btn_link }}">{{ btn_text }}</a>
          </div>
        {% endif %}
      </div>

      {% if btn_show and btn_pos == 'bottom' %}
        <div class="button-wrap button-bottom">
          <a href="{{ btn_link }}">{{ btn_text }}</a>
        </div>
      {% endif %}
    </div>
  {% endif %}
{% endunless %}
{% schema %}
{
  "name": "APEX Halloween Ann",
  "class": "apex-Announcement-sticky-1",
  "settings": [
    {
      "type": "product_list",
      "id": "target_products",
      "label": "Hide on these Products"
    },
    {
      "type": "textarea",
      "id": "hide_header_pages",
      "label": "Hide header on pages",
      "info": "Enter page handle"
    },
    {
      "type": "header",
      "content": "==== Background Settings ===="
    },
    {
      "type": "select",
      "id": "bg_type",
      "label": "Background Type",
      "options": [
        { "value": "image", "label": "Background Image" },
        { "value": "color", "label": "Background Color" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Bg Image",
      "visible_if": "{{section.settings.bg_type == 'image'}}"
    },
    {
      "type": "image_picker",
      "id": "bg_img_mobile",
      "label": "Bg Image (Mobile)",
      "visible_if": "{{section.settings.bg_type == 'image'}}"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#324a34",
      "visible_if": "{{section.settings.bg_type == 'color'}}"
    },
    {
      "type": "checkbox",
      "id": "sticky_top",
      "label": "Sticky Announcement",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "range",
      "id": "pt",
      "label": "Padding Top",
      "default": 15,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "pb",
      "label": "Padding Bottom",
      "default": 15,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "ann_title",
      "label": "Title",
      "default": "LEI OF LOVE"
    },
    {
      "type": "range",
      "id": "ann_title_size",
      "label": "Font Size",
      "default": 16,
      "min": 10,
      "max": 40,
      "step": 1
    },
    {
      "type": "range",
      "id": "ann_title_size_m",
      "label": "Font Size (Mobile)",
      "default": 16,
      "min": 10,
      "max": 40,
      "step": 1
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Jetzt für 69 €* shoppen & ein <strong>kostenloses Schmuckstück</strong> auswählen!</p>"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text Font Size",
      "default": 16,
      "min": 10,
      "max": 30,
      "step": 1
    },
    {
      "type": "range",
      "id": "text_size_m",
      "label": "Text Font Size (Mobile)",
      "default": 16,
      "min": 10,
      "max": 30,
      "step": 1
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": true
    },
    {
      "type": "select",
      "id": "button_position",
      "label": "Button position",
      "default": "right_side",
      "options": [
        {
          "value": "right_side",
          "label": "Right side"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ]
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    }
  ],

  "blocks": [
    {
      "type": "page_specific",
      "name": "Template Specific",
      "settings": [
        {
          "type": "header",
          "content": "Target Page/Template"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Target Collection"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Target Product"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Target Page"
        },

        {
          "type": "header",
          "content": "Announcement Content"
        },
        {
          "type": "text",
          "id": "ann_title",
          "label": "Title",
          "default": "Special Collection Offer"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Exclusive deals only for this collection!</p>"
        },

        {
          "type": "header",
          "content": "Button Settings"
        },
        {
          "type": "checkbox",
          "id": "show_button",
          "label": "Show button",
          "default": true
        },
        {
          "type": "select",
          "id": "button_position",
          "label": "Button position",
          "default": "right_side",
          "options": [
            {
              "value": "right_side",
              "label": "Right side"
            },
            {
              "value": "bottom",
              "label": "Bottom"
            }
          ]
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button link"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "APEX Black Friday announcement",
      "settings": {}
    }
  ]
}
{% endschema %}
