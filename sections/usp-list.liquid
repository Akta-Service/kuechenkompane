{{ 'apex-theme.css' | asset_url | stylesheet_tag }}
<style>.usp-list-section{padding:{{ section.settings.verticle_padding }}px {{ section.settings.horizontal_padding }}px}@media screen and (min-width:992px){.usp-list-main{max-width:1440px;width:100%;margin:0 auto;display:flex!important;align-items:stretch;justify-content:space-between}.usp-splide-wrapper{display:none}}@media screen and (max-width:991px){.usp-list-main{display:none!important}.usp-splide-wrapper{display:block}.usp-list-section{padding:40px 0 40px 16px;overflow:hidden}.usp-splide-wrapper .usp-list-item{text-align:center;background:#f8f8f8;padding:20px 15px;border-radius:10px;box-shadow:0 2px 5px rgba(0,0,0,.05);height:auto}.usp-splide .splide__track{overflow:visible!important;touch-action:pan-y}}</style>
<div class="usp-list-section m-color-{{ section.settings.color_scheme }}">
<div class="usp-list-main">{% for block in section.blocks %}<div class="usp-list-item" {{ block.shopify_attributes }}>{% if block.settings.usp_icon != blank %}<img src="{{ block.settings.usp_icon | img_url: '200x' }}" loading="lazy" alt="icon">{% endif %}<h4 style="color:{{ block.settings.title_color }};font-size:{{ block.settings.title_size }}px;">{{ block.settings.usp_title }}</h4><p style="color:{{ block.settings.info_color }};font-size:{{ block.settings.info_size }}px;">{{ block.settings.usp_info }}</p></div>{% if block.settings.divider and forloop.last == false %}<div class="usp-list-border"></div>{% endif %}{% endfor %}</div>
<div class="usp-splide-wrapper"><div class="splide usp-splide" id="usp-splide-{{ section.id }}"><div class="splide__track"><ul class="splide__list">{% for block in section.blocks %}<li class="splide__slide"><div class="usp-list-item">{% if block.settings.usp_icon != blank %}<img src="{{ block.settings.usp_icon | img_url: '200x' }}" loading="lazy" alt="icon">{% endif %}<h4 style="color:{{ block.settings.title_color }};font-size:{{ block.settings.title_size }}px;">{{ block.settings.usp_title }}</h4><p style="color:{{ block.settings.info_color }};font-size:{{ block.settings.info_size }}px;">{{ block.settings.usp_info }}</p></div></li>{% endfor %}</ul></div></div></div>
</div>
<script>(function(){function t(){const t=document.getElementById("usp-splide-{{ section.id }}");t&&window.innerWidth<=991&&!t.classList.contains("is-initialized")&&(new Splide(t,{type:"slide",perPage:1.5,focus:"center",gap:"16px",drag:"free",snap:!0,speed:400,easing:"cubic-bezier(0.25, 1, 0.5, 1)",padding:{right:"20px"},arrows:!1,pagination:!1,waitForTransition:!1,updateOnMove:!0,touchAngle:30,touchPower:600,flickPower:400,flickMaxPages:1}).mount(),t.classList.add("is-initialized"))}"loading"===document.readyState?document.addEventListener("DOMContentLoaded",t):t(),window.addEventListener("resize",function(){window.innerWidth<=991&&t()}),document.addEventListener("shopify:section:load",function(e){e.target.querySelector("#usp-splide-{{ section.id }}")&&setTimeout(t,300)})})();</script>
{% schema %}{"name":"APEX USPs","settings":[{"type":"color_scheme","id":"color_scheme","label":"Color scheme"},{"type":"range","id":"verticle_padding","label":"Vertical Padding","default":50,"min":0,"max":100},{"type":"range","id":"horizontal_padding","label":"Horizontal Padding","default":50,"min":0,"max":100},{"type":"range","id":"verticle_padding_mobile","label":"Vertical Padding (Mobile)","default":30,"min":0,"max":100}],"blocks":[{"type":"item","name":"USP Item","settings":[{"type":"image_picker","id":"usp_icon","label":"USP Icon"},{"type":"text","id":"usp_title","label":"USP Title","default":"Vegan"},{"type":"range","id":"title_size","min":12,"max":40,"label":"Title Font size","default":18},{"type":"textarea","id":"usp_info","label":"USP Info","default":"and without animal testing"},{"type":"range","id":"info_size","min":10,"max":30,"label":"info Font size","default":14},{"type":"checkbox","id":"divider","label":"Show Divider","default":true}]}],"presets":[{"name":"APEX USPs"}]}{% endschema %}