{%- style -%}
  .akta-header {
      display: none;
  }
    #shopify-section-{{ section.id }} {
      --kk-green: #47563E;
      --kk-green-night: #232C1D;
      --kk-paper: {{ section.settings.bg_color | default: '#FCFBF8' }};
      --kk-stone: #6E7266;
      --kk-line: #E7E6DF;
      --kk-wide: 75rem;
    }
    #shopify-section-{{ section.id }} .kk-top{background:var(--kk-green-night);color:#EDEEE8;text-align:center;padding:.6rem 1rem;font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;font-weight:700;position:sticky;top:0;z-index:70;box-shadow:0 6px 18px -10px rgba(0,0,0,.4);}

    #shopify-section-{{ section.id }} .kk-bar{background:var(--kk-paper);border-bottom:1px solid var(--kk-line);}
    #shopify-section-{{ section.id }} .kk-bar *{box-sizing:border-box}
    #shopify-section-{{ section.id }} .bar__in{max-width:var(--kk-wide);margin:0 auto;padding:.75rem 1.1rem;display:flex;align-items:center;justify-content:space-between;gap:1rem}
    #shopify-section-{{ section.id }} .kk-brand{display:flex;align-items:center;gap:.55rem;text-decoration:none}
    #shopify-section-{{ section.id }} .kk-brand__logo{display:block;height:{{ section.settings.logo_height }}px;width:auto}
    #shopify-section-{{ section.id }} .kk-brand__name{font-style:italic;font-weight:600;font-size:1.25rem;color:var(--kk-green);line-height:1}
    #shopify-section-{{ section.id }} .kk-bartrust{font-size:.76rem;font-weight:600;color:var(--kk-stone)}
    #shopify-section-{{ section.id }} .kk-bartrust b{color:var(--kk-green)}
{%- endstyle -%}

<div class="kk-bar">
  <div class="bar__in">
    <a class="kk-brand" href="{{ routes.root_url }}">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: 300
          | image_tag: class: 'kk-brand__logo', widths: '150,300', alt: section.settings.brand_name
        }}
      {%- else -%}
        <svg viewBox="0 0 32 32" aria-hidden="true" width="28" height="28">
          <path d="M10 13c-2.8 0-5-2-5-4.6C5 5.9 7.2 4 10 4c.6 0 1.2.1 1.7.3C12.8 2.9 14.3 2 16 2s3.2.9 4.3 2.3c.5-.2 1.1-.3 1.7-.3 2.8 0 5 1.9 5 4.4 0 2.6-2.2 4.6-5 4.6v9H10v-9z" fill="none" stroke="#47563E" stroke-width="1.8" stroke-linejoin="round"/><path d="M10 25h12M10 28h12" stroke="#47563E" stroke-width="1.8" stroke-linecap="round"/><text x="16" y="14.5" text-anchor="middle" font-family="Georgia,serif" font-style="italic" font-size="9" fill="#47563E">K</text>
        </svg>
      {%- endif -%}
      {%- if section.settings.brand_name != blank -%}
        <span class="kk-brand__name">{{ section.settings.brand_name }}</span>
      {%- endif -%}
    </a>
    {%- if section.settings.trust_text != blank -%}
      <span class="kk-bartrust">{{ section.settings.trust_text }}</span>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "KK Final Header",
  "tag": "section",
  "class": "kk-final-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Wird anstelle des Standard-Icons angezeigt, falls hochgeladen."
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo-Höhe",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Markenname",
      "default": "Küchenkompane"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Vertrauens-Text",
      "default": "★ „Exzellent\" · 3.735 Bewertungen"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrundfarbe",
      "default": "#FCFBF8"
    }
  ],
  "presets": [
    {
      "name": "KK Final Header"
    }
  ]
}
{% endschema %}
