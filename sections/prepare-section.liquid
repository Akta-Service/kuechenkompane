<style>
  .prepare-section {
    background-color: {{ section.settings.bg_color }};
    padding: 48px 0;
  }

  .prepare-container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .prepare-wrapper {
    display: flex;
    gap: 48px;
  }

  .prepare-image img {
    width: 100%;
    border-radius: 20px;
  }

  .prepare-image {
    flex: 1;
    width: 100%;
  }

  .prepare-content {
    flex: 1;
    width: 100%;
  }

  .prepare-subtitle {
    margin: 0;
    padding: 0;
    font-family: 'Sofia Pro', sans-serif;
    display: block;
    color: #fa8526;
    text-transform: uppercase;
    font-weight: 800;
    font-size: 24px;
    line-height: 1.15;
    padding-bottom: 8px;
  }

  .prepare-title {
    margin: 0;
    padding: 0;
    font-family: 'Sofia Pro', sans-serif;
    color: #533a2d;
    font-size: clamp(32px, 3vw, 44px);
    font-weight: 600;
    padding-bottom: 0px;
    margin-bottom: 0px;
    line-height: 1.15;
    padding-bottom: 56px;
  }

  .prepare-step {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .step-number {
    background: #fa8526;
    color: #fff;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
  }

  .prepare-step p {
    margin: 0;
    padding: 0;
    font-family: 'Sofia Pro', sans-serif;
    color: #533a2d;
    font-weight: 700;
    font-size: 18px;
    line-height: 130%;
  }

  .prepare-bottom {
    text-align: center;
    {% comment %} max-width: 400px; {% endcomment %}
    padding-top: 40px;
  }

  .prepare-bottom .ryze-button-wrap {
    margin-left: 0;
  }

  .prepare-top {
    display: none;
  }

  @media (max-width: 991px) {
    .prepare-title {
      padding-bottom: 28px;
    }
    .prepare-bottom {
      padding-top: 30px;
    }
  }
  @media (max-width: 768px) {
    .prepare-wrapper {
      flex-direction: column;
    }

    .prepare-subtitle.desktop {
      display: none;
    }
    .prepare-title.desktop {
      display: none;
    }

    .prepare-top {
      display: block;
    }

    .prepare-title {
      padding-bottom: 0;
    }
    .prepare-subtitle {
      text-align: center;
    }
    .prepare-title {
      text-align: center;
    }
  }

  @media (max-width: 576px) {
    .ryze-button {
      padding: 14px;
      font-size: 16px;
    }
    .prepare-section {
      padding: 30px 0;
    }
    .prepare-subtitle {
      font-size: 16px;
      text-align: center;
    }

    .prepare-title {
      font-size: 24px;
      text-align: center;
    }

    .prepare-wrapper {
      gap: 22px;
    }
    .prepare-bottom {
      padding-top: 20px;
    }
    .prepare-step p {
      font-size: 16px;
    }
  }

  @media (max-width: 400px) {
    .prepare-container {
      padding: 0 14px;
    }

    .prepare-subtitle {
      font-size: 15px;
    }

    .prepare-title {
      font-size: 22px;
    }

    .prepare-section {
      padding: 24px 0;
    }
    .ryze-button {
      font-size: 15px;
      padding: 12px;
    }
  }
</style>

<section class="prepare-section" id="prepare-{{ section.id }}">
  <div class="prepare-container">
    <div class="prepare-wrapper">
      <div class="prepare-top">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'subtitle' %}
              <p class="prepare-subtitle">{{ block.settings.subtitle }}</p>

            {% when 'title' %}
              <h2 class="prepare-title">{{ block.settings.title }}</h2>
          {% endcase %}
        {% endfor %}
      </div>
      {% capture image_option %}
      <div class="prepare-image">
        {% if section.settings.image %}
          <img src="{{ section.settings.image | img_url: 'master' }}" alt="prepare">
        {% else %}
          {{ 'image' | placeholder_svg_tag }}
        {% endif %}
      </div>
      {% endcapture %}

      {{ image_option }}

      <div class="prepare-content">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'subtitle' %}
              <p class="prepare-subtitle desktop">{{ block.settings.subtitle }}</p>

            {% when 'title' %}
              <h2 class="prepare-title desktop">{{ block.settings.title }}</h2>

            {% when 'step' %}
              <div class="prepare-step">
                <span class="step-number">{{ block.settings.number }}</span>
                <p>{{ block.settings.text }}</p>
              </div>

            {% when 'button' %}
              <div class="prepare-bottom">
                {% if block.settings.button_text != blank %}
                  <div class="ryze-button-wrap">
                    <a href="{{ block.settings.button_link }}" class="ryze-button">
                      {{ block.settings.button_text }}
                      {% if block.settings['btn-icon'] != blank %}
                        <img
                          src="{{ block.settings.btn-icon | img_url: 'master' }}"
                          alt="Icon"
                        >
                      {% endif %}
                    </a>
                  </div>
                {% endif %}
                {% if block.settings['guarantee-text'] != blank %}
                  <div class="guarantee-wrap">
                    {% if section.settings.guarantee_icon != blank %}
                      <img class="guarantee_icon" src="{{  section.settings.guarantee_icon | image_url }}" alt="icon">
                    {% else %}
                      <svg
                        stroke="currentColor"
                        fill="currentColor"
                        stroke-width="0"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                        height="1em"
                        width="1em"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.49 4.49 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd"></path>
                      </svg>
                    {% endif %}
                    <span class="guarantee-text">{{ block.settings['guarantee-text'] }}</span>
                  </div>
                {% endif %}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How To Prepare Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    { "type": "header", "content": "Background Color" },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Bg Color",
      "default": "#f5f0e8"
    }
  ],
  "blocks": [
    {
      "type": "subtitle",
      "name": "Subtitle",
      "settings": [
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        }
      ]
    },
    {
      "type": "title",
      "name": "Title",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    },
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step Number"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Step Text"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "TRY RYZE TODAY"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "image_picker",
          "id": "btn-icon",
          "label": "Button Icon"
        },
        {
          "type": "text",
          "id": "guarantee-text",
          "label": "Guarantee Text",
          "default": "30-Day Money Back Guarantee"
        },
        {
          "type": "image_picker",
          "id": "guarantee_icon",
          "label": "Guarantee Text Icon",
          "info": "If blank, the default SVG will be shown."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How To Prepare Section"
    }
  ]
}
{% endschema %}
