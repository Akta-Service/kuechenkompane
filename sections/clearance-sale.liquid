<style>.clearance-sale-section{padding:20px 0}.clearance-sale-container{max-width:1400px;padding:0 20px;margin:auto;display:grid;grid-template-columns:1fr 1fr;gap:40px}.clearance-breadcrubm>*{font-size:16px}.clearance-breadcrubm{margin-bottom:30px}.sale-text{padding-top:40px}.clearance-title{font-size:32px;margin:0 0 12px;font-weight:600}.clearance-description{font-size:16px;margin:0 0 18px;font-weight:400;line-height:1.6}.clearance-info{font-size:16px;font-weight:600}.clearance-features-list li{display:flex;align-items:center;gap:4px}.clearance-features-list li img{width:40px;height:40px}.clearance-features-list{list-style:none;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:30px}.features-list li{margin-bottom:8px;font-size:16px}.sale-image{flex:1;min-width:300px;text-align:center;position:relative}.sale-image img{width:100%;border-radius:6px;display:block}.countdown{transform:translateY(-4px);background:{{ section.settings.timerBg }};color:#fff;padding:10px 20px;border-top:1px solid #fff;font-weight:700;font-size:18px}.countdown small{font-size:12px;font-weight:500}.founder-note-wrapper{max-width:1400px;padding:0 20px;margin:auto;margin-top:30px;text-align:center}.founder-note{text-align:center}.founder-signature{text-align:center;display:flex;justify-content:center;width:200px;margin:auto;height:60px;margin-top:4px}@media (max-width:991px){.clearance-sale-container{grid-template-columns:1fr}.sale-text{padding-top:0}}@media (max-width:575px){.clearance-breadcrubm>*{font-size:14px}.clearance-title{font-size:20px}.clearance-description{font-size:14px}.clearance-sale-container{padding:0 15px}.clearance-info,.clearance-features-list li{font-size:14px}.clearance-features-list li img{width:32px;height:32px}.founder-note{margin-top:20px;font-size:14px}}@media (max-width:374px){.clearance-features-list{grid-template-columns:1fr}}@media (max-width:400px){.countdown{font-size:15px;padding:10px}}@media (max-width:768px){.clearance-features-list{display:none}.clearance-features-list.is-open{display:grid}.feature-toggle-btn{margin-top:4px;background:none;border:none;font-weight:600;cursor:pointer;font-size:14px}.clearance-sale-container{gap:30px}}@media (min-width:750px){.feature-toggle-btn{display:none}}</style>
<div class="clearance-sale-section"><div class="clearance-sale-container"><div class="sale-text"><nav class="clearance-breadcrubm"><a href="{{ routes.root_url }}">{{ section.settings.home_text }}</a><span>/ {{ collection.title }}</span></nav><h2 class="clearance-title">{{ section.settings.headline }}</h2><p class="clearance-description">{{ section.settings.description }}</p><p class="clearance-info">{{ section.settings.info }}</p><div class="clearance-list-wrapper"><ul class="clearance-features-list" id="featureList-{{ section.id }}">{% for block in section.blocks %}<li>{% if block.settings.icon %}<img src="{{ block.settings.icon | image_url }}" alt="icon">{% endif %}{{ block.settings.text }}</li>{% endfor %}</ul>{% if section.blocks.size > 0 %}<button class="feature-toggle-btn" data-target="featureList-{{ section.id }}" data-more="{{ section.settings.show_more_text }}" data-less="{{ section.settings.show_less_text }}">{{ section.settings.show_more_text }}</button>{% endif %}</div></div><div class="sale-image"><img src="{{ section.settings.main_image | img_url: 'master' }}" alt="Sale Image"><div class="countdown"><span>{{ section.settings.timer_text }}</span><span id="countdown-timer"></span><br><small>{{ section.settings.timer_text_info }}</small></div></div></div><div class="founder-note-wrapper"><p class="founder-note">{{ section.settings.founder_note }}</p>{% if section.settings.img_sign != blank %}<div class="founder-signature"><img src="{{ section.settings.img_sign | image_url }}" alt="Founder Signature"></div>{% endif %}</div></div>
{% schema %}{"name":"Clearance Sale Section","settings":[{"type":"text","id":"home_text","label":"Home Text","default":"Home"},{"type":"image_picker","id":"main_image","label":"Main Sale Image"},{"type":"text","id":"headline","label":"Headline","default":"Lagerräumungsverkauf"},{"type":"textarea","id":"description","label":"Description","default":"Profitieren Sie von exklusiven Preisvorteilen auf eine kuratierte Auswahl unserer beliebtesten Modelle. Wählen Sie beliebige 3 Paare für 84,95 € – eine seltene Gelegenheit, außergewöhnlichen Komfort zu sichern, bevor diese Modelle nicht mehr verfügbar sind."},{"type":"text","id":"info","label":"info","default":"Nur solange der Vorrat reicht."},{"type":"inline_richtext","id":"founder_note","label":"Founder Note","default":"Anmerkung des Gründers: Diese beliebte Kollektion wird aufgrund einer neuen Markenstrategie nicht zurückkehren. Nutzen Sie jetzt Ihre letzte Gelegenheit, Artikel zu Produktionspreisen zu sichern."},{"type":"image_picker","id":"img_sign","label":"Founder Signature "},{"type":"header","content":"timer Settings"},{"type":"color","id":"timerBg","label":"Timer Bg Color","default":"#324a34"},{"type":"text","id":"timer_text","label":"Timer TExt","default":"Sale endet in"},{"type":"text","id":"timer_text_info","label":"Timer Text Info","default":"Diese Modelle werden nicht wieder aufgefüllt."},{"type":"select","id":"end_day","label":"End Day","options":[{"value":"1","label":"1"},{"value":"2","label":"2"},{"value":"3","label":"3"},{"value":"4","label":"4"},{"value":"5","label":"5"},{"value":"6","label":"6"},{"value":"7","label":"7"},{"value":"8","label":"8"},{"value":"9","label":"9"},{"value":"10","label":"10"},{"value":"11","label":"11"},{"value":"12","label":"12"},{"value":"13","label":"13"},{"value":"14","label":"14"},{"value":"15","label":"15"},{"value":"16","label":"16"},{"value":"17","label":"17"},{"value":"18","label":"18"},{"value":"19","label":"19"},{"value":"20","label":"20"},{"value":"21","label":"21"},{"value":"22","label":"22"},{"value":"23","label":"23"},{"value":"24","label":"24"},{"value":"25","label":"25"},{"value":"26","label":"26"},{"value":"27","label":"27"},{"value":"28","label":"28"},{"value":"29","label":"29"},{"value":"30","label":"30"},{"value":"31","label":"31"}],"default":"20"},{"type":"select","id":"end_month","label":"End Month","options":[{"value":"1","label":"January"},{"value":"2","label":"February"},{"value":"3","label":"March"},{"value":"4","label":"April"},{"value":"5","label":"May"},{"value":"6","label":"June"},{"value":"7","label":"July"},{"value":"8","label":"August"},{"value":"9","label":"September"},{"value":"10","label":"October"},{"value":"11","label":"November"},{"value":"12","label":"December"}],"default":"2"},{"type":"select","id":"end_year","label":"End Year","options":[{"value":"2026","label":"2026"},{"value":"2027","label":"2027"},{"value":"2028","label":"2028"}],"default":"2026"},{"type":"select","id":"end_hour","label":"End Hour (24h)","options":[{"value":"0","label":"00"},{"value":"1","label":"01"},{"value":"2","label":"02"},{"value":"3","label":"03"},{"value":"4","label":"04"},{"value":"5","label":"05"},{"value":"6","label":"06"},{"value":"7","label":"07"},{"value":"8","label":"08"},{"value":"9","label":"09"},{"value":"10","label":"10"},{"value":"11","label":"11"},{"value":"12","label":"12"},{"value":"13","label":"13"},{"value":"14","label":"14"},{"value":"15","label":"15"},{"value":"16","label":"16"},{"value":"17","label":"17"},{"value":"18","label":"18"},{"value":"19","label":"19"},{"value":"20","label":"20"},{"value":"21","label":"21"},{"value":"22","label":"22"},{"value":"23","label":"23"}],"default":"23"},{"type":"select","id":"end_minute","label":"End Minute","options":[{"value":"0","label":"00"},{"value":"15","label":"15"},{"value":"30","label":"30"},{"value":"45","label":"45"}],"default":"0"},{"type":"text","id":"show_more_text","label":"Show more text","default":"Show more"},{"type":"text","id":"show_less_text","label":"Show less text","default":"Show less"}],"blocks":[{"type":"feature","name":"Feature Item","settings":[{"type":"image_picker","id":"icon","label":"Icon"},{"type":"text","id":"text","label":"Text","default":"Atmungsaktive Materialien"}]}],"presets":[{"name":"Clearance Sale Section","category":"Promotions"}]}{% endschema %}
<script>document.addEventListener('DOMContentLoaded',()=>{const buttons=document.querySelectorAll('.feature-toggle-btn');buttons.forEach(btn=>{const list=document.getElementById(btn.dataset.target);if(!list)return;btn.addEventListener('click',()=>{const isOpen=list.classList.toggle('is-open');btn.textContent=isOpen?btn.dataset.less:btn.dataset.more})})});</script>
<script>const endYear={{ section.settings.end_year }},endMonth={{ section.settings.end_month }}-1,endDay={{ section.settings.end_day }},endHour={{ section.settings.end_hour }},endMinute={{ section.settings.end_minute }},countdownDate=Date.UTC(endYear,endMonth,endDay,endHour,endMinute,0);function updateCountdown(){const e=(new Date).getTime(),t=countdownDate-e;if(t<=0)return void(document.getElementById("countdown-timer").innerHTML="EXPIRED");const n=Math.floor(t/864e5),o=Math.floor(t%864e5/36e5),i=Math.floor(t%36e5/6e4),d=Math.floor(t%6e4/1e3),a=n>0?n+"d : ":"";document.getElementById("countdown-timer").innerHTML=a+o.toString().padStart(2,"0")+" : "+i.toString().padStart(2,"0")+" : "+d.toString().padStart(2,"0")}updateCountdown(),setInterval(updateCountdown,1e3);</script>