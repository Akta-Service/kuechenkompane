{% comment %}
  Bestseller Collection Section
  Desktop:
    - Odd-positioned blocks  → horizontal card (image left, product info right)
    - Even-positioned blocks → full-height image card (image fills card, no visible text)
    - OR: merchant can force "horizontal" or "image_only" per block
  Mobile:
    - ALL blocks always render as horizontal cards (image left, info right)
{% endcomment %}

<style>
  /* ── ROOT ── */
  #kk-bestseller-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.desktop_padding_top }}px 0 {{ section.settings.desktop_padding_bottom }}px;
  }

  #kk-bestseller-{{ section.id }} .bs-container {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.container_padding_h }}px;
  }

  /* ── SECTION HEADER ── */
  #kk-bestseller-{{ section.id }} .bs-header {
    text-align: {{ section.settings.header_align }};
    margin-bottom: {{ section.settings.header_bottom_gap }}px;
  }

  #kk-bestseller-{{ section.id }} .bs-heading {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.desktop_heading_size }}px;
    font-weight: {{ section.settings.desktop_heading_weight }};
    line-height: {{ section.settings.desktop_heading_line_height }};
    letter-spacing: {{ section.settings.desktop_heading_letter_spacing }}px;
    text-transform: {{ section.settings.heading_transform }};
    margin: 0 0 8px;
  }

  #kk-bestseller-{{ section.id }} .bs-heading-underline {
    display: inline-block;
    width: 60px;
    height: 3px;
    background: {{ section.settings.accent_color }};
    margin: 0 auto;
  }

  /* ── GRID ── */
  #kk-bestseller-{{ section.id }} .bs-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.desktop_columns }}, 1fr);
    gap: {{ section.settings.desktop_gap }}px;
  }

  /* ── CARD WRAPPER (grid cell) ── */
  #kk-bestseller-{{ section.id }} .bs-card-wrap {
    display: flex;
    flex-direction: column;
    box-shadow: {{ section.settings.card_box_shadow }};
    border-radius: {{ section.settings.card_radius }}px;
  }

  /* ── CARD BASE ── */
  #kk-bestseller-{{ section.id }} .bs-card {
    flex: 1;
    overflow: hidden;
    background: {{ section.settings.card_bg }};
    position: relative;
  }

  /* ── CARD FOOTER (price + button, below the card) ── */
  #kk-bestseller-{{ section.id }} .bs-card__footer {
    padding: {{ section.settings.footer_padding_v }}px {{ section.settings.card_body_padding }}px;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.footer_inner_gap }}px;
  }

  /* ── HORIZONTAL CARD (odd items on desktop) ── */
  #kk-bestseller-{{ section.id }} .bs-card--horizontal {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    min-height: {{ section.settings.card_min_height }}px;
  }

  #kk-bestseller-{{ section.id }} .bs-card--horizontal .bs-card__img {
    flex: 0 0 {{ section.settings.h_card_img_width }}%;
    position: relative;
    overflow: hidden;
  }
  #kk-bestseller-{{ section.id }} .bs-card--horizontal .bs-card__img img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.h_card_img_fit }};
    object-position: center;
    transition: transform 0.4s ease;
  }
  #kk-bestseller-{{ section.id }} .bs-card--horizontal:hover .bs-card__img img {
    transform: scale(1.04);
  }

  #kk-bestseller-{{ section.id }} .bs-card--horizontal .bs-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 6px;
    padding: {{ section.settings.card_body_padding }}px;
    overflow: hidden;
  }

  /* ── IMAGE-ONLY CARD (even items on desktop) ── */
  #kk-bestseller-{{ section.id }} .bs-card--image {
    min-height: {{ section.settings.card_min_height }}px;
    position: relative;
  }

  #kk-bestseller-{{ section.id }} .bs-card--image .bs-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  #kk-bestseller-{{ section.id }} .bs-card--image .bs-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.4s ease;
  }
  #kk-bestseller-{{ section.id }} .bs-card--image:hover .bs-card__img img {
    transform: scale(1.04);
  }

  /* ── BADGE ── */
  #kk-bestseller-{{ section.id }} .bs-badge {
    position: absolute;
    top: {{ section.settings.badge_top }}px;
    left: {{ section.settings.badge_left }}px;
    z-index: 2;
    {% comment %} width: {{ section.settings.badge_circle_size }}px;
    height: {{ section.settings.badge_circle_size }}px;  border-radius: 50%; {% endcomment %}

        width: 84px;
    height: 30px;
    background: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_text_color }};
    font-size: {{ section.settings.desktop_badge_size }}px;
    font-weight: {{ section.settings.desktop_badge_weight }};
    line-height: 1;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  /* ── CARD BODY CONTENT ── */
  #kk-bestseller-{{ section.id }} .bs-product-name {
    color: {{ section.settings.product_name_color }};
    font-size: {{ section.settings.desktop_name_size }}px;
    font-weight: {{ section.settings.desktop_name_weight }};
    line-height: {{ section.settings.desktop_name_line_height }};
    letter-spacing: {{ section.settings.desktop_name_letter_spacing }}px;
    text-decoration: none;
    display: block;
    margin: 0;
  }
  #kk-bestseller-{{ section.id }} .bs-product-name:hover {
    color: {{ section.settings.accent_color }};
  }

  /* Stars */
  #kk-bestseller-{{ section.id }} .bs-stars {
    display: flex;
    align-items: center;
    gap: 3px;
  }
  #kk-bestseller-{{ section.id }} .bs-star {
    color: {{ section.settings.star_color }};
    font-size: {{ section.settings.desktop_stars_size }}px;
    font-weight: {{ section.settings.desktop_stars_weight }};
    line-height: 1;
  }
  #kk-bestseller-{{ section.id }} .bs-star--empty {
    color: {{ section.settings.empty_star_color }};
  }
  #kk-bestseller-{{ section.id }} .bs-star-label {
    color: {{ section.settings.subtitle_color }};
    font-size: {{ section.settings.desktop_stars_size | minus: 2 }}px;
    font-weight: {{ section.settings.desktop_stars_weight }};
    margin-left: 2px;
  }

  /* Features list */
  #kk-bestseller-{{ section.id }} .bs-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  #kk-bestseller-{{ section.id }} .bs-features li {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    color: {{ section.settings.feature_text_color }};
    font-size: {{ section.settings.desktop_feature_size }}px;
    font-weight: {{ section.settings.desktop_feature_weight }};
    line-height: {{ section.settings.desktop_feature_line_height }};
    letter-spacing: {{ section.settings.desktop_feature_letter_spacing }}px;
  }
  #kk-bestseller-{{ section.id }} .bs-features li::before {
    content: '✓';
    color: {{ section.settings.feature_check_color }};
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Price */
  #kk-bestseller-{{ section.id }} .bs-price-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  #kk-bestseller-{{ section.id }} .bs-price {
    color: {{ section.settings.price_color }};
    font-size: {{ section.settings.desktop_price_size }}px;
    font-weight: {{ section.settings.desktop_price_weight }};
    line-height: {{ section.settings.desktop_price_line_height }};
    letter-spacing: {{ section.settings.desktop_price_letter_spacing }}px;
  }
  #kk-bestseller-{{ section.id }} .bs-price-compare {
    color: {{ section.settings.compare_color }};
    font-size: {{ section.settings.desktop_compare_size }}px;
    font-weight: 400;
    text-decoration: line-through;
    line-height: 1;
  }

  /* Button */
  #kk-bestseller-{{ section.id }} .bs-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: {{ section.settings.btn_top_gap }}px;
    padding: {{ section.settings.desktop_btn_padding_v }}px {{ section.settings.desktop_btn_padding_h }}px;
    border-radius: {{ section.settings.btn_radius }}px;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text_color }};
    border: 2px solid {{ section.settings.btn_border_color }};
    font-size: {{ section.settings.desktop_btn_size }}px;
    font-weight: {{ section.settings.desktop_btn_weight }};
    line-height: {{ section.settings.desktop_btn_line_height }};
    letter-spacing: {{ section.settings.desktop_btn_letter_spacing }}px;
    text-transform: {{ section.settings.btn_transform }};
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
    width: 100%;
  }
  #kk-bestseller-{{ section.id }} .bs-btn:hover {
    background: {{ section.settings.btn_hover_bg }};
    color: {{ section.settings.btn_hover_text }};
  }

  /* ── MOBILE ── */
  @media (max-width: 767px) {
    #kk-bestseller-{{ section.id }} {
      padding: {{ section.settings.mobile_padding_top }}px 0 {{ section.settings.mobile_padding_bottom }}px;
    }

    #kk-bestseller-{{ section.id }} .bs-container {
      padding: 0 {{ section.settings.mobile_container_padding_h }}px;
    }

    /* Heading */
    #kk-bestseller-{{ section.id }} .bs-heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
      font-weight: {{ section.settings.mobile_heading_weight }};
      line-height: {{ section.settings.mobile_heading_line_height }};
      letter-spacing: {{ section.settings.mobile_heading_letter_spacing }}px;
    }

    /* Single column on mobile */
    #kk-bestseller-{{ section.id }} .bs-grid {
      grid-template-columns: 1fr;
      gap: {{ section.settings.mobile_gap }}px;
    }

    /* Mobile card: CSS grid — image left column (full height), body+footer right column */
    #kk-bestseller-{{ section.id }} .bs-card-wrap {
      display: grid;
      grid-template-columns: {{ section.settings.mobile_img_width }}% 1fr;
      grid-template-rows: 1fr auto;
      min-height: {{ section.settings.mobile_card_height }}px;
      overflow: hidden;
    }

    /* Flatten .bs-card children into the card-wrap grid */
    #kk-bestseller-{{ section.id }} .bs-card {
      display: contents;
    }

    /* Image: left column, spans both rows */
    #kk-bestseller-{{ section.id }} .bs-card .bs-card__img {
      grid-column: 1;
      grid-row: 1 / 3;
      position: relative;
      overflow: hidden;
    }
    #kk-bestseller-{{ section.id }} .bs-card .bs-card__img img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center;
    }

    /* Body: right column top — show even on image-only cards */
    #kk-bestseller-{{ section.id }} .bs-card__body {
      grid-column: 2;
      grid-row: 1;
      display: flex !important;
      flex-direction: column;
      justify-content: flex-start;
      gap: 4px;
      padding: {{ section.settings.mobile_card_padding }}px {{ section.settings.mobile_card_padding }}px {{ section.settings.mobile_card_padding | divided_by: 2 }}px !important;
      overflow: hidden;
      align-self: start;
    }

    /* Footer: right column bottom (price + button, directly below body) */
    #kk-bestseller-{{ section.id }} .bs-card__footer {
      grid-column: 2;
      grid-row: 2;
      padding: 0 {{ section.settings.mobile_card_padding }}px {{ section.settings.mobile_card_padding }}px;
    }

    /* Mobile typography */
    #kk-bestseller-{{ section.id }} .bs-product-name {
      font-size: {{ section.settings.mobile_name_size }}px;
      font-weight: {{ section.settings.mobile_name_weight }};
      line-height: {{ section.settings.mobile_name_line_height }};
      letter-spacing: {{ section.settings.mobile_name_letter_spacing }}px;
    }
    #kk-bestseller-{{ section.id }} .bs-star { font-size: {{ section.settings.mobile_stars_size }}px; }
    #kk-bestseller-{{ section.id }} .bs-star-label { font-size: {{ section.settings.mobile_stars_size | minus: 2 }}px; }
    #kk-bestseller-{{ section.id }} .bs-features li {
      font-size: {{ section.settings.mobile_feature_size }}px;
      font-weight: {{ section.settings.mobile_feature_weight }};
      line-height: {{ section.settings.mobile_feature_line_height }};
      letter-spacing: {{ section.settings.mobile_feature_letter_spacing }}px;
    }
    #kk-bestseller-{{ section.id }} .bs-price {
      font-size: {{ section.settings.mobile_price_size }}px;
      font-weight: {{ section.settings.mobile_price_weight }};
      line-height: {{ section.settings.mobile_price_line_height }};
      letter-spacing: {{ section.settings.mobile_price_letter_spacing }}px;
    }
    #kk-bestseller-{{ section.id }} .bs-price-compare {
      font-size: {{ section.settings.mobile_compare_size }}px;
    }
    #kk-bestseller-{{ section.id }} .bs-btn {
      font-size: {{ section.settings.mobile_btn_size }}px;
      font-weight: {{ section.settings.mobile_btn_weight }};
      line-height: {{ section.settings.mobile_btn_line_height }};
      letter-spacing: {{ section.settings.mobile_btn_letter_spacing }}px;
      padding: {{ section.settings.mobile_btn_padding_v }}px {{ section.settings.mobile_btn_padding_h }}px;
    }
    #kk-bestseller-{{ section.id }} .bs-badge {
      {% comment %} width: {{ section.settings.mobile_badge_circle_size }}px; {% endcomment %}
      width: 85px;
      {% comment %} height: {{ section.settings.mobile_badge_circle_size }}px; {% endcomment %}
      height: 20px;
      font-size: {{ section.settings.mobile_badge_size }}px;
    }
    #kk-bestseller-{{ section.id }} .bs-header {
      margin-bottom: {{ section.settings.header_bottom_gap | times: 0.7 | round }}px;
    }
  }
</style>

{% if section.settings.desktop_layout_mode == 'alternating' %}
  {% assign use_alternating = true %}
{% else %}
  {% assign use_alternating = false %}
{% endif %}

<section id="kk-bestseller-{{ section.id }}">
  <div class="bs-container">
    {%- comment -%} Section header {%- endcomment -%}
    {% if section.settings.heading != blank %}
      <div class="bs-header">
        <h2 class="bs-heading">{{ section.settings.heading }}</h2>
        {% if section.settings.show_heading_underline %}
          <div class="bs-heading-underline"></div>
        {% endif %}
      </div>
    {% endif %}

    {%- comment -%} Product grid {%- endcomment -%}
    <div class="bs-grid">
      {% for block in section.blocks %}
        {% liquid
          assign product = block.settings.product
          assign badge_text = block.settings.badge_text
          assign features_raw = block.settings.features
          assign block_card_style = block.settings.desktop_card_style

          assign card_style = 'horizontal'
          if block_card_style == 'auto'
            if use_alternating
              assign remainder = forloop.index | modulo: 2
              if remainder == 0
                assign card_style = 'image_only'
              else
                assign card_style = 'horizontal'
              endif
            endif
          else
            assign card_style = block_card_style
          endif

          assign product_url = '#'
          assign product_title = block.settings.product_title
          assign product_price = block.settings.product_price
          assign product_compare = block.settings.compare_price
          if product != blank
            assign product_url = product.url
            if product_title == blank
              assign product_title = product.title
            endif
            if product_price == blank
              assign product_price = product.price | money
            endif
            if product_compare == blank and product.compare_at_price > product.price
              assign product_compare = product.compare_at_price | money
            endif
          endif
        %}

        <div class="bs-card-wrap" {{ block.shopify_attributes }}>
          <div class="bs-card bs-card--{{ card_style }}">
            {%- comment -%} Image {%- endcomment -%}
            <div class="bs-card__img">
              {% if badge_text != blank %}
                <span class="bs-badge">{{ badge_text }}</span>
              {% endif %}
              <a href="{{ product_url }}" tabindex="-1" aria-hidden="true">
                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag: loading: 'lazy', alt: block.settings.image.alt
                    | default: product_title
                  }}
                {% elsif product != blank and product.featured_image != blank %}
                  {{
                    product.featured_image
                    | image_url: width: 800
                    | image_tag: loading: 'lazy', alt: product.featured_image.alt
                    | default: product_title
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'bs-placeholder-svg' }}
                {% endif %}
              </a>
            </div>

            {%- comment -%} Card body — hidden on desktop image-only cards, shown on mobile {%- endcomment -%}
            <div
              class="bs-card__body"
              {% if card_style == 'image_only' %}
                style="display:none"
              {% endif %}
            >
              <a href="{{ product_url }}" class="bs-product-name">
                {{ product_title | default: 'Product Name' }}
              </a>

              {% if block.settings.show_stars %}
                <div class="bs-stars">
                  {% assign full_stars = block.settings.star_rating | round %}
                  {% for i in (1..5) %}
                    {% if i <= full_stars %}
                      <span class="bs-star">★</span>
                    {% else %}
                      <span class="bs-star bs-star--empty">★</span>
                    {% endif %}
                  {% endfor %}
                  <span class="bs-star-label">({{ block.settings.star_rating }}/5)</span>
                </div>
              {% endif %}

              {% if features_raw != blank %}
                <ul class="bs-features">
                  {% assign feature_lines = features_raw | newline_to_br | split: '<br />' %}
                  {% for line in feature_lines %}
                    {% assign clean_line = line | strip_html | strip %}
                    {% if clean_line != blank %}
                      <li>{{ clean_line }}</li>
                    {% endif %}
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          </div>

          {%- comment -%} Footer: price + CTA, always visible below the card {%- endcomment -%}
          <div class="bs-card__footer">
            {% if product_price != blank or product != blank %}
              <div class="bs-price-row">
                <span class="bs-price">
                  {% if product != blank and block.settings.product_price == blank %}
                    {{ product.price | money }}
                  {% else %}
                    {{ block.settings.product_price }}
                  {% endif %}
                </span>
                {% if product_compare != blank %}
                  <span class="bs-price-compare">
                    {% if product != blank
                      and block.settings.compare_price == blank
                      and product.compare_at_price > product.price
                    %}
                      {{ product.compare_at_price | money }}
                    {% elsif block.settings.compare_price != blank %}
                      {{ block.settings.compare_price }}
                    {% endif %}
                  </span>
                {% endif %}
              </div>
            {% endif %}

            <a href="{{ product_url }}" class="bs-btn">
              {{ block.settings.button_label | default: section.settings.default_button_label }}
              {% if section.settings.btn_show_arrow %}
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              {% endif %}
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bestseller Collection",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "UNSERE BESTSELLER – JETZT BIS ZU -75% SPAREN"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Heading text case",
      "default": "uppercase",
      "options": [
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "capitalize", "label": "Capitalize" },
        { "value": "none", "label": "As typed" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_heading_underline",
      "label": "Show underline accent",
      "default": false
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "range",
      "id": "header_bottom_gap",
      "label": "Gap below heading (px)",
      "min": 8,
      "max": 60,
      "step": 4,
      "default": 32
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#1a2e1a"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (checkmarks, button, etc.)",
      "default": "#2e7d32"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "product_name_color",
      "label": "Product name color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle / rating color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "feature_text_color",
      "label": "Feature list color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "feature_check_color",
      "label": "Feature checkmark color",
      "default": "#2e7d32"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "compare_color",
      "label": "Compare price color",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color (filled)",
      "default": "#f5a623"
    },
    {
      "type": "color",
      "id": "empty_star_color",
      "label": "Star color (empty)",
      "default": "#dddddd"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "select",
      "id": "desktop_layout_mode",
      "label": "Desktop card layout mode",
      "default": "alternating",
      "options": [
        { "value": "alternating", "label": "Alternating (odd=horizontal, even=image-only)" },
        { "value": "all_horizontal", "label": "All horizontal cards" }
      ],
      "info": "Individual blocks can override this with their own setting."
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Columns",
