      "id": "btn_url",
      "label": "Button Url"
    },
    {
      "type": "header",
      "content": "Background Image Settings"
    },
    {
      "type": "image_picker",
      "id": "bg",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "bg_mobile",
      "label": "Background Image (Mobile)"
    },
    {
      "type": "header",
      "content": "Timer Settings"
    },
    {
      "type": "text",
      "id": "countdown_time",
      "label": "Target Date & Time (German time)",
      "default": "2025-12-24T23:59:59"
    },
    {
      "type": "header",
      "content": "Color Settings"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color (general)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "timer_number_color",
      "label": "Timer number color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "timer_label_color",
      "label": "Timer label color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "timer_border_color",
      "label": "Timer box border color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "close_btn_color",
      "label": "Close button color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Wellcome Popup"
    }
  ]
}
{% endschema %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const wellcomePopup = document.getElementById('wellcome-popup');
    const closeBtn = document.getElementById('wellcome-close-btn');

    let stopConfetti = false;
    let autoCloseTimeout = null;

    const colors = ['#FF6B6B', '#FFD93D', '#6BCB77', '#4D96FF', '#845EC2'];

    const isMobile = () => window.innerWidth <= 768;

    function closePopup() {
      if (!wellcomePopup) return;
      wellcomePopup.style.display = 'none';
      stopConfetti = true; // <-- Close button dile confetti off korbe
      if (autoCloseTimeout) clearTimeout(autoCloseTimeout);
    }

    if (closeBtn) closeBtn.addEventListener('click', closePopup);

    function getOrigin(side) {
      return {
        x: side === 'left' ? 0 : 1,
        y: isMobile() ? 0.1 : 0.5,
      };
    }

    document.addEventListener('passwordCorrect', function () {
      console.log('pass match');
      if (!wellcomePopup) return;

      stopConfetti = false; // <-- Confetti chalu korbe. Er por ar true kora jabe na
      wellcomePopup.style.display = 'flex';

      // 6 second por auto close hobe
      autoCloseTimeout = setTimeout(() => {
        closePopup();
        document.dispatchEvent(new Event('greetingStop'));
      }, 60000);

      (function frame() {
        if (stopConfetti) return; // stopConfetti true hole loop thambe

        confetti({
          particleCount: 3,
          angle: 100,
          spread: 70,
          startVelocity: 45,
          ticks: 200,
          scalar: 1.2,
          origin: getOrigin('left'),
          colors,
        });

        confetti({
          particleCount: 5,
          angle: 120,
          spread: 85,
          startVelocity: 45,
          ticks: 200,
          scalar: 1.2,
          origin: getOrigin('right'),
          colors,
        });

        requestAnimationFrame(frame);
      })();
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function startCountdown(targetTimeString) {
      const daysEl = document.getElementById('days');
      const hoursEl = document.getElementById('hours');
      const minutesEl = document.getElementById('minutes');
      const secondsEl = document.getElementById('seconds');

      if (!daysEl || !hoursEl || !minutesEl || !secondsEl) return;

      // Parse target time as German time (Europe/Berlin)
      const targetTime = new Date(new Date(targetTimeString).toLocaleString('en-US', { timeZone: 'Europe/Berlin' }));

      function updateTimer() {
        const now = new Date();
        const germanNow = new Date(now.toLocaleString('en-US', { timeZone: 'Europe/Berlin' }));

        let diffMs = targetTime - germanNow;
        if (diffMs <= 0) diffMs = 0; // Stop at 0

        const totalSeconds = Math.floor(diffMs / 1000);
        const days = Math.floor(totalSeconds / (24 * 3600));
        const hours = Math.floor((totalSeconds % (24 * 3600)) / 3600);
        const minutes = Math.floor((totalSeconds % 3600) / 60);
        const seconds = totalSeconds % 60;

        daysEl.textContent = String(days).padStart(2, '0');
        hoursEl.textContent = String(hours).padStart(2, '0');
        minutesEl.textContent = String(minutes).padStart(2, '0');
        secondsEl.textContent = String(seconds).padStart(2, '0');

        if (diffMs > 0) {
          setTimeout(updateTimer, 1000);
        }
      }

      updateTimer();
    }

    // Example: get target time from section settings (Liquid)
    const countdownTarget = '{{ section.settings.countdown_time }}';
    // Format example: 2025-12-24T23:59:59

    startCountdown(countdownTarget);
  });
</script>
