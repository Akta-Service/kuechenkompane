<style>
    .wellcome-popup{
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      height: 100%;
      display: flex;
      /* display: none; */
      align-items: center;
      z-index: 999;
      flex-direction: column;
      display: none;
    }
    .wellcome-popup-overlay{
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      height: 100%;
      z-index: 999;
      background:rgba(0, 0, 0, 0.83);
      background:rgb(0 0 0 / 57%);
    }
    .wellcome-popup-content {
      position: relative;
      z-index: 9999;
      background: #ffffff;
      padding: 2rem;
      border-radius: 10px;
      width: 500px;
      max-width: 100%;
      max-height: 100vh;
      margin: auto;
      {% comment %} margin-top: 50px; {% endcomment %}
      {% comment %} min-height: 300px; {% endcomment %}
    }
    #confetti {
      position: relative;
      z-index: 999;

    }
    .wellcome-close-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      color: #000;
      border: none;
      font-size: 18px;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      justify-content: center;
      align-items: center;
      transition: 0.3s ease;
      z-index: 99999;
      border: 1px solid #3f3f3f;
      transition: 0.3s;
    }
    .wellcome-close-btn:hover{
      background: #3f3f3f;
      color: #fff;
    }
    .wellcome-popup-title{
      margin: 0 0 20px;
      font-size: 30px;
      text-align: center;
    }
    .wellcome-popup-description {
      margin: 20px 0 10px;
      text-align: center;
      font-size: 16px;
    }
    .popup-timer {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .popup-timer-label {
      text-align: center;
      font-size: 23px;
      font-weight: 500;
    }
    #popup-timer-box {
      font-size: 30px;
      text-align: center;
      font-weight: 700;
    }
    .timer-wrapper {
    display: flex;
    gap: 12px;
    justify-content: center;
  }

  .time-box {
    padding: 12px 5px;
    border-radius: 10px;
    border: 1px solid #283041;
    text-align: center;
    width: 80px;
  }

  .time-box span {
    font-size: 18px;
    color: #000000;
    display: block;
    font-weight: 500;
    line-height: 1.5;
  }

  .time-box label {
    font-size: 18px;
    display: block;
    font-weight: 600;
    line-height: 1;
  }
  .timer-wrapper {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .wellcome-popup-btn {
    text-align: center;
  }

  .wellcome-popup-content {
    display: flex;
    flex-direction: column;
  }
</style>
<style>
  .wellcome-popup-content{
    {% if section.settings.bg != blank %}
    background-image: url({{ section.settings.bg | image_url }});
    {% else %}
      background-color: #000;
    {% endif %}
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: {{ section.settings.text_color }};
  }
  .wellcome-popup-title {
    color: {{ section.settings.title_color }};
  }
  .wellcome-popup-description {
    color: {{ section.settings.desc_color }};
  }
  .time-box span {
    color: {{ section.settings.timer_number_color }};
  }
  .time-box label {
    color: {{ section.settings.timer_label_color }};
  }
  .time-box {
    border: 1px solid {{ section.settings.timer_border_color }};
  }
  .wellcome-close-btn {
    color: {{ section.settings.close_btn_color }};
    border: 1px solid {{ section.settings.close_btn_color }};
  }
  .wellcome-close-btn:hover {
    background: {{ section.settings.close_btn_color }};
    color: {{ section.settings.close_btn_hover_text | default: '#000000' }};
  }

  @media (max-width: 768px) {
    .wellcome-popup-content{
    {% if section.settings.bg_mobile != blank %}
      background-image: url({{ section.settings.bg_mobile | image_url }});
    {% endif %}
    }
  }
</style>

<div class="wellcome-popup" id="wellcome-popup">
  <div class="wellcome-popup-overlay"></div>
  <div class="wellcome-popup-content">
    <button id="wellcome-close-btn" class="wellcome-close-btn">✕</button>
    {% if section.settings.title != blank %}
      <h4 class="wellcome-popup-title">{{ section.settings.title }}</h4>
    {% endif %}
    <div class="timer-wrapper">
      <div class="time-box"><span id="days">00</span><label>Tage</label></div>
      <div class="time-box"><span id="hours">00</span><label>Std</label></div>
      <div class="time-box"><span id="minutes">00</span><label>Min</label></div>
      <div class="time-box"><span id="seconds">00</span><label>Sek</label></div>
    </div>
    {% if section.settings.description != blank %}
      <p class="wellcome-popup-description">{{ section.settings.description }}</p>
    {% endif %}
    <div class="wellcome-popup-btn">
      <a class="m-button mrk-btn m-button--primary  " href="{{ section.settings.btn_url }}">
        {{- section.settings.btn_text -}}
      </a>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@tsparticles/confetti@3.0.3/tsparticles.confetti.bundle.min.js"></script>

{% schema %}
{
  "name": "Wellcome Popup",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "description",
