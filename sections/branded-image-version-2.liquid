<style>.branded-img-area.style-2{margin-top:{{ section.settings.margin_top }}px;margin-bottom:{{ section.settings.margin_bottom }}px}.branded-img-content{display:grid;grid-template-columns:repeat(2,1fr);gap:30px}.branded-right-item{height:600px;position:relative;filter:drop-shadow(5px 0 43px rgba(48,48,48,.35));z-index:1}.branded-img-inner{width:100%;height:100%;background-size:cover;background-repeat:no-repeat;background-position:center;-webkit-mask-image:url("data:image/svg+xml,%3Csvg width='200' height='300' viewBox='0 0 200 300' preserveAspectRatio='none' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M200 0H60C47.6 0 36.2 6.2 29.5 16.5L4.5 56.5C1.6 61.1 0 66.4 0 71.9V228.1C0 233.6 1.6 238.9 4.5 243.5L29.5 283.5C36.2 293.8 47.6 300 60 300H200V0Z' fill='black'/%3E%3C/svg%3E");mask-image:url("data:image/svg+xml,%3Csvg width='200' height='300' viewBox='0 0 200 300' preserveAspectRatio='none' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M200 0H60C47.6 0 36.2 6.2 29.5 16.5L4.5 56.5C1.6 61.1 0 66.4 0 71.9V228.1C0 233.6 1.6 238.9 4.5 243.5L29.5 283.5C36.2 293.8 47.6 300 60 300H200V0Z' fill='black'/%3E%3C/svg%3E");-webkit-mask-size:100% 100%;mask-size:100% 100%;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat}.branded-left-item{position:relative}.branded-title{font-size:{{ section.settings.title_font_size }}px;font-weight:400;text-transform:capitalize}.branded-text p{font-size:{{ section.settings.text_font_size }}px;margin-top:30px;margin-bottom:28px}.branded-text p[style*="font-size: px"]{font-size:16px}.branded-text{max-width:420px;margin:0 auto;text-align:center;position:absolute;width:100%;left:50%;top:50%;transform:translate(-50%,-50%);padding:0 10px}@media only screen and (max-width:749px){.branded-img-content{display:flex;flex-direction:column}.branded-text{position:static;transform:translate(0);margin-bottom:20px;padding:0 16px}.branded-left-item{padding:45px 0}.branded-right-item{height:350px;width:100%}.branded-img-area.style-2{margin-top:{{ section.settings.mobile_margin_top }}px;margin-bottom:{{ section.settings.mobile_margin_bottom }}px}.branded-title{font-size:30px}}</style>
<div class="branded-img-area style-2 m-color-{{ section.settings.color_scheme }}"><div class="branded-img-content"><div class="branded-left-item"><div class="branded-text">{% for block in section.blocks %}{%- case block.type -%}{%- when 'title' -%}<h3 class="branded-title {{ section.settings.heading_type }}">{{ block.settings.title }}</h3>{%- when 'sub_title' -%}<h3 class="branded-title {{ section.settings.sub_heading }}">{{ block.settings.sub_title }}</h3>{%- when 'text' -%}<p class="{{ section.settings.des_size}}">{{ block.settings.text }}</p>{%- when 'btn' -%}<div class="branded-btn branded-btn-{{ section.id }}"><a class="mrk-btn m-button {{ section.settings.button_style }} {{ section.settings.button_size }}" href="{{ block.settings.button_link }}">{{- block.settings.button_text -}}</a></div>{%- endcase -%}{%- endfor -%}</div></div><div class="branded-right-item"><div class="branded-img-inner"{% if section.settings.bg_img != blank %} style="background-image:url('{{ section.settings.bg_img | img_url: 'master' }}');"{% endif %}></div></div></div></div>
{% schema %}{"name":"Apex Branded Image Ver 2","settings":[{"type":"color_scheme","id":"color_scheme","label":"Color scheme"},{"type":"color","id":"shape_bg","label":"Shape Backgroung Color","default":"#deceba"},{"type":"header","content":"Section Spacing"},{"type":"range","id":"margin_top","label":"Margin Top","default":20,"min":0,"max":100,"unit":"px","step":1},{"type":"range","id":"margin_bottom","label":"Margin Bottom","default":20,"min":0,"max":100,"unit":"px","step":1},{"type":"header","content":"Mobile Section Spacing"},{"type":"range","id":"mobile_margin_top","label":"Mobile Margin Top","default":10,"min":0,"max":50,"unit":"px","step":1},{"type":"range","id":"mobile_margin_bottom","label":"Mobile Margin Bottom","default":10,"min":0,"max":50,"unit":"px","step":1},{"type":"header","content":"Section Image"},{"type":"image_picker","id":"bg_img","label":"Image"},{"type":"header","content":"Typography"},{"type":"select","id":"heading_type","label":"Choose Heading Size","options":[{"value":"mrk-h1","label":"H1"},{"value":"mrk-h2","label":"H2"},{"value":"mrk-h3","label":"H3"},{"value":"mrk-h4","label":"H4"},{"value":"mrk-h5","label":"H5"},{"value":"mrk-h6","label":"H6"}],"default":"mrk-h1"},{"type":"header","content":"Select Sub Heading size"},{"type":"select","id":"sub_heading","label":"Sub Heading Size","default":"p-medium","options":[{"value":"p-xl","label":"Extra Large"},{"value":"p-large","label":"Large"},{"value":"p-medium","label":"Medium"},{"value":"p-small","label":"Small"},{"value":"p-x-small","label":"Extra Small"}]},{"type":"header","content":"Select Decription size"},{"type":"select","id":"des_size","label":"Decription size","default":"p-medium","options":[{"value":"p-xl","label":"Extra Large"},{"value":"p-large","label":"Large"},{"value":"p-medium","label":"Medium"},{"value":"p-small","label":"Small"},{"value":"p-x-small","label":"Extra Small"}]},{"type":"header","content":"Button"},{"type":"select","id":"button_style","label":"Button style","options":[{"value":"m-button--primary","label":"Primary button"},{"value":"m-button--secondary","label":"Secondary button"},{"value":"m-button--white","label":"White button"},{"value":"m-button--link","label":"Underline button"}],"default":"m-button--primary"},{"type":"select","id":"button_size","label":"Button size","options":[{"value":"m-button--small","label":"Button small"},{"value":"","label":"Button medium"},{"value":"m-button--large","label":"Button large"}],"default":""}],"blocks":[{"name":"Title","type":"title","settings":[{"type":"text","id":"title","label":"Title","default":"Cosmetics that inspire"}]},{"name":"Sub Title","type":"sub_title","settings":[{"type":"text","id":"sub_title","label":"Sub Title","default":"CONFIDENCE"}]},{"name":"Description","type":"text","settings":[{"type":"text","id":"text","label":"Description","default":"Designed for women who balance ambition and authenticity, our products empower you to embrace your individuality while looking your best, whether you’re conquering the boardroom or dancing the night away."}]},{"name":"Button","type":"btn","settings":[{"type":"text","id":"button_text","label":"Button Text","default":"Discover more"},{"type":"url","id":"button_link","label":"Button Link"}]}],"presets":[{"name":"Apex Branded Image Ver 2","settings":{}}]}{% endschema %}