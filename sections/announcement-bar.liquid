<style>
  .header--sticky-ann {
    position: sticky;
    top: 0;
    z-index: 12;
  }
  .announcement-bar-wrapper {
    width: 100%;
    background-color: var(--announcement-bg, #494949);
    padding: 10px 0;
  }
  .announcement-bar-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
    width: 100%;
    overflow: hidden;
  }
  .announcement-bar-content {
    text-align: center;
    color: #fff;
    font-family: var(--announcement-font, Arial, sans-serif);
    font-weight: 400;
    font-size: var(--announcement-font-size);
  }
  .announcement-bar-wrapper p {
    line-height: 1;
  }

  /* Marquee */
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }
  .announcement-marquee {
    white-space: nowrap;
    width: 100%;
  }
  .announcement-marquee-track {
    display: inline-flex;
    animation: marquee var(--marquee-speed, 40s) linear infinite;
    will-change: transform;
  }
  .announcement-marquee-item {
    display: inline-flex;
    align-items: center;
    margin: 0 40px;
    white-space: normal;
    color: #fff;
    font-size: var(--announcement-font-size, 1.25rem);
  }

  /* Splide Slider */
  .announcement-slider.splide {
    width: 100%;
  }
  .announcement-slider .splide__slide {
    text-align: center;
    color: #fff;
    font-size: var(--announcement-font-size, 1.25rem);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .announcement-slider .splide__track {
    overflow: hidden;
  }
  .announcement-slider .splide__pagination,
  .announcement-slider .splide__arrows {
    display: none;
  }
</style>

{% liquid
  assign show_announcement = false
  assign collection_list = section.settings.collection_list

  for coll in collection_list
    if collection.handle == coll.handle
      assign show_announcement = true
    endif
  endfor
%}

{% if show_announcement %}
  <div
    class="announcement-bar-wrapper"
    style="--announcement-bg: {{ section.settings.bg_color }}; --announcement-font-size: {{ section.settings.font_size }}rem;"
  >
    <div class="announcement-bar-container">
      {% case section.settings.announcement_animation_type %}

        {% when 'marquee' %}
          <div class="announcement-marquee">
            {% if section.blocks.size > 0 %}
              {% assign blocks_exist = true %}
            {% else %}
              {% assign blocks_exist = false %}
            {% endif %}
            {% for row in (1..3) %}
              <div class="announcement-marquee-track" style="--marquee-speed: {{ section.settings.marquee_speed }}s;">
                {% if blocks_exist %}
                  {% for block in section.blocks %}
                    <span class="announcement-marquee-item">{{ block.settings.block_text }}</span>
                  {% endfor %}
                {% else %}
                  <span class="announcement-marquee-item"><p><strong>SUMMER SALE:&nbsp;</strong>Up to 70%</p></span>
                  <span class="announcement-marquee-item"><p><strong>FREE </strong>Shipping On<strong> ALL </strong>Orders!</p></span>
                  <span class="announcement-marquee-item"><p><strong>30-day</strong> money-back guarantee</p></span>
                {% endif %}
              </div>
            {% endfor %}
          </div>

        {% when 'slider' %}
          <div id="mrk-ann-slider--{{ section.id }}" class="splide announcement-slider">
            <div class="splide__track">
              <ul class="splide__list">
                {% if section.blocks.size > 0 %}
                  {% for block in section.blocks %}
                    <li class="splide__slide">{{ block.settings.block_text }}</li>
                  {% endfor %}
                {% else %}
                  <li class="splide__slide"><p><strong>SUMMER SALE:&nbsp;</strong>Up to 70%</p></li>
                  <li class="splide__slide"><p><strong>FREE </strong>Shipping On<strong> ALL </strong>Orders!</p></li>
                  <li class="splide__slide"><p><strong>30-day</strong> money-back guarantee</p></li>
                {% endif %}
              </ul>
            </div>
          </div>

        {% else %}
          <div class="announcement-bar-content">
            <p><strong>SUMMER SALE:&nbsp;</strong>Up to 70%</p>
          </div>

      {% endcase %}
    </div>
  </div>
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', function () {
  var animationType = {{ section.settings.announcement_animation_type | json }};
  if (animationType !== 'slider') return;

  var el = document.getElementById('mrk-ann-slider--{{ section.id }}');
  if (!el) return;

  new Splide(el, {
    type        : 'fade',
    rewind      : true,
    pagination  : false,
    arrows      : false,
    drag        : false,
    autoplay    : true,
    interval    : {{ section.settings.autoplay_delay }},
    speed       : {{ section.settings.speed }},
    pauseOnHover: false,
  }).mount();
});
</script>

{% schema %}
{
  "name": "Header Announcement Bar",
  "tag": "section",
  "class": "header-announcement header--sticky-ann",
  "settings": [
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "Show on Collections"
    },
    {
      "type": "select",
      "id": "announcement_animation_type",
      "label": "Announcement Animation Type",
      "default": "slider",
      "options": [
        {
          "value": "marquee",
          "label": "Marquee Animation"
        },
        {
          "value": "slider",
          "label": "Slider"
        }
      ]
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fbbf24"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size (rem)",
      "min": 0.5,
      "max": 3,
      "step": 0.1,
      "default": 1.5
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Marquee Speed (seconds)",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 40
    },
    {
      "type": "number",
      "id": "autoplay_delay",
      "label": "Autoplay Delay (ms)",
      "default": 4000
    },
    {
      "type": "number",
      "id": "speed",
      "label": "Transition Speed (ms)",
      "default": 1500
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement Text",
      "settings": [
        {
          "type": "richtext",
          "id": "block_text",
          "label": "Text",
          "default": "<p><strong>SUMMER SALE:&nbsp;</strong>Up to 70%</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header Announcement Bar",
      "category": "Announcement",
      "settings": {
        "announcement_animation_type": "slider"
      },
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "block_text": "<p><strong>SUMMER SALE:&nbsp;</strong>Up to 70%</p>"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "block_text": "<p><strong>FREE </strong>Shipping On<strong> ALL </strong>Orders!</p>"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "block_text": "<p><strong>30-day</strong> money-back guarantee</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}