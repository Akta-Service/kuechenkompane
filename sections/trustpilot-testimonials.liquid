<style>*{margin:0;padding:0;box-sizing:border-box;}a{text-decoration:none;}.trustpilot-area{margin-top:{{section.settings.mt}}px;margin-bottom:{{section.settings.mb}}px;}.trustpilot-area .container{max-width:1650px;margin:0 auto;padding:0 50px;}.testimonial-slider-wrapper{padding:0 30px;overflow:hidden;position:relative;}.trustpilot-heading{margin-bottom:50px;padding-left:30px;}.trustpilot-testimonials-item{border-radius:2px;box-shadow:0 1px 0 0 rgba(182,196,210,.4);line-height:16px;padding:15px;position:relative;height:100%;}.trustpilot-title{font-size:{{section.settings.t_size}}px;text-transform:uppercase;font-family:'Inter',sans-serif;font-weight:700;}.highligt-text{font-style:italic;color:{{section.settings.h_text_color}};}.testimonial-review{display:flex;align-items:center;gap:10px;margin-bottom:10px;}.review-verified{display:flex;align-items:center;gap:5px;}.review-star svg{width:100px;}.review-verified svg{width:14px;height:14px;}.review-verified span{font-size:13px;}.testimonial-title{font-size:14px;font-weight:700;height:16px;margin:0 0 10px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}.testimonial-content p{font-size:13px;line-height:16px;max-height:50px;overflow:hidden;word-wrap:break-word;}.testimonial-user-info{margin-top:30px;}.testimonial-user{font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px;}.testimonial-date{font-size:12px;}.trustpilot-{{section.id}} .splide__arrow{width:24px;height:24px;border-radius:100%;line-height:24px;background:transparent;border:none;padding:0;position:absolute;top:50%;transform:translateY(-50%);z-index:2;cursor:pointer;}.trustpilot-{{section.id}} .splide__arrow--prev{left:-30px!important;}.trustpilot-{{section.id}} .splide__arrow--next{right:-30px!important;}.trustpilot-{{section.id}} .splide__arrow--next svg{transform:rotate(180deg)!important;}.trustpilot-{{section.id}} .splide__arrow svg path{fill:{{section.settings.arrow_icon_color}};}.trustpilot-{{section.id}} .splide__arrow--prev svg{transform:scaleX(1)!important;}.trustpilot-{{section.id}} .splide__arrow:disabled{opacity:0.3!important;pointer-events:none;}.trustpilot-{{section.id}} .splide__arrow svg{fill:transparent;height:auto;width:auto;}@media only screen and (max-width:768px){.trustpilot-area .container{padding:0 20px;}.trustpilot-area{margin-top:{{section.settings.mt_mobile}}px;margin-bottom:{{section.settings.mb_mobile}}px;}.trustpilot-heading{margin-bottom:30px;padding-left:0;}}@media only screen and (max-width:520px){.trustpilot-title{font-size:24px;}}</style>
<div class="trustpilot-area trustpilot-{{ section.id }}  m-color-{{ section.settings.color_scheme }}"><div class="container">{% if section.settings.title != blank %}<div class="trustpilot-heading"><h3 class="trustpilot-title {{ section.settings.heading_type }}">{{ section.settings.title }}<span class="highligt-text">{{ section.settings.title_highlight }}</span></h3></div>{% endif %}<div class="testimonial-slider-wrapper"><div id="splide-{{ section.id }}" class="splide trustpilot-testimonials"><div class="splide__track"><ul class="splide__list">{% for block in section.blocks %}<li class="splide__slide"><div class="trustpilot-testimonials-item m-color-{{ section.settings.content_color_scheme }}{% if section.settings.content_color_scheme != section.settings.color_scheme %} m-custom-content__boxed{% endif %}"><div class="testimonial-review"><div class="review-star"><svg role="img" viewBox="0 0 251 46" xmlns="http://www.w3.org/2000/svg"><title>5 out of 5 star rating on Trustpilot</title><g class="tp-star"><path class="tp-star__canvas" fill="#00b67a" d="M0 46.330002h46.375586V0H0z"></path><path class="tp-star__shape" d="M39.533936 19.711433L13.230239 38.80065l3.838216-11.797827L7.02115 19.711433h12.418975l3.837417-11.798624 3.837418 11.798624h12.418975zM23.2785 31.510075l7.183595-1.509576 2.862114 8.800152L23.2785 31.510075z" fill="#FFF"></path></g><g class="tp-star"><path class="tp-star__canvas" fill="#00b67a" d="M51.24816 46.330002h46.375587V0H51.248161z"></path><path class="tp-star__canvas--half" fill="#00b67a" d="M51.24816 46.330002h23.187793V0H51.248161z"></path><path class="tp-star__shape" d="M74.990978 31.32991L81.150908 30 84 39l-9.660206-7.202786L64.30279 39l3.895636-11.840666L58 19.841466h12.605577L74.499595 8l3.895637 11.841466H91L74.990978 31.329909z" fill="#FFF"></path></g><g class="tp-star"><path class="tp-star__canvas" fill="#00b67a" d="M102.532209 46.330002h46.375586V0h-46.375586z"></path><path class="tp-star__canvas--half" fill="#00b67a" d="M102.532209 46