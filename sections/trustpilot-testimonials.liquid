      : 1,gap              : '20px',speed            : 500,pagination       : false,easing           : 'cubic-bezier(0.25, 1, 0.5, 1)',waitForTransition: false,updateOnMove     : true,touchAngle       : 30,touchPower       : 600,breakpoints: {1024: {perPage      : 4,drag         : 'free',snap         : true,flickPower   : 400,flickMaxPages: 1,},768: {perPage      : 2,drag         : 'free',snap         : true,flickPower   : 400,flickMaxPages: 1,},520: {perPage      : 1,drag         : 'free',snap         : true,flickPower   : 400,flickMaxPages: 1,}}}).mount();}if (document.readyState === 'loading') {document.addEventListener('DOMContentLoaded', initSplide);} else {initSplide();}document.addEventListener('shopify:section:load', function(e) {if (e.target.querySelector('#splide-{{ section.id }}')) {setTimeout(initSplide, 300);}});})();</script>
