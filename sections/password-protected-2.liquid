{% style %}
  .evs-section *,
  .evs-section *::before,
  .evs-section *::after {
  	box-sizing: border-box;
  	margin: 0;
  	padding: 0;
  }

  /* ── Full-screen overlay ── */
  .evs-section {
  	position: fixed;
  	inset: 0;
  	z-index: 999999;
    background-color: {{ section.settings.bg_fallback }};
  	background-size: cover;
  	background-position: center;
  	background-repeat: no-repeat;
  	color: #fff;
  	text-align: center;
  	overflow-x: hidden;
  	overflow-y: auto;
  	min-height: 100dvh;
  	display: flex;
  	justify-content: center;
  	padding: 36px 20px 32px;
  	font-family: 'Helvetica Neue',
  	Arial,
  	sans-serif;
  }

  .evs-wrapper {
  	width: 100%;
  	max-width: 700px;
  	display: flex;
  	flex-direction: column;
  	align-items: center;
  	gap: 0;
  }

  .evs-logo {
  	margin-bottom: 20px;
  }

  .evs-logo img {
  	display: block;
  	margin: 0 auto;
  }

  .evs-title-main {
  	font-size: 60px;
  	font-weight: 900;
  	text-transform: uppercase;
  	letter-spacing: -0.5px;
  	line-height: 1;
  	margin-bottom: 12px;
  	text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
  }

  .evs-discount-wrap {
  	display: inline-flex;
  	align-items: center;
  	gap: 12px;
  	padding: 10px 26px 10px 10px;
  	margin-bottom: 12px;
  }

  .evs-discount-percent {
  	font-size: 82px;
  	font-weight: 300;
  	line-height: 1.05;
  	padding: 2px 18px;
  	border-radius: 4px;
  	letter-spacing: -1px;
  	font-family: var(--font-stack-header);
  }

  .evs-discount-label {
  	font-size: 54px;
  	font-style: italic;
  	font-weight: 300;
  	line-height: 1;
  	font-family: var(--font-stack-header);
  }

  .evs-promo-text {
  	font-size: 28px;
  	font-weight: 900;
  	line-height: 1.25;
  	margin-bottom: 16px;
  	max-width: 450px;
  }

  .evs-timer {
  	display: flex;
  	gap: 20px;
  	justify-content: center;
  	margin-bottom: 32px;
  }

  .evs-timer-number {
  	font-size: 32px;
  	font-weight: 700;
  	min-width: 52px;
  }

  .evs-timer-label {
  	font-size: 10px;
  	font-weight: 700;
  	text-transform: uppercase;
  	opacity: 0.85;
  }

  .evs-form-card {
  	width: 100%;
  	max-width: 560px;
  	border: 2px solid rgba(255, 255, 255, 0.4);
  	box-shadow: 0 20px 40px rgb(0 0 0 / 15%);
  	border-radius: 10px;
  	padding: 26px 32px;
  	margin-bottom: 20px;
  }

  .evs-input {
  	width: 100%;
  	height: 50px;
  	border: 1.5px solid rgba(255, 255, 255, 0.85);
  	border-radius: 7px;
  	font-size: 15px;
  	padding: 0 16px;
  	outline: none;
  	margin-bottom: 16px;
  }

  .evs-input::placeholder {
  	color: rgba(255, 255, 255, 0.7);
  }

  .evs-btn {
  	width: 100%;
  	height: 50px;
  	border: none;
  	border-radius: 7px;
  	font-size: 18px;
  	font-weight: 700;
  	text-transform: uppercase;
  	cursor: pointer;
  	color: #ffffff !important;
  }

  .evs-sub-title {
  	font-size: 36px;
  	font-weight: 700;
  	text-transform: uppercase;
  	margin-bottom: 18px;
  }

  .evs-badges-wrap {
  	width: 100%;
  	max-width: 650px;
  	padding: 13px 10px 4px;
  }

  .evs-badges-row {
  	display: flex;
  	flex-wrap: wrap;
  	justify-content: center;
  	gap: 10px;
  }

  .evs-badge {
  	border-radius: 4px;
  	padding: 6px 15px;
  	display: inline-flex;
  	align-items: center;
  	gap: 10px;
  	font-size: 14px;
  	font-weight: 700;
  }

  .evs-badge-icon svg {
  	width: 40px;
  	height: 40px;
  }

  .evs-badges-footer {
  	font-size: 11px;
  	margin-top: 8px;
  	text-align: center;
  	opacity: 0.9;
  	font-weight: 500;
  }

  .evs-footer-menu ul {
  	list-style: none;
  	display: flex;
  	flex-wrap: wrap;
  	justify-content: center;
  	gap: 6px 18px;
  	padding: 15px 0 30px;
  }

  .evs-footer-menu a {
  	text-decoration: none;
  	font-size: 12px;
  	font-weight: 600;
  }

  .evs-input::placeholder {
      color: var(--placeholder_color);
  }

  /* ── Responsive ── */
  @media (max-width: 580px) {
  	.evs-title-main {
  		font-size: 38px;
  	}

  	.evs-discount-percent {
  		font-size: 36px;
  	}

  	.evs-discount-label {
  		font-size: 18px;
  	}

  	.evs-badge {
  		width: 100% !important;
  		justify-content: flex-start;
  	}

  	.evs-btn {
  		font-size: 16px;
  	}

  	.evs-sub-title {
  		font-size: 18px;
  	}

  	.evs-timer-number {
  		font-size: 26px;
  		min-width: 30px;
  	}

  	.evs-promo-text {
  		font-size: 24px;
  	}
  }
{% endstyle %}

{%- comment -%} ── Visibility Logic ── {%- endcomment -%}
{% assign show_popup = false %}

{% if section.settings.evs_show %}
  {% if settings.allowed_handles == blank %}
    {% assign show_popup = true %}
  {% else %}
    {% for protected_collection in settings.allowed_handles %}
      {% if protected_collection.handle == collection.handle %}
        {% assign show_popup = true %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endif %}

{% if show_popup %}
  {% assign overlay_percent = section.settings.bg_overlay_opacity | default: 0 | divided_by: 100.0 %}

  {%- comment -%} ── SVG Icon Captures ── {%- endcomment -%}

  {% capture icon_diamond %}
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 22L2 9L6 2H18L22 9L12 22Z" fill="currentColor"/>
      <path d="M6 2L12 9M18 2L12 9M2 9H22M6 2H18M12 22L6 9M12 22L18 9"
            stroke="white" stroke-width="1.2"
            stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M12 9L16 2H8L12 9Z" fill="white" fill-opacity="0.2"/>
    </svg>
  {% endcapture %}

  {% capture icon_fire %}
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 22C16.4 22 20 18.4 20 14C20 11.5 18.5 8.5 16.5 6.5
               C16.5 8.5 15.5 10 14.5 10.5C14.5 6.5 13 3 11 2
               C11 5.5 9.5 8.5 8 10C8 7.5 7 6 6 6
               C4.5 8.5 4 11.5 4 14C4 18.4 7.5 22 12 22Z"
            fill="currentColor"/>
      <circle cx="12" cy="15.5" r="4.5" fill="white"/>
      <text x="12" y="17.5" text-anchor="middle"
            font-size="6" font-weight="900" fill="currentColor">%</text>
    </svg>
  {% endcapture %}

  {% capture icon_star %}
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 2L14.1 4.8L17.5 4.5L18.4 7.8L21.5 9.2L20.3 12.4
               L21.7 15.5L19 17.7L18.8 21.1L15.4 21.5L13.5 24.3
               L10.5 23.8L7.5 24.3L5.6 21.5L2.2 21.1L2 17.7
               L-0.7 15.5L0.7 12.4L-0.5 9.2L2.6 7.8L3.5 4.5
               L6.9 4.8L9 2H12Z"
            fill="currentColor"/>
      <circle cx="10.5" cy="13.2" r="5.5" fill="white"/>
      <path d="M10.5 10.2L11.6 12.4H14.1L12.1 13.9L12.8 16.3
               L10.5 14.8L8.2 16.3L8.9 13.9L6.9 12.4H9.4L10.5 10.2Z"
            fill="currentColor"/>
    </svg>
  {% endcapture %}

  {%- comment -%} ── Section HTML ── {%- endcomment -%}

  <section
    class="evs-section"
    id="password-popup"
    style="
      background-image:
      linear-gradient(
        rgba(0, 0, 0, {{ overlay_percent }}),
        rgba(0, 0, 0, {{ overlay_percent }})
      ),
      url('{{ section.settings.bg_img | image_url }}');
    "
  >
    <div class="evs-wrapper">
      {% for block in section.blocks %}
        {% case block.type %}
            {%- comment -%} Logo ── {%- endcomment -%}
          {% when 'logo' %}
            <div class="evs-logo" {{ block.shopify_attributes }}>
              {% if block.settings.logo_image != blank %}
                <img
                  src="{{ block.settings.logo_image | image_url }}"
                  style="max-width: {{ block.settings.logo_width }}px; width: 100%;"
                >
              {% endif %}
            </div>

            {%- comment -%} Main Title ── {%- endcomment -%}
          {% when 'title_main' %}
            <h1
              class="evs-title-main"
              style="color: {{ block.settings.text_color }};"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </h1>

            {%- comment -%} Discount Box ── {%- endcomment -%}
          {% when 'discount_highlight' %}
            <div
              class="evs-discount-wrap"
              style="background-color: {{ block.settings.bg_color }};"
              {{ block.shopify_attributes }}
            >
              <span
                class="evs-discount-percent"
                style="
                  background: {{ block.settings.percent_bg }};
                  color: {{ block.settings.percent_text }};
                "
              >
                {{ block.settings.percent }}
              </span>
              <span
                class="evs-discount-label"
                style="color: {{ block.settings.label_color }};"
              >
                {{ block.settings.subtext }}
              </span>
            </div>

            {%- comment -%} Promo / Neon Text ── {%- endcomment -%}
          {% when 'promo_text' %}
            <p
              class="evs-promo-text"
              style="
                color: {{ block.settings.text_color }};
                text-shadow: 0 0 20px {{ block.settings.glow_color }};
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </p>

            {%- comment -%} Countdown Timer ── {%- endcomment -%}
          {% when 'timer' %}
            <div
              class="evs-timer"
              data-end="{{ block.settings.target_date }}"
              {{ block.shopify_attributes }}
            >
              {% assign units = 'days,hours,minutes,seconds' | split: ',' %}
              {% assign labels = block.settings.label_days
                | append: ','
                | append: block.settings.label_hours
                | append: ','
                | append: block.settings.label_min
                | append: ','
                | append: block.settings.label_sec
                | split: ','
              %}

              {% for unit in units %}
                <div class="evs-timer-cell">
                  <div
                    class="evs-timer-number"
                    style="color: {{ block.settings.num_color }};"
                    data-unit="{{ unit }}"
                  >
                    00
                  </div>
                  <div
                    class="evs-timer-label"
                    style="color: {{ block.settings.label_color }};"
                  >
                    {{ labels[forloop.index0] }}
                  </div>
                </div>
              {% endfor %}
            </div>

            {%- comment -%} Password Form ── {%- endcomment -%}
          {% when 'password_form' %}
            <div
              class="evs-form-card"
              style="
                background: {{ block.settings.card_bg }};
                backdrop-filter: blur(25px);
                --placeholder_color:{{ block.settings.placeholder_color }};
              "
              {{ block.shopify_attributes }}
            >
              {% comment %}
                <input
                type="password"
                id="evs-password-{{ block.id }}"
                class="evs-input"
                placeholder="{{ block.settings.placeholder }}"
                style="background: {{ block.settings.input_bg }};
                       color: {{ block.settings.input_text_color }};">
              {% endcomment %}

              <input
                type="password"
                id="evs-password-{{ block.id }}"
                class="evs-input"
                placeholder="{{ block.settings.placeholder }}"
                style="background: {{ block.settings.input_bg }}; color: {{ block.settings.input_text_color }};"
                onkeyup="if(event.keyCode === 13) evsCheckPassword('{{ block.id }}', '{{ settings.password | escape }}', '{{ block.settings.redirect_url | escape }}')"
              >

              <button
                class="evs-btn"
                onclick="
                  evsCheckPassword(
                    '{{ block.id }}',
                    '{{ settings.password | escape }}',
                    '{{ block.settings.redirect_url | escape }}'
                  )
                "
                style="
                  background: {{ block.settings.btn_bg }};
                  color: {{ block.settings.btn_text_color }};
                "
              >
                {{ block.settings.button_text }}
              </button>

              <div
                id="evs-error-{{ block.id }}"
                style="
                  color: {{ block.settings.error_color }};
                  display: none;
                  margin-top: 10px;
                  font-size: 13px;
                "
              >
                {{ block.settings.error_msg }}
              </div>
            </div>

            {%- comment -%} Sub-Headline ── {%- endcomment -%}
          {% when 'title_sub' %}
            <h2
              class="evs-sub-title"
              style="color: {{ block.settings.text_color }};"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </h2>

            {%- comment -%} Badges Group ── {%- endcomment -%}
          {% when 'badges_group' %}
            <div
              class="evs-badges-wrap"
              style="background-color: {{ block.settings.wrap_bg_color }};"
              {{ block.shopify_attributes }}
            >
              <div class="evs-badges-row">
                {% for i in (1..3) %}
                  {% capture txt_key %}badge_{{ i }}_text{% endcapture %}
                  {% capture img_key %}badge_{{ i }}_img{% endcapture %}
                  {% capture ico_key %}badge_{{ i }}_icon{% endcapture %}

                  {% if block.settings[txt_key] != blank %}
                    <div
                      class="evs-badge"
                      style="
                        background: {{ block.settings.badge_bg_color }};
                        color: {{ block.settings.badge_text_color }};
                      "
                    >
                      <span
                        class="evs-badge-icon"
                        style="color: {{ block.settings.icon_color }};"
                      >
                        {% if block.settings[img_key] != blank %}
                          <img
                            src="{{ block.settings[img_key] | image_url: width: 40 }}"
                            style="width: 25px;"
                          >
                        {% else %}
                          {% case block.settings[ico_key] %}
                            {% when 'fire' %}
                              {{ icon_fire }}
                            {% when 'star' %}
                              {{ icon_star }}
                            {% when 'diamond' %}
                              {{ icon_diamond }}
                            {% else %}
                              {{ block.settings[ico_key] }}
                          {% endcase %}
                        {% endif %}
                      </span>

                      <span
                        class="evs-badge-text"
                        style="
                          text-align: {{ block.settings.badge_text_align }};
                          flex-grow: 1;
                        "
                      >
                        {{ block.settings[txt_key] }}
                      </span>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>

              <div
                class="evs-badges-footer"
                style="color: {{ block.settings.footer_text_color }};"
              >
                {{ block.settings.footer_text }}
              </div>
            </div>

            {%- comment -%} Fine Print / Info Text ── {%- endcomment -%}
          {% when 'info_text' %}
            <div
              class="evs-info-text"
              style="color: {{ block.settings.text_color }};"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </div>

            {%- comment -%} Footer Menu ── {%- endcomment -%}
          {% when 'menu' %}
            {% assign nav = linklists[block.settings.menu] %}
            {% if nav.links.size > 0 %}
              <nav class="evs-footer-menu" {{ block.shopify_attributes }}>
                <ul>
                  {% for link in nav.links %}
                    <li>
                      <a
                        href="{{ link.url }}"
                        style="color: {{ block.settings.link_color }};"
                      >
                        {{ link.title }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              </nav>
            {% endif %}
        {% endcase %}
      {% endfor %}
    </div>
  </section>
{% endif %}

<script>
  (function () {
    var popupId = 'password-popup';
    if (sessionStorage.getItem('vip_access_granted') === 'true') {
      var popup = document.getElementById(popupId);
      if (popup) popup.style.display = 'none';
    } else {
      if (document.getElementById(popupId)) {
        document.body.style.overflow = 'hidden';
      }
    }

    document.querySelectorAll('.evs-timer').forEach(function (timer) {
      var endDate = new Date(timer.dataset.end).getTime();
      function tick() {
        var diff = endDate - Date.now();
        if (diff <= 0) return;
        timer.querySelector('[data-unit="days"]').textContent = String(Math.floor(diff / 86400000)).padStart(2, '0');
        timer.querySelector('[data-unit="hours"]').textContent = String(
          Math.floor((diff % 86400000) / 3600000)
        ).padStart(2, '0');
        timer.querySelector('[data-unit="minutes"]').textContent = String(
          Math.floor((diff % 3600000) / 60000)
        ).padStart(2, '0');
        timer.querySelector('[data-unit="seconds"]').textContent = String(Math.floor((diff % 60000) / 1000)).padStart(
          2,
          '0'
        );
      }
      setInterval(tick, 1000);
      tick();
    });

    window.evsCheckPassword = function (id, pass, url) {
      var inputElement = document.getElementById('evs-password-' + id);
      var userTyped = inputElement.value.trim();
      var originalPass = pass.trim();

      if (userTyped.toLowerCase() === originalPass.toLowerCase()) {
        sessionStorage.setItem('vip_access_granted', 'true');
        document.body.style.overflow = '';
        document.dispatchEvent(new Event('passwordCorrect'));
        if (url) {
          window.location.href = url;
        } else {
          document.getElementById(popupId).style.display = 'none';
        }
      } else {
        document.getElementById('evs-error-' + id).style.display = 'block';
      }
    };
  })();
</script>

{% schema %}
{
  "name": "password banner",

  "settings": [
    {
      "type": "header",
      "content": "Section Activation Settings"
    },
    {
      "type": "checkbox",
      "id": "evs_show",
      "label": "Activate Section",
      "default": true
    },
    {
      "type": "paragraph",
      "content": "Protected Collections and Password are managed in Global Theme Settings."
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "bg_overlay_opacity",
      "label": "Background Overlay Opacity",
      "min": 0,
      "max": 100,
      "default": 0
    },
    {
      "type": "color",
      "id": "bg_fallback",
      "label": "Background Fallback Color",
      "default": "#A7C4B5"
    }
  ],

  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo Image"
        },
        {
          "type": "range",
          "id": "logo_width",
          "label": "Logo Width (px)",
          "min": 50,
          "max": 350,
          "step": 5,
          "default": 160
        }
      ]
    },

    {
      "type": "title_main",
      "name": "Main Title",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Title Text",
          "default": "OSTER VIP SALE!"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Title Color",
          "default": "#ffffff"
        }
      ]
    },

    {
      "type": "discount_highlight",
      "name": "Discount Box",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "percent", "label": "Percent", "default": "18%" },
        { "type": "text", "id": "subtext", "label": "Subtext", "default": "auf alles" },
        { "type": "color", "id": "bg_color", "label": "Box BG Color", "default": "#E39191" },
        { "type": "color", "id": "percent_bg", "label": "Percent Box Color", "default": "#ffffff" },
        { "type": "color", "id": "percent_text", "label": "Percent Text Color", "default": "#E39191" },
        { "type": "color", "id": "label_color", "label": "Subtext Color", "default": "#ffffff" }
      ]
    },

    {
      "type": "promo_text",
      "name": "Promo / Neon Text",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Promo Text", "default": "Gratis 4-Teiliges Damast Messerset" },
        { "type": "color", "id": "text_color", "label": "Text Color", "default": "#FA8526" },
        { "type": "color", "id": "glow_color", "label": "Neon Glow Color", "default": "#FA8526" }
      ]
    },

    {
      "type": "timer",
      "name": "Countdown Timer",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "target_date", "label": "End Date (ISO 8601)", "default": "2025-04-20T20:00:00" },
        { "type": "color", "id": "num_color", "label": "Number Color", "default": "#ffffff" },
        { "type": "color", "id": "label_color", "label": "Label Color", "default": "#ffffff" },
        { "type": "text", "id": "label_days", "label": "Days Label", "default": "TAGE" },
        { "type": "text", "id": "label_hours", "label": "Hours Label", "default": "STUNDEN" },
        { "type": "text", "id": "label_min", "label": "Min Label", "default": "MIN" },
        { "type": "text", "id": "label_sec", "label": "Sec Label", "default": "SEK" }
      ]
    },

    {
      "type": "password_form",
      "name": "Password Form",
      "limit": 1,
      "settings": [
        { "type": "url", "id": "redirect_url", "label": "Redirect URL" },
        { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "Passwort eingeben" },
        { "type": "text", "id": "button_text", "label": "Button Label", "default": "JETZT ZUM SALE" },
        { "type": "color", "id": "card_bg", "label": "Card BG Color", "default": "rgba(255,255,255,0.15)" },
        { "type": "color", "id": "input_bg", "label": "Input BG Color", "default": "rgba(255,255,255,0.12)" },
        { "type": "color", "id": "input_text_color", "label": "Input Text Color", "default": "#ffffff" },
