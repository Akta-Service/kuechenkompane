      "default": "1200px",
      "info": "Gleicher Wert wie 'Container width' bzw. 'Container max-width' im Theme (z.B. 1200px oder 1420px)"
    },
    {
      "type": "range",
      "id": "container_side_padding",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding links & rechts",
      "default": 20,
      "info": "Bei Fluid container: gleicher Wert wie 'Margin left & right' im Theme (z.B. 65px)"
