<style>#shop-by-category-{{section.id}}{box-sizing:border-box;width:100%;padding:28px 0;position:relative;overflow:hidden;}#shop-by-category-{{section.id}} .sbc-heading{font-size:20px;font-weight:600;margin:0 0 20px;}#shop-by-category-{{section.id}} .custom-container{overflow:visible!important;}#shop-by-category-{{section.id}} .splide{overflow:visible!important;}#shop-by-category-{{section.id}} .splide__track{overflow:visible!important;}#shop-by-category-{{section.id}} .splide__list{display:flex;padding:0;margin:0;list-style:none;align-items:stretch;}#shop-by-category-{{section.id}} .splide__slide{display:flex;flex-direction:column;width:230px!important;}#shop-by-category-{{section.id}} .sbc-card{display:flex;flex-direction:column;gap:14px;text-decoration:none;color:inherit;outline:none;height:100%;}#shop-by-category-{{section.id}} .sbc-media{width:100%;aspect-ratio:3 / 4;overflow:hidden;background:#fff;display:block;flex-shrink:0;}#shop-by-category-{{section.id}} .sbc-media img{width:100%;height:100%;object-fit:contain;display:block;transition:transform .6s cubic-bezier(.2,.9,.2,1);}#shop-by-category-{{section.id}} .sbc-title{letter-spacing:normal;font-weight:500;font-size:18px;transition:color .3s ease;display:block;}#shop-by-category-{{section.id}} .sbc-card:hover .sbc-title{color:#fe5b00;}@media (max-width:1023px){#shop-by-category-{{section.id}} .splide__slide{width:190px!important;}}@media (max-width:767px){#shop-by-category-{{section.id}} .sbc-heading{font-size:22px;margin:0 0 28px;text-align:center;}#shop-by-category-{{section.id}} .splide__slide{width:160px!important;}#shop-by-category-{{section.id}} .sbc-title{font-size:15px;}}@media (max-width:499px){#shop-by-category-{{section.id}} .splide__slide{width:140px!important;}#shop-by-category-{{section.id}} .sbc-title{font-size:14px;}}</style>
<section id="shop-by-category-{{ section.id }}" class="shop-by-category" role="region" aria-label="{{ section.settings.heading | default: 'Shop by category' }}"><div class="custom-container">{% if section.settings.heading != blank %}<h2 class="sbc-heading">{{ section.settings.heading }}</h2>{% endif %}<div class="splide" id="sbc-splide-{{ section.id }}"><div class="splide__track"><ul class="splide__list">{% for block in section.blocks %}{% assign coll_handle = block.settings.collection %}{% assign card_title = block.settings.title | default: '' %}{% assign card_link = block.settings.link | default: '' %}{% assign card_image = block.settings.image %}{% assign card_alt = block.settings.alt | default: card_title %}{% if coll_handle and collections[coll_handle] %}{% assign the_collection = collections[coll_handle] %}{% if the_collection.title != blank %}{% assign card_title = the_collection.title %}{% endif %}{% if the_collection.url != blank %}{% assign card_link = the_collection.url %}{% endif %}{% if the_collection.featured_image != blank %}{% assign card_image = the_collection.featured_image %}{% elsif the_collection.products_count > 0 %}{% assign first_product = the_collection.products.first %}{% if first_product and first_product.featured_image %}{% assign card_image = first_product.featured_image %}{% endif %}{% endif %}{% if card_alt == blank %}{% assign card_alt = the_collection.title %}{% endif %}{% endif %}<li class="splide__slide" {{ block.shopify_attributes }}><a class="sbc-card" href="{{ card_link | default: '#' }}"{% if block.settings.open_in_new_tab %} target="_blank" rel="noopener noreferrer"{% endif %} aria-label="{{ card_title | escape }}"><div class="sbc-media">{% if card_image %}<img src="{{ card_image | image_url: width: 200 }}" srcset="{{ card_image | image_url: width: 300 }} 300w,{{ card_image | image_url: width: 500 }} 500w,{{ card_image | image_url: width: 700 }} 700w" sizes="(max-width: 499px) 140px, (max-width: 767px) 160px, (max-width: 1023px) 190px, 230px" alt="{{ card_alt | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}" decoding="{% if forloop.first %}sync{% else %}async{% endif %}" width="{{ card_image.width }}" height="{{ card_image.height }}">{% else %}<div class="sbc-placeholder"></div>{% endif %}</div><div class="sbc-meta"><span class="sbc-title">{{ card_title | escape }}</span></div></a></li>{% endfor %}</ul></div></div></div></section><script>(function () {var SECTION_ID = '{{ section.id }}';var SPLIDE_ID  = 'sbc-splide-' + SECTION_ID;function mountSplide() {var el = document.getElementById(SPLIDE_ID);if (!el || el.classList.contains('is-initialized')) return;new Splide('#' + SPLIDE_ID, {autoWidth        : true,gap              : 12,speed            : 400,loop             : true,arrows           : false,pagination       : false,drag             : 'free',snap             : true,flickPower       : 400,flickMaxPages    : 1,waitForTransition: false,updateOnMove     : true,touchAngle       : 30,touchPower       : 600,easingFunc       : (t) => 1 - Math.pow(1 - t, 4),}).mount();}if (document.readyState === 'loading') {document.addEventListener('DOMContentLoaded', mountSplide);} else {mountSplide();}document.addEventListener('shopify:section:load', function (e) {if (e.target.querySelector('#' + SPLIDE_ID)) {setTimeout(mountSplide, 300);}});})();</script>
{% schema %}{"name":"Shop by Category","settings":[{"type":"text","id":"heading","label":"Heading","default":"Shop by category"}],"blocks":[{"type":"category","name":"Category","settings":[{"type":"collection","id":"collection","label":"Select collection (optional)"},{"type":"image_picker","id":"image","label":"Fallback / override image"},{"type":"text","id":"alt","label":"Image alt text (fallback)"},{"type":"text","id":"title","label":"Fallback / override title"},{"type":"url","id":"link","label":"Fallback / override link"},{"type":"checkbox","id":"open_in_new_tab","label":"Open link in new tab","default":false}]}],"max_blocks":12,"presets":[{"name":"Shop by Category","category":"Collections","blocks":[{"type":"category"},{"type":"category"},{"type":"category"},{"type":"category"},{"type":"category"},{"type":"category"}]}]}{% endschema %}