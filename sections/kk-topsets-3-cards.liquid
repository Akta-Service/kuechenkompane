{% comment %}
  BF TOP SETS SECTION
{% endcomment %}

<style>
  .bf-topsets {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .bf-topsets .bf-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .bf-topsets .bf-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .bf-topsets .bf-eyebrow {
    margin: 0 0 8px;
    font-size: {{ section.settings.eyebrow_size }}px;
    color: {{ section.settings.eyebrow_color }};
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .03em;
  }

  .bf-topsets .bf-title {
    margin: 0;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size }}px;
    line-height: 1.1;
    font-weight: 700;
    padding-bottom: 18px;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }
  .bf-topsets .bf-title::before {
    content: "";
    width: 240px;
    height: 11px;
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    background-image: url({{ section.settings.shape_image | image_url }});
    background-repeat: no-repeat;
    background-size: contain;
    background-position: center;
    flex-shrink: 0;
    display: block;
  }

  .bf-topsets .bf-title span {
    color: {{ section.settings.highlight_color }};
  }

  .bf-topsets .bf-splide {
    overflow: visible;
  }

  .bf-topsets .bf-splide .splide__track {
    overflow: hidden;
  }

  .bf-topsets .bf-grid {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .bf-topsets .bf-card {
    position: relative;
    background: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_radius }}px;
    overflow: visible;
    height: auto;
  }

  .bf-topsets .bf-discount {
    position: absolute;
    top: 16px;
    left: 16px;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_text }};
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 5;
    font-size: 16px;
    font-weight: 700;
  }

  .bf-topsets .bf-image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1.45 / 1;
  }

  .bf-topsets .bf-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 12px 12px 0 0;
  }

  .bf-topsets .bf-label {
    position: absolute;
    left: 0;
    bottom: 0;
    background: {{ section.settings.label_bg }};
    color: {{ section.settings.label_color }};
    padding: 8px 14px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
  }

  .bf-topsets .bf-content {
    padding: 18px 18px 20px;
  }

  .bf-topsets .bf-card-title {
    margin: 0 0 10px;
    color: {{ section.settings.card_title_color }};
    font-size: {{ section.settings.card_title_size }}px;
    line-height: 1.3;
    font-weight: 700;
  }

  .bf-topsets .bf-desc {
    margin: 0 0 22px;
    color: {{ section.settings.desc_color }};
    font-size: {{ section.settings.desc_size }}px;
    line-height: 1.5;
  }

  .bf-topsets .bf-price-wrap {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 10px;
    margin-bottom: 18px;
  }

  .bf-topsets .bf-price-left {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }

  .bf-topsets .bf-price {
    color: {{ section.settings.price_color }};
    font-size: {{ section.settings.price_size }}px;
    font-weight: 800;
    line-height: 1;
  }

  .bf-topsets .bf-compare {
    color: {{ section.settings.compare_color }};
    text-decoration: line-through;
    font-size: 18px;
    font-weight: 600;
  }

  .bf-topsets .bf-save {
    text-align: right;
    color: {{ section.settings.save_color }};
    font-size: 10px;
    line-height: 1.2;
    text-transform: uppercase;
    font-weight: 700;
  }

  .bf-topsets .bf-save strong {
    display: block;
    font-size: 15px;
  }

  .bf-topsets .bf-btn {
    width: 100%;
    justify-content: center;
    text-transform: uppercase;
    text-decoration: none;
  }

  .bf-topsets .bf-bottom-link {
    text-align: center;
    margin-top: 26px;
  }

  .bf-topsets .bf-bottom-link a {
    color: {{ section.settings.bottom_link_color }};
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .bf-topsets .splide__pagination {
    position: static;
    padding: 0;
    margin-top: 20px;
  }

  .bf-topsets .splide__pagination__page {
    background: #ccc;
  }

  .bf-topsets .splide__pagination__page.is-active {
    background: {{ section.settings.highlight_color }};
    transform: scale(1.2);
  }

  .bf-title-mobile {
    display: none;
  }

  @media screen and (max-width: 991px) {
    .bf-topsets .bf-eyebrow {
      font-size: {{ section.settings.eyebrow_size_mobile }}px;
    }

    .bf-topsets .bf-title {
      font-size: {{ section.settings.title_size_mobile }}px;
    }

    .bf-topsets .bf-card-title {
      font-size: {{ section.settings.card_title_size_mobile }}px;
      line-height: 1.3;
    }

    .bf-topsets .bf-desc {
      font-size: {{ section.settings.desc_size_mobile }}px;
    }

    .bf-topsets .bf-price {
      font-size: {{ section.settings.price_size_mobile }}px;
    }

    .bf-topsets .splide__slide {
      height: auto;
    }

    .bf-topsets .bf-card {
      margin-right: 0;
    }

    .bf-title-desktop {
      display: none;
    }

    .bf-title-mobile {
      display: block;
    }

    /* =====================================================
       MOBILE GRID LAYOUT — active when slider is disabled
       ===================================================== */
    {% if section.settings.mobile_layout != 'slider' %}
      .bf-topsets .bf-splide .splide__track {
        overflow: visible !important;
      }

      .bf-topsets .bf-grid {
        display: grid !important;
        grid-template-columns: repeat({{ section.settings.mobile_layout }}, 1fr);
        gap: 12px;
      }

      /* Reset any Splide inline-style overrides on slides */
      .bf-topsets .bf-grid .splide__slide {
        width: 100% !important;
        transform: none !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
      }

      /* Hide pagination dots — not needed for grid */
      .bf-topsets .splide__pagination {
        display: none;
      }
    {% endif %}
  }
</style>

<section class="bf-topsets">
  <div class="bf-container">

    <div class="bf-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="bf-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="bf-title">
        {{ section.settings.heading_before }}
        <span>{{ section.settings.heading_highlight }}</span>
        {{ section.settings.heading_after }}
      </h2>
    </div>

    <div id="bf-topsets-splide-{{ section.id }}" class="splide bf-splide">
      <div class="splide__track">
        <ul class="bf-grid splide__list">
          {%- for block in section.blocks -%}
            {%- assign product = block.settings.product -%}
            <li class="bf-card splide__slide" {{ block.shopify_attributes }}>

              {%- if block.settings.discount_text != blank -%}
                <div class="bf-discount">{{ block.settings.discount_text }}</div>
              {%- endif -%}

              <a href="{{ product.url | default: block.settings.button_link }}">
                <div class="bf-image">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 900 }}"
                      srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 900 }} 900w"
                      sizes="(max-width: 991px) 100vw, 33vw"
                      alt="{{ block.settings.title | escape }}"
                      loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                      fetchpriority="auto"
                      decoding="async"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                    >
                  {%- elsif product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 900 }}"
                      srcset="{{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w"
                      sizes="(max-width: 991px) 100vw, 33vw"
                      alt="{{ product.title | escape }}"
                      loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                      fetchpriority="auto"
                      decoding="async"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                    >
                  {%- endif -%}

                  {%- if block.settings.label != blank -%}
                    <div class="bf-label">{{ block.settings.label }}</div>
                  {%- endif -%}
                </div>
              </a>

              <div class="bf-content">
                <h3 class="bf-card-title">
                  {%- assign card_title = block.settings.title | default: product.title -%}

                  <span class="bf-title-desktop">
                    {{ card_title }}
                  </span>

                  <span class="bf-title-mobile">
                    {{ card_title | truncate: 28 }}
                  </span>
                </h3>

                {%- if block.settings.description != blank -%}
                  <div class="bf-desc">{{ block.settings.description }}</div>
                {%- endif -%}

                <div class="bf-price-wrap">
                  <div class="bf-price-left">
                    <div class="bf-price">
                      {%- if product != blank -%}
                        {{ product.price | money }}
                      {%- else -%}
                        {{ block.settings.price }}
                      {%- endif -%}
                    </div>
                    {%- if product.compare_at_price > product.price -%}
                      <div class="bf-compare">{{ product.compare_at_price | money }}</div>
                    {%- elsif block.settings.compare_price != blank -%}
                      <div class="bf-compare">{{ block.settings.compare_price }}</div>
                    {%- endif -%}
                  </div>
                  {%- if block.settings.save_text != blank -%}
                    <div class="bf-save">
                      {{ section.settings.save_label }}
                      <strong>{{ block.settings.save_text }}</strong>
                    </div>
                  {%- endif -%}
                </div>

                <a
                  href="{{ product.url | default: block.settings.button_link }}"
                  class="bf-btn mrk-btn m-button {{ section.settings.button_style }} {{ section.settings.button_size }}"
                >
                  {{ section.settings.button_text }} →
                </a>
              </div>

            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>

    {%- if section.settings.bottom_link_text != blank -%}
      <div class="bf-bottom-link">
        <a href="{{ section.settings.bottom_link_url }}">
          {{ section.settings.bottom_link_text }} →
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<script>
(function () {
  function initSplide() {
    var el = document.querySelector('#bf-topsets-splide-{{ section.id }}');
    if (!el || el.classList.contains('is-initialized')) return;
    if (typeof Splide === 'undefined') { setTimeout(initSplide, 100); return; }
    new Splide(el, {
      type             : 'loop',
      perPage          : 3,
      perMove          : 1,
      gap              : '{{ section.settings.card_gap }}px',
      arrows           : false,
      pagination       : false,
      drag             : false,
      waitForTransition: false,
      updateOnMove     : true,
      breakpoints: {
        991: {
          {%- if section.settings.mobile_layout == 'slider' -%}
          /*
           * SLIDER mode — swipeable horizontal carousel (default)
           */
          perPage      : 1,
          perMove      : 1,
          padding      : { right: '{{ section.settings.mobile_peek }}%' },
          gap          : '12px',
          drag         : true,
          snap         : true,
          pagination   : true,
          arrows       : false,
          flickPower   : 400,
          flickMaxPages: 1
          {%- else -%}
          /*
           * GRID mode — Splide surrenders control on mobile;
           * CSS grid (1 or 2 columns) takes over instead.
           */
          destroy      : true
          {%- endif -%}
        }
      }
    }).mount();
    el.classList.add('is-initialized');
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSplide);
  } else {
    initSplide();
  }
  document.addEventListener('shopify:section:load', function(e) {
    if (e.target.querySelector('#bf-topsets-splide-{{ section.id }}')) {
      setTimeout(initSplide, 300);
    }
  });
})();
</script>

