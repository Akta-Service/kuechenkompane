{% comment %}
  Countdown Timer Section
  - Settings: bg color, text color, padding top/bottom, end date/time, heading text
  - Shows TAGE / STUNDEN / MINUTEN / SEKUNDEN
  - Hides automatically when timer expires (optional)
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    text-align: center;
    font-family: {{ section.settings.font_family }};
  }

  .countdown-heading-{{ section.id }} {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    margin: 0 0 {{ section.settings.gap_heading_timer }}px 0;
    line-height: 1.3;
  }

  .countdown-timer-{{ section.id }} {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
  }

  .countdown-unit-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ section.settings.unit_min_width }}px;
  }

  .countdown-number-{{ section.id }} {
    color: {{ section.settings.number_color }};
    font-size: {{ section.settings.number_size }}px;
    font-weight: {{ section.settings.number_weight }};
    line-height: 1;
    letter-spacing: 1px;
  }

  .countdown-label-{{ section.id }} {
    color: {{ section.settings.label_color }};
    font-size: {{ section.settings.label_size }}px;
    font-weight: {{ section.settings.label_weight }};
    letter-spacing: {{ section.settings.label_letter_spacing }}px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .countdown-divider-{{ section.id }} {
    color: {{ section.settings.divider_color }};
    font-size: {{ section.settings.number_size }}px;
    font-weight: 300;
    line-height: 1;
    padding: 0 {{ section.settings.divider_spacing }}px;
    align-self: flex-start;
    margin-top: 0;
  }

  .countdown-expired-{{ section.id }} {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    margin: 0;
    display: none;
  }

  @media (max-width: 480px) {
    .countdown-number-{{ section.id }} {
      font-size: {{ section.settings.number_size | minus: 6 }}px;
    }
    .countdown-heading-{{ section.id }} {
      font-size: {{ section.settings.heading_size | minus: 2 }}px;
    }
    .countdown-unit-{{ section.id }} {
      min-width: {{ section.settings.unit_min_width | minus: 10 }}px;
    }
  }
{%- endstyle -%}

<div
  id="countdown-{{ section.id }}"
  data-end-date="{{ section.settings.end_date }}T{{ section.settings.end_time }}:00"
  data-hide-on-expire="{{ section.settings.hide_on_expire }}"
  data-section-id="{{ section.id }}"
>
  <p class="countdown-heading-{{ section.id }}">{{ section.settings.heading }}</p>

  <div class="countdown-timer-{{ section.id }}">
    <div class="countdown-unit-{{ section.id }}">
      <span class="countdown-number-{{ section.id }}" id="cd-days-{{ section.id }}">00</span>
      <span class="countdown-label-{{ section.id }}">{{ section.settings.label_days }}</span>
    </div>

    <span class="countdown-divider-{{ section.id }}">|</span>

    <div class="countdown-unit-{{ section.id }}">
      <span class="countdown-number-{{ section.id }}" id="cd-hours-{{ section.id }}">00</span>
      <span class="countdown-label-{{ section.id }}">{{ section.settings.label_hours }}</span>
    </div>

    <span class="countdown-divider-{{ section.id }}">|</span>

    <div class="countdown-unit-{{ section.id }}">
      <span class="countdown-number-{{ section.id }}" id="cd-minutes-{{ section.id }}">00</span>
      <span class="countdown-label-{{ section.id }}">{{ section.settings.label_minutes }}</span>
    </div>

    <span class="countdown-divider-{{ section.id }}">|</span>

    <div class="countdown-unit-{{ section.id }}">
      <span class="countdown-number-{{ section.id }}" id="cd-seconds-{{ section.id }}">00</span>
      <span class="countdown-label-{{ section.id }}">{{ section.settings.label_seconds }}</span>
    </div>
  </div>

  <p class="countdown-expired-{{ section.id }}" id="cd-expired-{{ section.id }}">
    {{ section.settings.expired_message }}
  </p>
</div>

<script>
(function() {
  var sectionId = {{ section.id | json }};
  var wrapper   = document.getElementById('countdown-' + sectionId);
  if (!wrapper) return;

  var endDateStr   = wrapper.getAttribute('data-end-date');
  var hideOnExpire = wrapper.getAttribute('data-hide-on-expire') === 'true';
  var endTime      = new Date(endDateStr).getTime();

  var daysEl    = document.getElementById('cd-days-'    + sectionId);
  var hoursEl   = document.getElementById('cd-hours-'   + sectionId);
  var minutesEl = document.getElementById('cd-minutes-' + sectionId);
  var secondsEl = document.getElementById('cd-seconds-' + sectionId);
  var expiredEl = document.getElementById('cd-expired-' + sectionId);
  var timerEl   = wrapper.querySelector('.countdown-timer-' + sectionId);

  function pad(n) {
    return n < 10 ? '0' + n : '' + n;
  }

  function tick() {
    var now  = new Date().getTime();
    var diff = endTime - now;

    if (diff <= 0) {
      daysEl.textContent    = '00';
      hoursEl.textContent   = '00';
      minutesEl.textContent = '00';
      secondsEl.textContent = '00';

      if (hideOnExpire) {
        var section = wrapper.closest('.shopify-section');
        if (section) section.style.display = 'none';
      } else {
        if (timerEl)   timerEl.style.display   = 'none';
        if (expiredEl) expiredEl.style.display  = 'block';
      }
      return;
    }

    var days    = Math.floor(diff / (1000 * 60 * 60 * 24));
    var hours   = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    var seconds = Math.floor((diff % (1000 * 60)) / 1000);

    daysEl.textContent    = pad(days);
    hoursEl.textContent   = pad(hours);
    minutesEl.textContent = pad(minutes);
    secondsEl.textContent = pad(seconds);

    setTimeout(tick, 1000);
  }

  tick();
})();
</script>

{% schema %}
{
  "name": "Password Countdown",
  "tag": "div",
  "class": "countdown-timer-section",
  "settings": [
    {
      "type": "header",
      "content": "Countdown Target"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End date (YYYY-MM-DD)",
      "default": "2025-04-20"
    },
    {
      "type": "text",
      "id": "end_time",
      "label": "End time (HH:MM) — 24 h format",
      "default": "23:59"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Der VIP Oster Pre-Sale läuft noch:"
    },
    {
      "type": "text",
      "id": "expired_message",
      "label": "Expired message",
      "default": "Der Sale ist beendet."
    },
    {
      "type": "header",
      "content": "Labels"
    },
    {
      "type": "text",
      "id": "label_days",
      "label": "Days label",
      "default": "TAGE"
    },
    {
      "type": "text",
      "id": "label_hours",
      "label": "Hours label",
      "default": "STUNDEN"
    },
    {
      "type": "text",
      "id": "label_minutes",
      "label": "Minutes label",
      "default": "MINUTEN"
    },
    {
      "type": "text",
      "id": "label_seconds",
      "label": "Seconds label",
      "default": "SEKUNDEN"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f5f0e8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2c2a25"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Number color",
      "default": "#2c2a25"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#2c2a25"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#2c2a25"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_heading_timer",
      "label": "Gap: heading → timer",
      "min": 4,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "unit_min_width",
      "label": "Unit column width",
      "min": 40,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "divider_spacing",
      "label": "Divider horizontal spacing",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "text",
      "id": "font_family",
      "label": "Font family",
      "default": "inherit"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Heading letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "Number font size",
      "min": 18,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "number_weight",
      "label": "Number font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label font size",
      "min": 8,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Label font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "label_letter_spacing",
      "label": "Label letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Behaviour"
    },
    {
      "type": "checkbox",
      "id": "hide_on_expire",
      "label": "Hide entire section when expired",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Password Countdown"
    }
  ]
}
{% endschema %}
