{% comment %}
  Icon Bar Section
  Desktop : All items in a horizontal row with thin vertical dividers.
  Mobile  : 2 × 2 grid (or a single-column stack when more than 4 items).
{% endcomment %}

<style>
  /* ── ROOT ── */
  #kk-icon-bar-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    border-top: {{ section.settings.border_top_width }}px solid {{ section.settings.border_color }};
    border-bottom: {{ section.settings.border_bottom_width }}px solid {{ section.settings.border_color }};
  }

  #kk-icon-bar-{{ section.id }} .ib-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: {{ section.settings.desktop_padding_top }}px {{ section.settings.desktop_padding_h }}px {{ section.settings.desktop_padding_bottom }}px;
  }

  /* ── DESKTOP GRID ── */
  #kk-icon-bar-{{ section.id }} .ib-grid {
    display: flex;
    align-items: stretch;
  }

  #kk-icon-bar-{{ section.id }} .ib-item {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.desktop_item_justify }};
    gap: {{ section.settings.icon_text_gap }}px;
    padding: 0 24px;
    position: relative;
    text-align: {{ section.settings.desktop_text_align }};
  }

  /* Vertical divider */
  {% if section.settings.show_desktop_dividers %}
  #kk-icon-bar-{{ section.id }} .ib-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 10%;
    height: 80%;
    width: 1px;
    background: {{ section.settings.divider_color }};
  }
  {% endif %}

  /* Icon wrapper */
  #kk-icon-bar-{{ section.id }} .ib-icon {
    flex-shrink: 0;
    width: {{ section.settings.desktop_icon_size }}px;
    height: {{ section.settings.desktop_icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.icon_color }};
  }
  #kk-icon-bar-{{ section.id }} .ib-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  #kk-icon-bar-{{ section.id }} .ib-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: {{ section.settings.icon_color }};
    stroke-width: {{ section.settings.icon_stroke_width }};
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Text block */
  #kk-icon-bar-{{ section.id }} .ib-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  #kk-icon-bar-{{ section.id }} .ib-title {
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.desktop_title_size }}px;
    font-weight: {{ section.settings.desktop_title_weight }};
    line-height: {{ section.settings.desktop_title_line_height }};
    letter-spacing: {{ section.settings.desktop_title_letter_spacing }}px;
    text-transform: {{ section.settings.title_transform }};
  }

  #kk-icon-bar-{{ section.id }} .ib-subtitle {
    color: {{ section.settings.subtitle_color }};
    font-size: {{ section.settings.desktop_subtitle_size }}px;
    font-weight: {{ section.settings.desktop_subtitle_weight }};
    line-height: {{ section.settings.desktop_subtitle_line_height }};
    letter-spacing: {{ section.settings.desktop_subtitle_letter_spacing }}px;
  }

  /* ── MOBILE ── */
  @media (max-width: 767px) {
    #kk-icon-bar-{{ section.id }} .ib-inner {
      padding: {{ section.settings.mobile_padding_top }}px {{ section.settings.mobile_padding_h }}px {{ section.settings.mobile_padding_bottom }}px;
    }

    #kk-icon-bar-{{ section.id }} .ib-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }

    #kk-icon-bar-{{ section.id }} .ib-item {
      flex-direction: {{ section.settings.mobile_item_direction }};
      justify-content: {{ section.settings.mobile_item_justify }};
      text-align: {{ section.settings.mobile_text_align }};
      padding: {{ section.settings.mobile_item_padding_v }}px {{ section.settings.mobile_item_padding_h }}px;
      gap: {{ section.settings.mobile_icon_text_gap }}px;
    }

    /* Remove desktop dividers */
    #kk-icon-bar-{{ section.id }} .ib-item::after { display: none !important; }

    {% if section.settings.show_mobile_grid_lines %}
    /* Right border for left-column items */
    #kk-icon-bar-{{ section.id }} .ib-item:nth-child(odd) {
      border-right: 1px solid {{ section.settings.divider_color }};
    }
    /* Bottom border for top-row items (first half of blocks) */
    #kk-icon-bar-{{ section.id }} .ib-item:nth-child(-n + {{ section.blocks.size | divided_by: 2 }}) {
      border-bottom: 1px solid {{ section.settings.divider_color }};
    }
    {% endif %}

    /* Icon size on mobile */
    #kk-icon-bar-{{ section.id }} .ib-icon {
      width: {{ section.settings.mobile_icon_size }}px;
      height: {{ section.settings.mobile_icon_size }}px;
    }

    /* Mobile typography: title */
    #kk-icon-bar-{{ section.id }} .ib-title {
      font-size: {{ section.settings.mobile_title_size }}px;
      font-weight: {{ section.settings.mobile_title_weight }};
      line-height: {{ section.settings.mobile_title_line_height }};
      letter-spacing: {{ section.settings.mobile_title_letter_spacing }}px;
    }

    /* Mobile typography: subtitle */
    #kk-icon-bar-{{ section.id }} .ib-subtitle {
      font-size: {{ section.settings.mobile_subtitle_size }}px;
      font-weight: {{ section.settings.mobile_subtitle_weight }};
      line-height: {{ section.settings.mobile_subtitle_line_height }};
      letter-spacing: {{ section.settings.mobile_subtitle_letter_spacing }}px;
    }
  }
</style>

{% comment %} Icon SVGs {% endcomment %}
{% capture svg_truck %}
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <rect x="1" y="3" width="15" height="13"/>
    <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
    <circle cx="5.5" cy="18.5" r="2.5"/>
    <circle cx="18.5" cy="18.5" r="2.5"/>
  </svg>
{% endcapture %}
{% capture svg_clock %}
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <circle cx="12" cy="12" r="10"/>
    <polyline points="12 6 12 12 16 14"/>
  </svg>
{% endcapture %}
{% capture svg_lock %}
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
  </svg>
{% endcapture %}
{% capture svg_headphones %}
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
    <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
  </svg>
{% endcapture %}
{% capture svg_shield %}
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
  </svg>
{% endcapture %}
{% capture svg_star %}
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
  </svg>
{% endcapture %}
{% capture svg_check %}
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
    <polyline points="22 4 12 14.01 9 11.01"/>
  </svg>
{% endcapture %}
{% capture svg_gift %}
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <polyline points="20 12 20 22 4 22 4 12"/>
    <rect x="2" y="7" width="20" height="5"/>
    <line x1="12" y1="22" x2="12" y2="7"/>
    <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
    <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
  </svg>
{% endcapture %}
{% capture svg_percent %}
  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <circle cx="9" cy="9" r="2.5"/>
    <circle cx="15" cy="15" r="2.5"/>
    <line x1="19" y1="5" x2="5" y2="19"/>
  </svg>
{% endcapture %}

<div id="kk-icon-bar-{{ section.id }}">
  <div class="ib-inner">
    <div class="ib-grid">
      {% for block in section.blocks %}
        <div class="ib-item" {{ block.shopify_attributes }}>

          {%- comment -%} Icon {%- endcomment -%}
          {% unless block.settings.icon_type == 'none' %}
            <div class="ib-icon">
              {% if block.settings.icon_image != blank %}
                {{ block.settings.icon_image | image_url: width: 80 | image_tag: loading: 'lazy' }}
              {% else %}
                {% case block.settings.icon_type %}
                  {% when 'truck' %}       {{ svg_truck }}
                  {% when 'clock' %}       {{ svg_clock }}
                  {% when 'lock' %}        {{ svg_lock }}
                  {% when 'headphones' %}  {{ svg_headphones }}
                  {% when 'shield' %}      {{ svg_shield }}
                  {% when 'star' %}        {{ svg_star }}
                  {% when 'check' %}       {{ svg_check }}
                  {% when 'gift' %}        {{ svg_gift }}
                  {% when 'percent' %}     {{ svg_percent }}
                {% endcase %}
              {% endif %}
            </div>
          {% endunless %}

          {%- comment -%} Text {%- endcomment -%}
          <div class="ib-text">
            {% if block.settings.title != blank %}
              <span class="ib-title">{{ block.settings.title }}</span>
            {% endif %}
            {% if block.settings.subtitle != blank %}
              <span class="ib-subtitle">{{ block.settings.subtitle }}</span>
            {% endif %}
          </div>

        </div>
      {% endfor %}
    </div>
  </div>
</div>

