<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.querySelector('.filter-open-btn');
    const layout = document.querySelector('.akta-collection-grid-wrapper');

    if (!btn || !layout) return;

    btn.addEventListener('click', () => {
      layout.classList.toggle('filters-open');
      btn.classList.toggle('active');
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    function initDropdowns() {
      const buttons = document.querySelectorAll('.filter-tab-btn');
      const dropdowns = document.querySelectorAll('.dropdown');

      // Close all dropdowns
      function closeAll() {
        buttons.forEach((btn) => btn.classList.remove('is-active'));
        dropdowns.forEach((dd) => dd.classList.remove('active'));
      }

      // Button click
      buttons.forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();

          const id = btn.dataset.filter;
          const dropdown = document.querySelector(`.dropdown[data-dropdown="${id}"]`);

          const isOpen = dropdown.classList.contains('active');

          closeAll(); // close others first

          if (!isOpen) {
            btn.classList.add('is-active');
            dropdown.classList.add('active');
          }
        });
      });

      // Click outside closes all
      document.addEventListener('click', () => {
        closeAll();
      });

      // Prevent inside dropdown click from closing
      dropdowns.forEach((dd) => {
        dd.addEventListener('click', (e) => {
          e.stopPropagation();
        });
      });
    }
    initDropdowns();
  });
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const sectionWrapper = document.querySelector(".filter-collection");

    /** -----------------------------
    * Collection Tabs
    * ----------------------------- */
    function loadCollection(handle, pushUrl = false) {
      sectionWrapper.classList.add("is-loading");

      fetch(`/collections/${handle}?sections=filter-collection-with-dropdown`)
        .then((res) => {
          // HTTP error check
          if (!res.ok) {
            console.error(
              "Fetch failed:",
              res.status,
              res.statusText,
              `/collections/${handle}`,
            );
            throw new Error("Network response was not ok");
          }

          return res.json();
        })
        .then((data) => {
          // Section existence check
          if (!data["filter-collection-with-dropdown"]) {
            console.error("Section not found in response:", data);
            throw new Error("Missing section HTML");
          }

          const html = data["filter-collection-with-dropdown"];

          const parser = new DOMParser();
          const doc = parser.parseFromString(html, "text/html");

          // Replace Grid
          const newGrid = doc.querySelector(".akta-grid-pagi-wrapper");
          const grid = document.querySelector(".akta-grid-pagi-wrapper");

          if (!newGrid) console.error("New grid not found");
          if (!grid) console.error("Current grid not found");

          if (newGrid && grid) grid.innerHTML = newGrid.innerHTML;

          // Replace Banner
          const newBanner = doc.querySelector(".filter-banner");
          const banner = document.querySelector(".filter-banner");

          if (!newBanner) console.error("New banner not found");
          if (!banner) console.error("Current banner not found");

          if (newBanner && banner) banner.innerHTML = newBanner.innerHTML;

          // Replace Filters
          const newFilter = doc.querySelector(".custom-filters");
          const filter = document.querySelector(".custom-filters");

          if (!newFilter) console.error("New filters not found");
          if (!filter) console.error("Current filters not found");

          if (newFilter && filter) filter.innerHTML = newFilter.innerHTML;

          // Update URL
          if (pushUrl) {
            {% comment %} history.pushState({ handle }, "", `/collections/${handle}`); {% endcomment %}
          }

          // Re-init scripts
          initTabs();
          initFilters();
          initAccordion();
          initPagination();

          sectionWrapper.classList.remove("is-loading");
        })
        .catch((error) => {
          console.error("loadCollection ERROR:", error);
          sectionWrapper.classList.remove("is-loading");
        });
    }

    function loadPagination(url) {
      const sectionWrapper = document.querySelector(".filter-collection");
      if (!sectionWrapper) return;

      sectionWrapper.classList.add("is-loading");

      // keep query params + inject section rendering
      const fetchUrl =
        url +
        (url.includes("?") ? "&" : "?") +
        "sections=filter-collection-with-dropdown";

      fetch(fetchUrl)
        .then((res) => res.json())
        .then((data) => {
          const html = data["filter-collection-with-dropdown"];
          if (!html) throw new Error("Section HTML missing");

          const parser = new DOMParser();
          const doc = parser.parseFromString(html, "text/html");

          // replace GRID + PAGINATION together
          const newWrapper = doc.querySelector(".akta-grid-pagi-wrapper");
          const currentWrapper = document.querySelector(
            ".akta-grid-pagi-wrapper",
          );

          if (newWrapper && currentWrapper) {
            currentWrapper.innerHTML = newWrapper.innerHTML;
          }

          // re-init dynamic scripts
          initTabs();
          initFilters();
          initAccordion();
          initPagination();

          sectionWrapper.classList.remove("is-loading");
        })
        .catch((err) => {
          console.error("Pagination error:", err);
          sectionWrapper.classList.remove("is-loading");
        });
    }

    function initPagination() {
      const links = document.querySelectorAll(".akta-collection-pagination a");
      if (!links.length) return;

      links.forEach((link) => {
        link.addEventListener("click", function (e) {
          e.preventDefault();

          const url = this.getAttribute("href");
          if (!url) return;

          loadPagination(url);
        });
      });
    }
    function initTabs() {
      const tabs = document.querySelectorAll(".collection-tab-btn");
      const selects = document.querySelectorAll(".filter-select");

      if (!tabs.length) return;

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          if (tab.classList.contains("is-active")) return;

          // activate tab
          tabs.forEach((t) => t.classList.remove("is-active"));
          tab.classList.add("is-active");

          // remove active from ALL selects
          selects.forEach((select) => {
            select.classList.remove("is-active");
          });

          loadCollection(tab.dataset.handle);
        });
      });
    }

    // MULTIPLE SELECT SUPPORT
    document.querySelectorAll(".filter-select").forEach((select) => {
      select.addEventListener("change", function () {
        const handle = this.value;

        loadCollection(handle);
        console.log("Selected handle:", handle);

        // remove active from ALL selects
        document
          .querySelectorAll(".filter-select")
          .forEach((s) => s.classList.remove("is-active"));

        // add active only to current select
        this.classList.add("is-active");

        // remove active from tabs
        document
          .querySelectorAll(".collection-tab-btn")
          .forEach((tab) => tab.classList.remove("is-active"));
      });
    });

    /** -----------------------------
    * Accordion
    * ----------------------------- */
    function initAccordion() {
      document.querySelectorAll(".filter-toggle").forEach((btn) => {
        btn.addEventListener("click", () => {
          btn.classList.toggle("active");

          const body = btn.nextElementSibling;
          body.classList.toggle("open");

          btn.setAttribute("aria-expanded", btn.classList.contains("active"));
        });
      });
    }

    /** -----------------------------
    * Filter Form AJAX
    * ----------------------------- */
    function initFilters() {
      const form = document.getElementById("CollectionFiltersForm");
      if (!form) return;

      const sectionWrapper = document.querySelector(".filter-collection");

      function updateCollectionFromForm() {
        sectionWrapper.classList.add("is-loading");

        // Build URL only from non-empty form values
        const formData = new FormData(form);
        const params = new URLSearchParams();

        for (const [key, value] of formData.entries()) {
          if (value !== "" && value != null) {
            params.append(key, value);
          }
        }

        const url = `${window.location.pathname}${params.toString() ? "?" + params.toString() : ""}`;

        fetch(url)
          .then((res) => res.text())
          .then((html) => {
            const doc = new DOMParser().parseFromString(html, "text/html");

            const newGrid = doc.querySelector(".akta-collection-grid");
            const currentGrid = document.querySelector(".akta-collection-grid");
            if (newGrid && currentGrid) currentGrid.innerHTML = newGrid.innerHTML;

            history.pushState({}, "", url);
            sectionWrapper.classList.remove("is-loading");

            initAccordion(); // Re-init dynamic elements
          });
      }

      // Handle changes on inputs
      form.addEventListener("change", updateCollectionFromForm);

      // Handle Clear button
      const clearBtn = form.querySelector(".clear-btn");
      if (clearBtn) {
        clearBtn.addEventListener("click", (e) => {
          e.preventDefault(); // Prevent default form reset / reload
          form.reset(); // Reset all inputs in the form
          updateCollectionFromForm(); // Update collection via AJAX
        });
      }
    }

    /** -----------------------------
    * Initial Setup
    * ----------------------------- */
    initTabs();
    initFilters();
    initAccordion();
    initPagination();
  });  
</script>




<script>
  function autoWidthSelect(select) {
    // create temp element to measure text width
    const temp = document.createElement('select');
    const tempOption = document.createElement('option');
    
    tempOption.textContent = select.options[select.selectedIndex].text;
    temp.appendChild(tempOption);
    
    temp.style.cssText = `
      position: absolute;
      visibility: hidden;
      font-size: ${getComputedStyle(select).fontSize};
      font-family: ${getComputedStyle(select).fontFamily};
      font-weight: ${getComputedStyle(select).fontWeight};
      padding: ${getComputedStyle(select).padding};
      border: ${getComputedStyle(select).border};
    `;
    
    document.body.appendChild(temp);
    select.style.width = temp.offsetWidth + 'px';
    document.body.removeChild(temp);
  }

  // init
  document.querySelectorAll('.filter-select').forEach(select => {
    autoWidthSelect(select); // on load

    select.addEventListener('change', function () {
      autoWidthSelect(this); // on change
    });
  });
</script>
