{{ 'akta-collection-grid.css' | asset_url | stylesheet_tag }}
{{ 'filter-collection.css' | asset_url | stylesheet_tag }}
{{ 'dropdown-filter.css' | asset_url | stylesheet_tag }}
<style>
  .akta-collection-pagination.akta-pagination-circle a,
  .akta-collection-pagination.akta-pagination-circle .active {
    border-radius: 50%;
  }
  .section-{{ section.id }}{
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .tab-item .collection-tab-btn {
    border-radius: 4px;
    border: 1px solid #d2d2d2;
    padding: 8px 8px;
  }
  a.tab-btn-link {
    border: 1px solid #d2d2d2;
    font-size: 14px;
    color: #000;
    padding: 4.5px 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  select.filter-select {
    border-radius: 4px;
    border: 1px solid #d2d2d2;
    padding:3px 25px 3px 8px;
    transition: 0.3s;
  }
  .filter-select:focus {
    outline: 0;
    box-shadow: none;    
  }


  select.filter-select.is-active {
    border-color: #000;
  }


  @media (max-width: 768px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.5 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.5 }}px;
    }
  }
  {% comment %} .akta-collection-grid-item:hover img{
    transform: scale(1.2);
  } {% endcomment %}

  {%- if section.settings.hover_second_image -%}

    /* Hover Effect = Zoom + Swap */
    .akta-collection-grid-item:hover .akta-image-default {
      opacity: 0;
      transform: scale(1.1);
    }

    .akta-collection-grid-item:hover .akta-image-hover {
      opacity: 1;
      transform: scale(1.1);
    }
  {%- endif -%}
</style>
<div
  id="filter-collection-{{ section.id }}"
  class="filter-collection  section-{{ section.id }}"
>
  {% if section.settings.Show_banner %}
    <div class="filter-banner">
      <div class="filter-banner__inner">
        <!-- Left Content -->
        <div class="filter-banner__content">
          {% if section.settings.breadcrumbs %}
            <nav class="filter-banner__breadcrumbs">
              <a href="/">Home</a>
              <span>/</span>
              <a href="/collection/all">Shop All</a>
              <span>/</span>
              <span>{{ collection.title }}</span>
            </nav>
          {% endif %}
          <div class="filter-banner__content-main">
            <h1 class="filter-banner__title">{{ collection.title }}</h1>
            {% if section.settings.show_des %}
              <p class="filter-banner__desc">{{ collection.description | truncatewords: 20 | strip_html }}</p>
            {% endif %}
          </div>
        </div>

        <!-- Right Image -->
        <div class="filter-banner__image">
          <img
            src="{{ collection.featured_image | image_url }}"
            alt="Cookware Accessories"
            loading="lazy"
            width=""
            height=""
          >
        </div>
      </div>
    </div>
  {% endif %}
  {% if section.settings.show_filter %}
    <div class="filter-container">
      <button class="filter-open-btn">
        Filter
        {% render 'icons', type: 'filter' %}
      </button>     
      <div class="dropdown-filter-wrapper">
        {% for block in section.blocks %}
          {% assign collections = block.settings.collections %}
      
          <div class="tab-item">
            {% if collections.size > 1 %}
              <!-- Multi-collection: render as <select> dropdown -->
              {% if collections != blank %}
                <select
                  class="filter-select"
                  name="collection_filter"
                  data-filter="{{ block.id }}"
                >
                  <option value="" disabled selected>{{ block.settings.filter_label }}</option>
                  {% for collection in collections %}
                    <option
                      value="{{ collection.handle }}"
                      data-handle="{{ collection.handle }}"
                    >
                      {{ collection.title }}
                    </option>
                  {% endfor %}
                </select>
              {% endif %}
      
            {% else %}
              <!-- Single collection: render as a button -->
              {% for collection in collections limit: 1 %}
                <button
                  type="button"
                  class="collection-tab-btn"
                  data-handle="{{ collection.handle }}"
                >
                  {{ block.settings.filter_label }}
                </button>
              {% endfor %}
            {% endif %}
          </div>
      
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <div class="akta-collection-grid-wrapper">
    {% render 'collection-filters', collection: collection %}
    <div class="akta-grid-pagi-wrapper" >
      {% paginate collection.products by section.settings.products_limit %}
        <div class="akta-collection-grid ">
          {% for product in collection.products %}
            <div class="akta-collection-grid-item">
              <div class="akta-collection-grid-image-wrapper">
                {% if product.available %}
                {% else %}
                  <span class="akta-sold-out-badge">Ausverkauft</span>
                {% endif %}

                <a href="{{ product.url }}">
                  <!-- Show normal featured image -->
                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url }}"
                      alt="{{ product.title }}"
                      class="akta-collection-grid-image akta-image-default"
                      width="100%"
                      height=""
                      {% if forloop.index <= 4 %}
                        loading="eager" fetchpriority="high"
                      {% else %}
                        loading="lazy"
                      {% endif %}
                    >
                  {%- endif -%}

                  <!-- Hover image always comes from product.images[1] -->
                  {%- if section.settings.hover_second_image and product.images.size > 1 -%}
                    <img
                      src="{{ product.images[1] | image_url }}"
                      alt="{{ product.title }}"
                      class="akta-collection-grid-image akta-image-hover"
                      width="100%"
                      height=""
                      {% if forloop.index <= 4 %}
                        loading="eager" fetchpriority="high"
                      {% else %}
                        loading="lazy"
                      {% endif %}
                    >
                  {%- endif -%}
                </a>
              </div>

              <div class="akta-collection-grid-content">
                {% if section.settings.show_product_ratings %}
                  <div
                    class="loox-rating"
                    data-id="{{ product.id }}"
                    data-rating="{{ product.metafields.loox.avg_rating }}"
                    data-raters="{{ product.metafields.loox.num_reviews }}"
                  ></div>
                {% endif %}

                <a href="{{ product.url }}">
                  <h3 class="akta-collection-grid-title">{{ product.title }}</h3>
                </a>

                {% comment %}
                  <div class="akta-collection-grid-prices">
                    {% if product.compare_at_price > product.price %}
                      <span class="akta-collection-grid-price">{{ product.price | money }}</span>
                      <span class="akta-collection-grid-compare">{{ product.compare_at_price | money }}</span>
                    {% else %}
                      <span class="akta-collection-grid-price">{{ product.price | money }}</span>
                    {% endif %}
                  </div>
                {% endcomment %}

                {% if section.settings.show_max_price %}
                  {% assign main_price = product.price_max %}
                  {% assign compare_price = product.compare_at_price_max %}
                {% else %}
                  {% assign main_price = product.price %}
                  {% assign compare_price = product.compare_at_price %}
                {% endif %}

                <div class="akta-collection-grid-prices">
                  {% if compare_price > main_price %}
                    <span class="akta-collection-grid-price">
                      {{ main_price | money }}
                    </span>

                    <span class="akta-collection-grid-compare">
                      {{ compare_price | money }}
                    </span>

                  {% else %}
                    <span class="akta-collection-grid-price">
                      {{ main_price | money }}
                    </span>
                  {% endif %}
                </div>
                {% if section.settings.show_save_price %}
                  <style>
                    .akta-collection-grid-prices {
                        margin-bottom: -4px;
                    }
                  </style>
                  {% assign savings = compare_price | minus: main_price %}
                  <span class="akta-collection-grid-save">
                    Du sparst <strong>{{ savings | money }}</strong>
                  </span>
                {% endif %}

                {% if section.settings.show_stock_status %}
                  {% render 'stock-count-status', product: product, custom_class: 'ml-15 collection-stock' %}
                {% endif %}

                {% if section.settings.show_gift_info %}
                  {% render 'gift-info-text-with-icon' %}
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <nav class="akta-collection-pagination akta-pagination-{{ section.settings.pagination_style }}">
            <ul>
              {% if paginate.previous %}
                <li><a href="{{ paginate.previous.url }}" class="prev">«</a></li>
              {% endif %}

              {% for part in paginate.parts %}
                {% if part.is_link %}
                  <li>
                    <a href="{{ part.url }}">{{ part.title }}</a>
                  </li>
                {% else %}
                  <li class="active">{{ part.title }}</li>
                {% endif %}
              {% endfor %}

              {% if paginate.next %}
                <li><a href="{{ paginate.next.url }}" class="next">»</a></li>
              {% endif %}
            </ul>
          </nav>
        {% endif %}
      {% endpaginate %}
    </div>
  </div>
</div>
{% schema %}
