<script src="{{ 'announcement-bar.js' | asset_url }}" defer="defer"></script>

<style>
  .m-announcement-bar__wrapper.splide {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .m-announcement-bar__inner.splide__track {
    flex: 1;
    overflow: hidden;
  }

  .splide__list {
    display: flex;
  }

  .m-announcement-bar__item.splide__slide {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    width: 100%;
    flex-shrink: 0;
  }

  .m-announcement-bar__nav {
    display: contents;
  }

  .mrk-ann-prev {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: inline-flex;
    align-items: center;
    color: currentColor;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .mrk-ann-next {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: inline-flex;
    align-items: center;
    color: currentColor;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .mrk-ann-prev:hover,
  .mrk-ann-next:hover {
    opacity: 1;
  }
</style>



{% liquid
  assign enable_slider = false
  if section.blocks.size > 1
    assign enable_slider = true
  endif

  assign autorotate = section.settings.autorotate
  assign autorotate_speed = section.settings.autorotate_speed
  assign show_divider = section.settings.show_divider
  assign show_nav = section.settings.show_nav

  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif
%}

{% if section.settings.show_announcement %}
  {% if section.settings.homepage_only == false or request.page_type == 'index' or page.template_suffix == 'ntv' %}
    <section
      id="m-announcement--{{ section.id }}"
      data-section-id="{{ section.id }}"
      data-section-type="announcement"
      class="m-announcement-bar m-gradient m-color-{{ section.settings.color_scheme }}"
      {% if show_divider %}
        style="--border-width: 1px"
      {% endif %}
    >
      <m-announcement-bar
        data-enable-slider="{{ enable_slider }}"
        {% if enable_slider %}
          data-enable-autoplay="{{ autorotate }}"
          data-autoplay-speed="{{ autorotate_speed }}"
        {% endif %}
      >
        <div class="m-announcement-bar__container {{ container }}">

          {% if enable_slider %}
            <div class="m-announcement-bar__wrapper splide" id="mrk-announcement-splide--{{ section.id }}">
              <div class="m-announcement-bar__inner splide__track">
                <ul class="splide__list">
                  {% for block in section.blocks %}
                    <li class="m-announcement-bar__item splide__slide">
                      {% if block.settings.message_link != blank %}
                        <a href="{{ block.settings.message_link }}" class="m-announcement-bar__link"></a>
                      {% endif %}
                      {% if block.settings.message != blank %}
                        <div class="m-announcement-bar__content">{{ block.settings.message }}</div>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              </div>

              {% if show_nav %}
                <div class="m-announcement-bar__nav">
                  <button class="mrk-ann-prev" aria-label="Previous">
                    <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <button class="mrk-ann-next" aria-label="Next">
                    <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              {% endif %}
            </div>

          {% else %}
            <div class="m-announcement-bar__wrapper">
              <div class="m-announcement-bar__inner">
                {% for block in section.blocks %}
                  <div class="m-announcement-bar__item">
                    {% if block.settings.message_link != blank %}
                      <a href="{{ block.settings.message_link }}" class="m-announcement-bar__link"></a>
                    {% endif %}
                    {% if block.settings.message != blank %}
                      <div class="m-announcement-bar__content">{{ block.settings.message }}</div>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endif %}

        </div>
      </m-announcement-bar>

      {% if section.settings.show_close %}
        <div class="m-announcement-bar__close m:flex m:items-center">
          <svg
            class="m-svg-icon--medium"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </div>
        <script>
          document.querySelector('.m-announcement-bar__close').addEventListener('click', function () {
            document.querySelector('.m-announcement-bar').remove();
            document.documentElement.style.setProperty('--m-announcement-height', '0px');
          });
        </script>
      {% endif %}
    </section>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "[Watch tutorial](https://foxecom.link/zDfFJy)"
    },
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container",
      "options": [
        {
          "value": "container-fluid",
          "label": "Default"
        },
        {
          "value": "w-full",
          "label": "Full width"
        },
        {
          "value": "container",
          "label": "Use container box"
        }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "homepage_only",
      "label": "Home page only",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_close",
      "label": "Show close button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider",
      "default": false
    },
    {
      "type": "header",
      "content": "Slider settings"
    },
    {
      "type": "paragraph",
      "content": "Slider work when more than more 2 items"
    },
    {
      "type": "checkbox",
      "id": "show_nav",
      "label": "Show navigation",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "autorotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "autorotate_speed",
      "label": "Change slides every",
      "max": 10,
      "min": 2,
      "step": 1,
      "unit": "s",
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Announcement item",
      "settings": [
        {
          "type": "textarea",
          "id": "message",
          "label": "Message",
          "default": "Free shipping for all orders from $60+"
        },
        {
          "type": "url",
          "id": "message_link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "category": "Image",
      "blocks": [
        {
          "type": "item"
        }
      ]
    }
  ]
}
{% endschema %}