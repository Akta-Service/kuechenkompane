
<style>#section-{{section.id}}{background:{{section.settings.background_color | default:'#ffffff'}};padding-top:{{section.settings.padding_top | default:24}}px;padding-bottom:{{section.settings.padding_bottom | default:24}}px;overflow:hidden;}.marquee-{{section.id}} .splide__slide{width:auto!important;display:flex;align-items:center;justify-content:center;}.marquee-{{section.id}} .press-marquee__item img{display:block;height:{{section.settings.logo_height | default:84}}px;width:auto!important;max-width:none!important;object-fit:contain;pointer-events:none;user-select:none;transition:0.3s ease;opacity:1;visibility:visible;}.text-left{text-align:left;}.text-center{text-align:center;}.text-right{text-align:right;}.marquee-{{section.id}} .splide__arrows,.marquee-{{section.id}} .splide__pagination{display:none!important;}#splide-marquee-{{section.id}} .splide__list{display:flex!important;visibility:visible!important;gap:{{section.settings.gap | default:44}}px;}@media screen and (max-width:768px){#splide-marquee-{{section.id}} .splide__list{gap:{{section.settings.gap_mobile | default:35}}px;}}#splide-marquee-{{section.id}}.is-initialized .splide__list{gap:0!important;}@media screen and (max-width:600px){#section-{{section.id}}{padding-top:{{section.settings.padding_top | default:24 | times:0.75}}px;padding-bottom:{{section.settings.padding_bottom | default:24 | times:0.75}}px;}}</style>
<section id="section-{{ section.id }}" class="press-marquee marquee-{{ section.id }}" aria-label="Press logos">{% if section.settings.title != blank %}<div class="press-logo-title-area {{ section.settings.alignment }}" style="margin-bottom: 30px; padding: 0 40px;"><h2 class="press-logo-title {{ section.settings.heading_type }}">{{ section.settings.title }}</h2></div>{% endif %}<div id="splide-marquee-{{ section.id }}" class="splide"><div class="splide__track"><ul class="splide__list">{% for i in (1..3) %}{% for block in section.blocks %}{% if block.settings.logo != blank %}<li class="splide__slide" {{ block.shopify_attributes }}><div class="press-marquee__item"><img src="{{ block.settings.logo | image_url: width: 150 }}" alt="{{ block.settings.alt_text | default: 'logo' }}" loading="{% if i == 1 %}eager{% else %}lazy{% endif %}"{% if i == 1 %}fetchpriority="high"{% endif %}height="{{ section.settings.logo_height }}" width="200"></div></li>{% endif %}{% endfor %}{% endfor %}</ul></div></div></section>{%- liquid
assign theme_speed = section.settings.speed | default: 12
assign final_speed = 5.0 | divided_by: theme_speed
-%}<script>(function () {function initMarquee() {var el = document.querySelector('#splide-marquee-{{ section.id }}');if (!el || el.classList.contains('is-initialized')) return;if (typeof Splide === 'undefined') {setTimeout(initMarquee, 100);return;}var extensions = {};if (window.SplideAutoScroll) {extensions = { AutoScroll: window.SplideAutoScroll };} else if (window.splide && window.splide.Extensions) {extensions = window.splide.Extensions;}new Splide(el, {type : 'loop',drag : 'free',autoWidth : true,gap : {{ section.settings.gap | default: 44 }},arrows : false,pagination : false,snap : false,autoScroll : {speed : {{ final_speed }},pauseOnHover : true,pauseOnFocus : false,rewind : false,},breakpoints: {768: {gap: {{ section.settings.gap_mobile | default: 35 }},}}}).mount(extensions);}if (document.readyState === 'loading') {document.addEventListener('DOMContentLoaded', initMarquee);} else {initMarquee();}document.addEventListener('shopify:section:load', function(e) {if (e.target.querySelector('#splide-marquee-{{ section.id }}')) {setTimeout(initMarquee, 300);}});})();</script>
{% schema %}{"name":"Akta new marquee","settings":[{"type":"text","id":"title","label":"Title"},{"type":"select","id":"alignment","label":"Text alignment","options":[{"value":"text-left","label":"Left"},{"value":"text-center","label":"Center"},{"value":"text-right","label":"Right"}],"default":"text-left"},{"type":"select","id":"heading_type","label":"Choose Heading Size","options":[{"value":"mrk-h1","label":"H1"},{"value":"mrk-h2","label":"H2"},{"value":"mrk-h3","label":"H3"},{"value":"mrk-h4","label":"H4"},{"value":"mrk-h5","label":"H5"},{"value":"mrk-h6","label":"H6"}],"default":"mrk-h3"},{"type":"range","id":"logo_height","label":"Logo height (px)","min":20,"max":200,"step":2,"default":86},{"type":"range","id":"gap","label":"Gap Desktop","min":8,"max":120,"step":4,"default":44},{"type":"range","id":"gap_mobile","label":"Gap Mobile","min":8,"max":100,"step":1,"default":35},{"type":"range","id":"speed","label":"Scroll Speed (seconds)","min":2,"max":100,"step":1,"default":12},{"type":"color","id":"background_color","label":"Background color","default":"#ffffff"},{"type":"range","id":"padding_top","label":"Padding top (px)","min":0,"max":100,"step":1,"default":24},{"type":"range","id":"padding_bottom","label":"Padding bottom (px)","min":0,"max":100,"step":1,"default":24}],"blocks":[{"type":"logo","name":"Logo","settings":[{"type":"image_picker","id":"logo","label":"Logo image"},{"type":"text","id":"alt_text","label":"Alt text (optional)"}]}],"max_blocks":24,"presets":[{"name":"Akta new marquee","category":"Media"}]}{% endschema %}