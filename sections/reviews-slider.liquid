{{ 'splide.min.css' | asset_url | stylesheet_tag }}

{%- style -%}
.reviews-slider-section {
  padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
  background-color: {{ section.settings.section_bg }};
  overflow: hidden;
}

.reviews-slider__header {
  text-align: center;
  margin-bottom: 28px;
}

.reviews-slider__heading {
  font-size: {{ section.settings.heading_size }}px;
  font-weight: 600;
  color: {{ section.settings.heading_color }};
  text-transform: uppercase;
  font-family: "Roboto", sans-serif;
  letter-spacing: -0.05em;
  line-height: 1.15;
  margin: 0 0 12px;
}

.reviews-slider__overall {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: {{ section.settings.overall_size }}px;
  font-weight: 500;
  color: {{ section.settings.subtext_color }};
}

.reviews-slider__overall-stars {
  display: flex;
  align-items: center;
  gap: 2px;
  padding-bottom: 4px;
}

.reviews-slider__overall-stars svg {
  width: 22px;
  height: 22px;
  display: block;
}

.reviews-slider__splide {
  overflow: hidden;
}

.reviews-slider__splide .splide__track {
  overflow: hidden;
}

.reviews-slider__splide .splide__list {
  align-items: stretch;
}

.reviews-slider__splide .splide__slide {
  width: 466px;
  max-width: 100%;
  height: auto;
}

.review-card {
  display: flex;
  flex-direction: row;
  background-color: {{ section.settings.card_bg }};
  border: 1px solid {{ section.settings.card_border_color }};
  border-radius: {{ section.settings.card_radius }}px;
  overflow: hidden;
  height: 100%;
}

.review-card__content {
  flex: 1 1 58%;
  padding: 24px 22px 22px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.review-card__stars {
  display: flex;
  gap: 3px;
  align-items: center;
}

.review-card__stars svg {
  width: 20px;
  height: 20px;
  display: block;
}

.review-card__quote {
  font-size: {{ section.settings.quote_size }}px;
  line-height: 1.6;
  color: {{ section.settings.quote_color }};
  margin: 0;
  flex: 1;
}

.review-card__author {
  font-size: {{ section.settings.author_size }}px;
  font-weight: 600;
  color: {{ section.settings.author_color }};
  margin-top: auto;
}

.review-card__image {
  flex: 0 0 40%;
  max-width: 40%;
  position: relative;
  overflow: hidden;
  min-height: 200px;
  clip-path: polygon(20% 0%, 100% 0, 100% 100%, 0% 100%);
}

.review-card__image img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.reviews-slider__nav {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
  margin-top: -8px;
}

.reviews-slider__btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 2px solid {{ section.settings.nav_color }};
  background-color: transparent;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.reviews-slider__btn:hover {
  background-color: {{ section.settings.nav_color }};
}

.reviews-slider__btn:hover svg {
  stroke: #ffffff;
}

.reviews-slider__btn svg {
  width: 18px;
  height: 18px;
  stroke: {{ section.settings.nav_color }};
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.reviews-slider__splide .splide__pagination {
  position: static;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 6px;
  padding: 0;
  margin-top: 16px;
}

.reviews-slider__splide .splide__pagination li {
  line-height: 1;
  margin: 0;
}

.reviews-slider__splide .splide__pagination__page {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: {{ section.settings.nav_color }};
  opacity: 0.3;
  cursor: pointer;
  border: none;
  margin: 0;
  padding: 0;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.reviews-slider__splide .splide__pagination__page.is-active {
  opacity: 1;
  transform: scale(1.25);
}

@media (max-width: 767px) {
  .reviews-slider-section {
    padding: {{ section.settings.section_padding_top_mobile }}px 0 {{ section.settings.section_padding_bottom_mobile }}px;
  }

  .reviews-slider__heading {
    font-size: {{ section.settings.heading_size_mobile }}px;
  }

  .reviews-slider__overall {
    flex-direction: column;
    font-size: {{ section.settings.overall_size_mobile }}px;
  }

  .review-card__quote {
    font-size: {{ section.settings.quote_size_mobile }}px;
  }

  .review-card__author {
    font-size: {{ section.settings.author_size_mobile }}px;
  }

  .review-card__content {
    padding: 14px 0 16px 16px;
  }

  .review-card__image {
    flex: 0 0 40%;
    max-width: 40%;
    min-height: 160px;
  }
}
{%- endstyle -%}

{%- liquid
  assign star_color     = section.settings.star_color
  assign star_empty     = section.settings.star_empty_color
  assign overall_rating = section.settings.overall_rating | times: 1.0
-%}

<section class="reviews-slider-section" {{ section.shopify_attributes }}>

  <div class="reviews-slider__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="reviews-slider__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.show_overall_rating -%}
        <div class="reviews-slider__overall">
          <div class="reviews-slider__overall-stars">
            {%- for i in (1..5) -%}
              {%- liquid
                assign i_f        = i | times: 1.0
                assign half_mark  = i_f | minus: 0.5
                if overall_rating >= i_f
                  assign star_type = 'full'
                elsif overall_rating >= half_mark
                  assign star_type = 'half'
                else
                  assign star_type = 'empty'
                endif
              -%}
              {%- if star_type == 'full' -%}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="{{ star_color }}" stroke="{{ star_color }}" stroke-width="1"/>
                </svg>
              {%- elsif star_type == 'half' -%}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <linearGradient id="oh-{{ section.id }}-{{ forloop.index }}" x1="0" x2="1" y1="0" y2="0">
                      <stop offset="50%" stop-color="{{ star_color }}"/>
                      <stop offset="50%" stop-color="{{ star_empty }}"/>
                    </linearGradient>
                  </defs>
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#oh-{{ section.id }}-{{ forloop.index }})" stroke="{{ star_color }}" stroke-width="1"/>
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="{{ star_empty }}" stroke="{{ star_color }}" stroke-width="1"/>
                </svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span>{{ section.settings.overall_rating }}/5 {{ section.settings.overall_label }} {{ section.settings.overall_count }}</span>
        </div>

    {%- endif -%}
  </div>


  <div class="custom-container">
    <div class="splide reviews-slider__splide" id="reviews-splide-{{ section.id }}">
      <div class="splide__track">
        <ul class="splide__list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign b_rating   = block.settings.rating | times: 1.0
          -%}
          <li class="splide__slide" {{ block.shopify_attributes }}>
            <div class="review-card">

              <div class="review-card__content">
                <div class="review-card__stars">
                  {%- for i in (1..5) -%}
                    {%- liquid
                      assign i_f       = i | times: 1.0
                      assign half_mark = i_f | minus: 0.5
                      if b_rating >= i_f
                        assign stype = 'full'
                      elsif b_rating >= half_mark
                        assign stype = 'half'
                      else
                        assign stype = 'empty'
                      endif
                    -%}
                    {%- if stype == 'full' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="{{ star_color }}" stroke="{{ star_color }}" stroke-width="1"/>
                      </svg>
                    {%- elsif stype == 'half' -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                          <linearGradient id="sh-{{ section.id }}-{{ block.id }}-{{ forloop.index }}" x1="0" x2="1" y1="0" y2="0">
                            <stop offset="50%" stop-color="{{ star_color }}"/>
                            <stop offset="50%" stop-color="{{ star_empty }}"/>
                          </linearGradient>
                        </defs>
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#sh-{{ section.id }}-{{ block.id }}-{{ forloop.index }})" stroke="{{ star_color }}" stroke-width="1"/>
                      </svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="{{ star_empty }}" stroke="{{ star_color }}" stroke-width="1"/>
                      </svg>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

                {%- if block.settings.quote != blank -%}
                  <p class="review-card__quote">{{ block.settings.quote }}</p>
                {%- endif -%}

                {%- if block.settings.author != blank -%}
                  <span class="review-card__author">– {{ block.settings.author }}</span>
                {%- endif -%}
              </div>

              {%- if block.settings.image != blank -%}
                <div class="review-card__image">
                  <img
                    src="{{ block.settings.image | image_url: width: 400 }}"
                    alt="{{ block.settings.author | escape }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                </div>
              {%- endif -%}

            </div>
          </li>
        {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>

  {%- if section.settings.show_nav_buttons -%}
    <div class="reviews-slider__nav">
      <button class="reviews-slider__btn" id="reviews-prev-{{ section.id }}" aria-label="Previous review">
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="reviews-slider__btn" id="reviews-next-{{ section.id }}" aria-label="Next review">
        <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
      </button>
    </div>
  {%- endif -%}

</section>

<script src="{{ 'splide.min.js' | asset_url }}"></script>

<script>
(function () {
  var instance = null;

  function initSlider() {
    var el = document.querySelector('#reviews-splide-{{ section.id }}');
    if (!el || typeof Splide === 'undefined') return;
    if (instance) { instance.destroy(); instance = null; }

    var splide = new Splide('#reviews-splide-{{ section.id }}', {
      type: {% if section.settings.loop %}'loop'{% else %}'slide'{% endif %},
      autoWidth: true,
      gap: '{{ section.settings.slides_gap }}px',
      arrows: false,
      pagination: {% if section.settings.show_paginations %}true{% else %}false{% endif %},
      {%- if section.settings.autoplay %}
      autoplay: true,
      interval: {{ section.settings.autoplay_delay }},
      pauseOnHover: false,
      pauseOnFocus: false,
      {%- else %}
      autoplay: false,
      {%- endif %}
    });

    {%- if section.settings.show_nav_buttons %}
    var prevBtn = document.querySelector('#reviews-prev-{{ section.id }}');
    var nextBtn = document.querySelector('#reviews-next-{{ section.id }}');
    if (prevBtn) prevBtn.addEventListener('click', function () { splide.go('<'); });
    if (nextBtn) nextBtn.addEventListener('click', function () { splide.go('>'); });
    {%- endif %}

    splide.mount();
    instance = splide;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSlider);
  } else {
    initSlider();
  }

  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail.sectionId === '{{ section.id }}') initSlider();
  });
})();
</script>

