
 <style>.apex-vip-sale-banner__inner{max-width:100%;margin:auto;padding:0}.apex-vip-sale-banner{width:100%;display:block}.apex-vip-sale-banner__image{display:block;width:100%;height:auto}.apex-vip-sale-banner__inner picture{display:block;width:100%}.section-{{section.id}}{padding-top:{{section.settings.padding_top}}px;padding-bottom:{{section.settings.padding_bottom}}px}@media (max-width:768px){.section-{{section.id}}{padding-top:{{section.settings.padding_top | times:0.5}}px;padding-bottom:{{section.settings.padding_bottom | times:0.5}}px}}{% if section.settings.show_title %}.banner-title{margin-bottom:{{section.settings.title_bottom_space}}px}@media (max-width:767px){.banner-title{margin-bottom:{{section.settings.title_bottom_space_mobile}}px}}{% endif %}{% if section.settings.show_button %}.only-banner-btn-wrapper{margin-block:20px;display:flex}{% endif %}{% if section.settings.show_button_desktop %}@media (min-width:768px){.apex-vip-sale-banner__inner{position:relative}.section-{{section.id}}a.only-banner-btn.m-button.m-button--primary{position:absolute;bottom:11%}}{% endif %}</style>
{%- liquid
assign desktop_img = section.settings.desktop_image
assign mobile_img  = section.settings.mobile_image

assign desktop_src    = desktop_img | image_url: width: 1200
assign desktop_src_sm = desktop_img | image_url: width: 1200
assign desktop_src_xs = desktop_img | image_url: width: 800
assign mobile_src     = mobile_img  | image_url: width: 500
assign mobile_src_sm  = mobile_img  | image_url: width: 480
-%}{%- if mobile_img != blank -%}<link rel="preload" as="image" imagesrcset="{{ mobile_src_sm }} 480w, {{ mobile_src }} 800w" imagesizes="100vw" media="(max-width:767px)" fetchpriority="high">{%- endif -%}{%- if desktop_img != blank -%}<link rel="preload" as="image" imagesrcset="{{ desktop_src_xs }} 800w, {{ desktop_src_sm }} 1200w, {{ desktop_src }} 2000w" imagesizes="100vw" media="(min-width:768px)" fetchpriority="high">{%- endif -%}<section class="apex-vip-sale-banner section-{{ section.id }}{% if section.settings.add_container %} custom-container{% endif %}"><div class="apex-vip-sale-banner__inner">{% if section.settings.show_title %}<h2 class="banner-title" style="text-align: {{ section.settings.title_alignment }};">{{ section.settings.title }}</h2>{% endif %}{% if desktop_img != blank or mobile_img != blank %}<a href="{{ section.settings.url }}"><picture>{%- if mobile_img != blank -%}<source media="(max-width:767px)" srcset="{{ mobile_src_sm }} 480w, {{ mobile_src }} 800w" sizes="100vw" type="image/webp">{%- endif -%}{%- if desktop_img != blank -%}<source media="(min-width:768px)" srcset="{{ desktop_src_xs }} 800w, {{ desktop_src_sm }} 1200w, {{ desktop_src }} 2000w" sizes="100vw" type="image/webp"><img src="{{ desktop_src_sm }}" alt="{{ desktop_img.alt | escape | default: 'Banner' }}" class="apex-vip-sale-banner__image" fetchpriority="high" loading="eager" decoding="async" width="{{ desktop_img.width }}" height="{{ desktop_img.height }}">{%- elsif mobile_img != blank -%}<img src="{{ mobile_src }}" alt="{{ mobile_img.alt | escape | default: 'Banner' }}" class="apex-vip-sale-banner__image" fetchpriority="high" loading="eager" decoding="async" width="{{ mobile_img.width }}" height="{{ mobile_img.height }}">{%- endif -%}</picture></a>{% endif %}{% if section.settings.show_button %}<div class="only-banner-btn-wrapper" style="justify-content: {{ section.settings.btn_alignment }};"><a href="{{ section.settings.button_url }}" class="only-banner-btn m-button m-button--primary">{{- section.settings.button_text -}}</a></div>{% endif %}</div></section>

{% schema %}{"name":"Image only","settings":[{"type":"header","content":"Section Spacing"},{"type":"range","id":"padding_top","label":"Padding Top (px)","min":0,"max":100,"step":1,"default":0},{"type":"range","id":"padding_bottom","label":"Padding Bottom (px)","min":0,"max":100,"step":1,"default":0},{"type":"image_picker","id":"desktop_image","label":"Desktop banner image"},{"type":"image_picker","id":"mobile_image","label":"Mobile banner image"},{"type":"url","id":"url","label":"Please Connect the collection"},{"type":"header","content":"Extra Content Settings"},{"type":"checkbox","id":"add_container","label":"Add container","default":false},{"type":"header","content":"Title Settings"},{"type":"checkbox","id":"show_title","label":"Show title","default":false},{"type":"text","id":"title","label":"Title","default":"VIP Sale","visible_if":"{{ section.settings.show_title }}"},{"type":"text_alignment","id":"title_alignment","label":"Title alignment","default":"center","visible_if":"{{ section.settings.show_title }}"},{"type":"range","id":"title_bottom_space","label":"Title bottom space","min":0,"max":100,"step":5,"unit":"px","default":20,"visible_if":"{{ section.settings.show_title }}"},{"type":"range","id":"title_bottom_space_mobile","label":"Title bottom space (Mobile)","min":0,"max":100,"step":5,"unit":"px","default":15,"visible_if":"{{ section.settings.show_title }}"},{"type":"header","content":"Button Settings"},{"type":"checkbox","id":"show_button","label":"Show button","default":false},{"type":"checkbox","id":"show_button_desktop","label":"Put the button on top of the Banner image","default":false},{"type":"text","id":"button_text","label":"Button text","default":"Shop Now","visible_if":"{{ section.settings.show_button }}"},{"type":"url","id":"button_url","label":"Button link","visible_if":"{{ section.settings.show_button }}"},{"type":"text_alignment","id":"btn_alignment","label":"Button alignment","default":"center","visible_if":"{{ section.settings.show_button }}"}],"presets":[{"name":"Image only"}]}{% endschema %}
