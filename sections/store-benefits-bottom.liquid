
 <style>.store-benefits-bottom{padding-top:{{- section.settings.pt -}}px;padding-bottom:{{- section.settings.pb -}}px}.store-benefit-text{font-size:{{- section.settings.font_size -}}px}.store-benefit-icon svg path{fill:{{section.settings.icon_color}}}.store-benefits-active .splide__track{overflow:hidden}.store-benefits-active .splide__slide{min-width:0}.store-benefit{width:100%;text-align:center}.store-benefit-text{white-space:normal;word-break:normal}@media only screen and (max-width:768px){.store-benefits-bottom{padding-top:{{- section.settings.ptm -}}px;padding-bottom:{{- section.settings.pbm -}}px}}.store-benefits-active .splide__list{align-items:stretch!important}.store-benefits-active .splide__slide{display:flex;justify-content:center}.store-benefits-active .splide{visibility:visible!important}</style>
<div class="store-benefits-bottom m-color-{{ section.settings.color_scheme }}"><div class="rs-container"><div class="store-benefits-row"><div id="store-benefits-{{ section.id }}" class="splide store-benefits-active"><div class="splide__track"><ul class="splide__list">{% for block in section.blocks %}<li class="splide__slide"><div class="store-benefit"><div class="store-benefit-icon">{%- if block.settings['svg-code'] != blank -%}{{ block.settings['svg-code'] | replace: ' width=', ' ' | replace: ' height=', ' ' }}{% else %}{% render 'store-benefit-icons', icon: block.settings.icon %}{% endif %}</div><p class="store-benefit-text">{{ block.settings.store_benefit_text }}</p></div></li>{% endfor %}</ul></div></div></div></div></div>
<script>function initSplideBenefits(){var e=document.querySelector("#store-benefits-{{ section.id }}");if(!e||"undefined"==typeof Splide){setTimeout(initSplideBenefits,200);return}if(e.classList.contains("is-initialized"))return;new Splide(e,{type:"loop",perPage:4,perMove:1,gap:"12px",speed:600,easing:"cubic-bezier(0.25, 1, 0.5, 1)",autoplay:true,interval:4000,pauseOnHover:false,arrows:false,pagination:false,drag:true,focus:0,trimSpace:true,flickPower:400,flickMaxPages:1,breakpoints:{1024:{perPage:3,gap:"12px",focus:0,trimSpace:true},768:{perPage:2,gap:"10px",focus:0,trimSpace:true},480:{perPage:1,gap:"10px",focus:0,trimSpace:true}}}).mount(),e.classList.add("is-initialized")}document.addEventListener("DOMContentLoaded",initSplideBenefits),document.addEventListener("shopify:section:load",initSplideBenefits);</script>
{% schema %}{"name":"APEX Store Benefit Bottom","settings":[{"type":"color_scheme","id":"color_scheme","label":"Color scheme"},{"type":"color","id":"icon_color","label":"Icon Color","default":"#000000"},{"type":"range","id":"pt","label":"Padding Top","default":50,"min":0,"max":100,"step":1},{"type":"range","id":"pb","label":"Padding Bottom","default":50,"min":0,"max":100,"step":1},{"type":"range","id":"font_size","label":"Font Size","default":14,"min":10,"max":50,"step":1},{"type":"range","id":"ptm","min":0,"max":100,"step":1,"unit":"px","label":"Padding Top (Mobile)","default":50},{"type":"range","id":"pbm","min":0,"max":100,"step":1,"unit":"px","label":"Padding Bottom (Mobile)","default":50}],"blocks":[{"name":"Benefit Item","type":"item","settings":[{"type":"select","id":"icon","label":"Select an Icon","options":[{"value":"none","label":"Select an Icon"},{"value":"icon1","label":"Icon 1"},{"value":"icon2","label":"Icon 2"},{"value":"icon3","label":"Icon 3"},{"value":"icon4","label":"Icon 4"},{"value":"icon5","label":"Icon 5"}],"default":"none"},{"type":"html","id":"svg-code","label":"SVG icon code","info":"Learn more about adding your own SVG icons [here](https://support.safeasmilk.co/article/236-general-add-custom-svg-icons-to-your-theme)."},{"type":"text","id":"store_benefit_text","label":"Benefit Text","default":"Free Shipping"}]}],"presets":[{"name":"APEX Store Benefit Bottom","settings":{}}]}{% endschema %}
