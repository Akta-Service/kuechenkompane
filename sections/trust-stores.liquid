<style>#trust-stores-{{ section.id }}{box-sizing:border-box;width:100%;padding:58px 0;background:#fff}#trust-stores-{{ section.id }} .ts-inner{display:flex;justify-content:center;margin:0 auto;align-items:center;gap:12px}#trust-stores-{{ section.id }} .ts-inner .ts-line{width:100%;height:1px;background:#bdbbbb;display:none;margin-bottom:32px}#trust-stores-{{ section.id }} .ts-trust{width:fit-content}#trust-stores-{{ section.id }} .ts-trust-text{display:flex;align-items:center;gap:10px;color:var(--dark-green)}#trust-stores-{{ section.id }} span.ts-trust-text{font-size:17px}span.ts-trust-star svg,span.ts-trust-logo svg{height:28px;width:fit-content}#trust-stores-{{ section.id }} span.ts-trust-number{font-size:14px;text-decoration:underline;white-space:nowrap}#trust-stores-{{ section.id }} .ts-trust-text:hover span.ts-trust-number{text-decoration:none}@media (max-width:1199px){#trust-stores-{{ section.id }} .ts-inner{margin:0}}@media (max-width:767px){#trust-stores-{{ section.id }}{padding:20px 0}#trust-stores-{{ section.id }} .ts-inner{justify-content:space-between;margin:0}#trust-stores-{{ section.id }} .ts-inner .ts-line{display:inline-block}#trust-stores-{{ section.id }} .ts-trust{flex:1}#trust-stores-{{ section.id }} .ts-trust-text{flex-direction:column}}</style>

<section id="trust-stores-{{ section.id }}" class="trust-stores" role="region" aria-label="Trust and retailers"><div class="custom-container"><div class="ts-inner"><span class="ts-line"></span><div class="ts-trust">{% if section.settings.trust_text != blank %}<a href="{{ section.settings.trust_link }}" class="ts-trust-text"><span class="ts-trust-text">{{ section.settings.trust_text1 }}</span><span class="ts-trust-star">{{ section.settings.trust_star }}</span><span class="ts-trust-number">{{ section.settings.trust_text }}</span><span class="ts-trust-logo">{{ section.settings.trust_review }}</span></a>{% endif %}</div><span class="ts-line"></span></div></div></section>

{% schema %}{"name":"Trust & Retailers Row","settings":[{"type":"url","id":"trust_link","label":"Trust / review URL"},{"type":"text","id":"trust_text1","label":"Trust / review text","default":"Excellent"},{"type":"html","id":"trust_star","label":"Trust / review Sart"},{"type":"text","id":"trust_text","label":"Trust / review text","default":"3,951 reviews on"},{"type":"html","id":"trust_review","label":"Trust / review Logo"}],"presets":[{"name":"Trust & Retailers Row","category":"Footer / Trust"}]}{% endschema %}