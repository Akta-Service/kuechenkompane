<style>#features-row-{{ section.id }} .features-grid{display:grid;gap:28px;align-items:start;justify-items:center;background:#eeeff8;padding:56px 0 60px}#features-row-{{ section.id }} .features-grid.cols-3{grid-template-columns:repeat(3,1fr)}#features-row-{{ section.id }} .features-grid.cols-4{grid-template-columns:repeat(4,1fr)}#features-row-{{ section.id }} .features-grid.cols-5{grid-template-columns:repeat(5,1fr)}#features-row-{{ section.id }} .features-grid.cols-6{grid-template-columns:repeat(6,1fr)}#features-row-{{ section.id }} .features-grid.cols-auto{grid-template-columns:repeat(auto-fit,minmax(160px,1fr))}#features-row-{{ section.id }} .feature-card{display:flex;flex-direction:column;align-items:center;text-align:center;gap:12px}#features-row-{{ section.id }} .feature-icon{width:64px;height:64px;display:flex;align-items:center;justify-content:center}#features-row-{{ section.id }} .feature-icon img{width:100%;height:100%;object-fit:contain}#features-row-{{ section.id }} .icon-svg{width:48px;height:48px;display:inline-block}span.icon-svg svg path{stroke:#324a34}#features-row-{{ section.id }} .icon-dot{width:12px;height:12px;background:#c76aff;border-radius:50%;display:inline-block}#features-row-{{ section.id }} .feature-title :is(p,strong,em,span,a){margin:0;padding:0;line-height:1.2;letter-spacing:-.02em;font-size:18px;font-weight:400}#features-row-{{ section.id }} .feature-title{font-weight:700;font-size:15px;color:#111;line-height:1.3}#features-row-{{ section.id }} .feature-subtitle{font-size:13px;color:#222;line-height:1.3}@media (max-width:999px){#features-row-{{ section.id }} .custom-container{padding:0}#features-row-{{ section.id }} .features-grid{grid-template-columns:repeat(3,1fr)!important;padding:36px 20px 36px}}@media (max-width:767px){#features-row-{{ section.id }} .features-grid{padding:36px 20px 36px;gap:0;row-gap:20px}#features-row-{{ section.id }} .feature-card{border-right:1px dotted #bdbbbb;padding:0 8px;width:100%;height:100%}#features-row-{{ section.id }} .feature-card:nth-child(3),#features-row-{{ section.id }} .feature-card:nth-child(6){border-right:none}#features-row-{{ section.id }} .feature-icon,#features-row-{{ section.id }} .icon-svg svg{width:50px;height:50px}#features-row-{{ section.id }} .feature-title :is(p,strong,em,span,a){font-size:12px}#features-row-{{ section.id }} .feature-subtitle{font-size:12px}}@media (max-width:575px){#features-row-{{ section.id }} .feature-title :is(p,strong,em,span,a){font-size:10px}#features-row-{{ section.id }} .feature-subtitle{font-size:10px}}</style>

<section id="features-row-{{ section.id }}" class="features-row" role="region" aria-label="Product features"><div class="custom-container"><div class="features-grid {{ section.settings.columns_class }}">{% for block in section.blocks %}<div class="feature-card" role="group" {{ block.shopify_attributes }}><div class="feature-icon">{% if block.settings.icon_image %}<img src="{{ block.settings.icon_image | img_url: '100x' }}" alt="{{ block.settings.icon_alt | escape }}" loading="lazy">{% elsif block.settings.icon_svg != blank %}<span class="icon-svg">{{ block.settings.icon_svg }}</span>{% else %}<span class="icon-dot"></span>{% endif %}</div><div class="feature-text"><div class="feature-title">{{ block.settings.title }}</div>{% if block.settings.subtitle != blank %}<div class="feature-subtitle">{{ block.settings.subtitle }}</div>{% endif %}</div></div>{% endfor %}</div></div></section>

{% schema %}{"name":"Feature Row","settings":[{"type":"select","id":"columns_class","label":"Columns layout","options":[{"value":"cols-3","label":"3 columns"},{"value":"cols-4","label":"4 columns"},{"value":"cols-5","label":"5 columns"},{"value":"cols-6","label":"6 columns"},{"value":"cols-auto","label":"Auto-fit"}],"default":"cols-6"}],"blocks":[{"type":"feature","name":"Feature","settings":[{"type":"image_picker","id":"icon_image","label":"Icon image (optional)"},{"type":"textarea","id":"icon_svg","label":"Icon SVG (optional)"},{"type":"text","id":"icon_alt","label":"Icon alt text"},{"type":"richtext","id":"title","label":"Title (rich text)","default":"<p>Feature title</p>"},{"type":"text","id":"subtitle","label":"Subtitle"}]}],"presets":[{"name":"Feature Row","category":"Sections"}]}{% endschema %}