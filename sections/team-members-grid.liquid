<style>
  #team-members-grid-{{ section.id }} {
    background: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #team-members-grid-{{ section.id }} .team-members-grid-heading {
    text-align: center;
    margin: 0 0 14px;
    font-size: 21.6px;
    line-height: 1.7;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
  }

  #team-members-grid-{{ section.id }} .team-members-grid-description {
    max-width: 700px;
    margin: 0 auto 38px;
    text-align: center;
    font-size: 16px;
    line-height: 1.8;
    color: {{ section.settings.text_color }};
  }

  #team-members-grid-{{ section.id }} .team-members-grid-description p {
    margin: 0;
  }

  #team-members-grid-{{ section.id }} .team-members-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  #team-members-grid-{{ section.id }} .team-member-card {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: 24px 16px;
    text-align: center;
    min-height: 100%;
    min-width: 0;
  }

  #team-members-grid-{{ section.id }} .team-member-avatar-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 14px;
  }

  #team-members-grid-{{ section.id }} .team-member-avatar {
    width: 90px;
    height: 90px;
    border-radius: 999px;
    background: linear-gradient(135deg, #dce8dc, #ccdacc);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #team-members-grid-{{ section.id }} .team-member-avatar-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #team-members-grid-{{ section.id }} .team-member-avatar-icon {
    width: 34px;
    height: 34px;
    color: {{ section.settings.avatar_icon_color }};
  }

  #team-members-grid-{{ section.id }} .team-member-name {
    margin: 0 0 5px;
    font-size: 15.2px;
    line-height: 1.7;
    font-weight: 700;
    color: {{ section.settings.name_color }};
  }

  #team-members-grid-{{ section.id }} .team-member-role {
    font-size: 13.28px;
    line-height: 1.65;
    color: {{ section.settings.role_color }};
  }

  @media screen and (max-width: 1199px) {
     #team-members-grid-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
  }

  @media screen and (max-width: 639px) {
    #team-members-grid-{{ section.id }} .team-members-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<section id="team-members-grid-{{ section.id }}" class="team-members-grid-section">
  <div class="custom-container">
    {% if section.settings.heading != blank %}
      <h2 class="team-members-grid-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="team-members-grid-description rte">
        {{ section.settings.description }}
      </div>
    {% endif %}

    <div class="team-members-grid">
      {% for block in section.blocks %}
        {% if block.type == 'member' %}
          <div class="team-member-card" {{ block.shopify_attributes }}>
            <div class="team-member-avatar-wrap">
              {% if block.settings.image != blank %}
                <div class="team-member-avatar has-image">
                  {{
                    block.settings.image
                    | image_url: width: 300
                    | image_tag: loading: 'lazy', alt: block.settings.name, class: 'team-member-avatar-image'
                  }}
                </div>
              {% else %}
                <div class="team-member-avatar">
                  <svg
                    class="team-member-avatar-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.7"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6.75a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                  </svg>
                </div>
              {% endif %}
            </div>

            {% if block.settings.name != blank %}
              <h3 class="team-member-name">{{ block.settings.name }}</h3>
            {% endif %}

            {% if block.settings.role != blank %}
              <div class="team-member-role">{{ block.settings.role }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Team members grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Die Menschen hinter Küchenkompane"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Wir sind ein kleines Team mit hohem Anspruch. Jeder von uns trägt dazu bei, dass Produkte und Service das halten, was wir versprechen.</p>"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description color",
      "default": "#2e2e2e"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#fcfcfc"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#e6e6e6"
    },
    {
      "type": "color",
      "id": "avatar_icon_color",
      "label": "Avatar icon color",
      "default": "#7a9a76"
    },
    {
      "type": "color",
      "id": "name_color",
      "label": "Name color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "role_color",
      "label": "Role color",
      "default": "#444444"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 56
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding top",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Team member",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Member image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Mats Radzuweit"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Gründer & Geschäftsführer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team members grid",
      "blocks": [
        {
          "type": "member"
        },
        {
          "type": "member"
        },
        {
          "type": "member"
        },
        {
          "type": "member"
        }
      ]
    }
  ]
}
{% endschema %}
