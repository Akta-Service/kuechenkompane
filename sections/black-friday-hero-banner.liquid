<style>
  /* ===================================
     BLACK FRIDAY HERO (CSS FULLY NESTED)
     =================================== */

  #bf-hero-banner-{{ section.id }} .bf-hero-banner {
    position: relative;
    width: 100%;
    height: 440px;
    height: 750px;
    overflow: hidden;
    background: #0b0b0b;
    color: #fff;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #bf-hero-banner-{{ section.id }} .bf-hero-inner {
    width: 100%;
  }

  /* Background images (img tags) */
  #bf-hero-banner-{{ section.id }} .bf-bg {
    {% comment %} position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    z-index: -1; {% endcomment %}
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    display: block;
    z-index: -1;
  }

  #bf-hero-banner-{{ section.id }} .bf-bg-mobile {
    display: none;
  }

  /* Hero content */
  #bf-hero-banner-{{ section.id }} .bf-content {
    text-align: center;
    pointer-events: none;
  }

  #bf-hero-banner-{{ section.id }} .bf-eyebrow {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: normal;
    pointer-events: auto;
    color: #ffffff;
    text-transform: uppercase;
    width: fit-content;
    margin: 0 auto 6px;
  }

  #bf-hero-banner-{{ section.id }} .bf-title {
    margin: 0 0 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  #bf-hero-banner-{{ section.id }} .bf-title > span {
    pointer-events: auto;
    letter-spacing: normal;
    font-size: 90px;
    font-weight: 400;
    font-family: "Bebas Neue", sans-serif;
    line-height: 1;
    color: #ffffff;
  }

  #bf-hero-banner-{{ section.id }} .bf-subtitle {
    font-size: 30px;
    font-weight: 700;
    margin-top: 8px;
    pointer-events: auto;
  }

  #bf-hero-banner-{{ section.id }} .bf-cta {
    display: inline-block;
    letter-spacing: normal;
    padding: 15px 60px;
    font-size: 20px;
    background: #f98727;
    color: #fff;
    text-decoration: none;
    font-weight: 400;
    transition: all 0.3s;
    pointer-events: auto;
  }

  /* Footer (caption + social icons) */
  #bf-hero-banner-{{ section.id }} .bf-footer {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 60px auto 40px;
    margin-bottom: 0;
    z-index: 6;
    gap: 12px;
  }

  #bf-hero-banner-{{ section.id }} .bf-caption {
    font-size: 24px;
    pointer-events: auto;
    text-transform: capitalize;
    letter-spacing: normal;
    line-height: 26.4px;
  }

  #bf-hero-banner-{{ section.id }} .bf-socials {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  #bf-hero-banner-{{ section.id }} .bf-social {
    color: rgba(255,255,255,0.92);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
  }

  /* Responsive */

  @media (max-width: 1440px) {
     #bf-hero-banner-{{ section.id }} .bf-hero-banner {   
          height: 700px;      
      }

  }
  @media (max-width: 1300px) {
     #bf-hero-banner-{{ section.id }} .bf-hero-banner {   
          height: 600px;      
      }

  }
  @media (max-width: 1023px) {
    #bf-hero-banner-{{ section.id }}.custom-container {
      padding: 0;
    }

    #bf-hero-banner-{{ section.id }} .bf-bg-desktop { display: none; }
    #bf-hero-banner-{{ section.id }} .bf-bg-mobile { display: block; }

    #bf-hero-banner-{{ section.id }} .bf-title {
      flex-direction: column;
      margin: 0 auto 24px;
    }

    #bf-hero-banner-{{ section.id }} .bf-title > span {
      font-size: 100px;
      line-height: 0.9;
    }

    #bf-hero-banner-{{ section.id }} .bf-title > span:last-child {
      font-size: 48px;
    }

  }
  @media (max-width: 767px) {

    #bf-hero-banner-{{ section.id }} .bf-title > span {
      font-size: 90px;
    }
    #bf-hero-banner-{{ section.id }} .bf-footer {
      justify-content: center;
      gap: 16px;
      flex-direction: column;
      text-align: center;
      padding: 0 15px;
    }
      #bf-hero-banner-{{ section.id }} .bf-hero-banner {   
          height: 600px;      
      }
  }
  @media (max-width: 575px) {
    #bf-hero-banner-{{ section.id }} .bf-title > span {
      font-size: 80px;
    }
      #bf-hero-banner-{{ section.id }} .bf-cta {
      padding: 12px 30px;
      font-size: 18px;
    }
     #bf-hero-banner-{{ section.id }} .bf-hero-banner {   
          height: 500px;      
      }
  }
  @media (max-width: 399px) {
    #bf-hero-banner-{{ section.id }} .bf-title > span {
      font-size: 70px;
    }
    #bf-hero-banner-{{ section.id }} .bf-title > span:last-child {
      font-size: 40px;
    }
  }
</style>

<div class="" id="bf-hero-banner-{{ section.id }}" role="region" aria-label="Black Friday hero">
  <section class="bf-hero-banner">
    <div class="bf-hero-inner">
      <!-- Desktop background image -->
      <a href="{{ section.settings.url }}">
        <img
          src="{{ section.settings.desktop_image | img_url: 'master' }}"
          alt="{{ section.settings.desktop_alt | default: 'Black Friday background' }}"
          class="bf-bg bf-bg-desktop"
          loading="lazy"
        >

        <!-- Mobile background image -->
        <img
          src="{{ section.settings.mobile_image | img_url: 'master' }}"
          alt="{{ section.settings.mobile_alt | default: 'Black Friday background mobile' }}"
          class="bf-bg bf-bg-mobile"
          loading="lazy"
        >
      </a>

      <!-- Centered hero content -->
      <div class="bf-content" role="article">
        {% if section.settings.eyebrow_text != blank %}
          <div class="bf-eyebrow">{{ section.settings.eyebrow_text }}</div>
        {% endif %}

        {% if section.settings.main_heading != blank %}
          <h1 class="bf-title">
            <span>{{ section.settings.main_heading }}</span><span>{{ section.settings.last_heading }}</span>
          </h1>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <div class="bf-subtitle">{{ section.settings.subheading }}</div>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a
            href="{{ section.settings.button_link }}"
            class="bf-cta"
            {% if section.settings.open_in_new_tab %}
              target="_blank" rel="noopener noreferrer"
            {% endif %}
          >
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </section>
  <!-- footer row with caption left and social icons right -->
  {% comment %}
    <div class="bf-footer">
      <div class="bf-caption">
        {{ section.settings.caption_text }}
      </div>

      <div class="bf-socials" aria-label="Social links">
        {% if section.settings.instagram_url != blank %}
          <a
            href="{{ section.settings.instagram_url }}"
            class="bf-social"
            target="_blank"
            rel="noopener"
            aria-label="Instagram"
          >
            <!-- Instagram SVG -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 7.5C3 6.30653 3.47411 5.16193 4.31802 4.31802C5.16193 3.47411 6.30653 3 7.5 3H16.5C17.6935 3 18.8381 3.47411 19.682 4.31802C20.5259 5.16193 21 6.30653 21 7.5V16.5C21 17.6935 20.5259 18.8381 19.682 19.682C18.8381 20.5259 17.6935 21 16.5 21H7.5C6.30653 21 5.16193 20.5259 4.31802 19.682C3.47411 18.8381 3 17.6935 3 16.5V7.5Z" stroke="#999999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path><path d="M8.625 12C8.625 12.8951 8.98058 13.7536 9.61351 14.3865C10.2464 15.0194 11.1049 15.375 12 15.375C12.8951 15.375 13.7536 15.0194 14.3865 14.3865C15.0194 13.7536 15.375 12.8951 15.375 12C15.375 11.1049 15.0194 10.2464 14.3865 9.61351C13.7536 8.98058 12.8951 8.625 12 8.625C11.1049 8.625 10.2464 8.98058 9.61351 9.61351C8.98058 10.2464 8.625 11.1049 8.625 12Z" stroke="#999999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path><path d="M17.0625 6.9375V6.94875" stroke="#999999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.tiktok_url != blank %}
          <a
            href="{{ section.settings.tiktok_url }}"
            class="bf-social"
            target="_blank"
            rel="noopener"
            aria-label="TikTok"
          >
            <!-- TikTok-ish SVG (simple note) -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M19.0794 7.21685C18.1627 7.02461 17.3327 6.55035 16.7102 5.8632C16.0878 5.17606 15.7055 4.31195 15.619 3.39685V3H12.457V15.3032C12.455 15.8479 12.279 16.3783 11.9537 16.8198C11.6285 17.2614 11.1702 17.5919 10.6435 17.765C10.1167 17.9381 9.54785 17.945 9.01687 17.7848C8.48588 17.6245 8.01945 17.3052 7.68312 16.8717C7.34156 16.4309 7.15209 15.8949 7.14218 15.3415C7.13228 14.788 7.30245 14.2458 7.62801 13.7936C7.95358 13.3413 8.41763 13.0025 8.95285 12.8262C9.48808 12.6499 10.0667 12.6454 10.6047 12.8132V9.66363C9.4049 9.50102 8.18328 9.71014 7.11069 10.2618C6.0381 10.8134 5.16819 11.6799 4.62265 12.74C4.0771 13.8002 3.8832 15.0011 4.06807 16.1746C4.25294 17.3482 4.80734 18.4357 5.65371 19.2852C6.46084 20.0948 7.49577 20.6503 8.62637 20.8808C9.75697 21.1112 10.932 21.0061 12.0014 20.5789C13.0708 20.1516 13.9861 19.4217 14.6304 18.4822C15.2748 17.5427 15.6189 16.4362 15.619 15.3041V9.01751C16.8969 9.9132 18.4291 10.3935 20 10.3907V7.31044C19.6906 7.31081 19.3821 7.27944 19.0794 7.21685Z" fill="#999999"></path>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.facebook_url != blank %}
          <a
            href="{{ section.settings.facebook_url }}"
            class="bf-social"
            target="_blank"
            rel="noopener"
            aria-label="Facebook"
          >
            <!-- Facebook SVG -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M16.1334 12.9503L16.6357 9.81988H13.6775V7.63975C13.6775 6.74534 14.0124 6.07453 15.352 6.07453H16.8031V3.2236C16.0217 3.1118 15.1287 3 14.3473 3C11.7799 3 9.99382 4.56522 9.99382 7.36025V9.81988H7.20312V12.9503H9.99382V20.8323C10.6078 20.9441 11.2217 21 11.8357 21C12.4496 21 13.0636 20.9441 13.6775 20.8323V12.9503H16.1334Z" fill="#999999"></path>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>
  {% endcomment %}
</div>

{% schema %}
{
  "name": "Black Friday Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop background image"
    },
    {
      "type": "text",
      "id": "desktop_alt",
      "label": "Desktop image alt text",
      "default": "Black Friday background"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Please Connect the collection"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile background image"
    },
    {
      "type": "text",
      "id": "mobile_alt",
      "label": "Mobile image alt text",
      "default": "Black Friday background mobile"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow / small top text",
      "default": "BLACK FRIDAY SALE"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main heading",
      "default": "50% OFF"
    },
    {
      "type": "text",
      "id": "last_heading",
      "label": "Heading Last Text",
      "default": "EVERYTHING"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (smaller under headline)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button URL",
      "default": "/collections/all"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open button in new tab",
      "default": false
    },
    {
      "type": "text",
      "id": "caption_text",
      "label": "Caption text (footer left)",
      "default": "Loved by our community of 750.000+ people"
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "text",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "text",
      "id": "facebook_url",
      "label": "Facebook URL"
    }
  ],
  "presets": [
    {
      "name": "Black Friday Hero Banner",
      "category": "Hero Sections"
    }
  ]
}
{% endschema %}
