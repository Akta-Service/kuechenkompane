{% assign si = section.id %}
{% assign ss = section.settings %}

<div class="floow-comparison-section-{{ si }}">
  <div class="content-wrapper-{{ si }} floow-comparison-table">
    {% content_for 'blocks' %}
  </div>
</div>

<style>
  {% if ss.show_only_in_editor %}
    #shopify-section-{{ si }} {
      display: none;
      {% if request.design_mode %}
        display: block;
      {% endif %}
    }
  {% endif %}

  .content-wrapper-{{ si }} {
    margin-top: {{ ss.margin_top }}px;
    margin-bottom: {{ ss.margin_bottom }}px;
    padding: {{ ss.padding_top }}px {{ ss.padding_right }}px {{ ss.padding_bottom }}px {{ ss.padding_left }}px;
    background-color: {{ ss.bg_color }};
    border-radius: {{ ss.border_radius }}px;
    display: flex;
    flex-direction: {{ ss.flex-direction }};
    flex-wrap: {{ ss.flex-wrap }};
    justify-content: {{ ss.justify-content }};
    align-items: {{ ss.align-items }};
    gap: {{ ss.gap }}px;
  }
  
  @media(max-width: 768px) {
    .content-wrapper-{{ si }} {
      padding: {{ ss.padding_top_mobile }}px {{ ss.padding_right_mobile }}px {{ ss.padding_bottom_mobile }}px {{ ss.padding_left_mobile }}px;
      flex-direction: {{ ss.flex-direction-mobile }};
      flex-wrap: {{ ss.flex-wrap-mobile }};
      justify-content: {{ ss.justify-content-mobile }};
      align-items: {{ ss.align-items-mobile }};
      gap: {{ ss.gap-mobile }}px;
    }
  }
  
  .section:has(#floow-comparison-table) {
    padding-block-start: 0px !important;
    padding-block-end: 0px !important;
    --calculated-section-spacing-inline: 0px !important;
    padding: 0px;
  }
</style>

{% schema %}
{
  "name": "Floow Comparison Table",
  "presets": [
    {
      "name": "Floow Comp Table & Image",
      "blocks": [
        {
          "type": "_floow-table-group",
          "blocks": [
            {
              "type": "_floow-image",
              "settings": {
                "radius": 20,
                "radius_mobile": 20,
                "margin_top_mobile": -60
              }
            },
            {
              "type": "_floow-heading",
              "settings": {
                "heading": "Überschrift",
                "color": "#ffffff"
              }
            },
            {
              "type": "_floow-text",
              "settings": {
                "text": "<p>Hier stehen Informationen.</p> <p>Hier stehen Informationen. Hier stehen Informationen.</p>",
                "font_color": "#ffffff",
                "font_size": 15,
                "alignment": "center"
              }
            }
          ]
        },
        {
          "type": "_floow-table-group",
          "blocks": [
            {
              "type": "_floow-table",
              "settings": {
                "border_radius": 15,
                "bg_color": "#ffffff",
                "padding": 10,
                "padding_mobile": 10
              },
              "blocks": [
                {
                  "type": "_floow-table-row",
                  "blocks": [
                    {
                      "type": "_floow-table-cell",
                      "settings": {
                        "bg_color": "#D0F6DF",
                        "border_radius_top_left": 8,
                        "border_radius_top_right": 8
                      }
                    },
                    {
                      "type": "_floow-table-cell"
                    }
                  ]
                },
                {
                  "type": "_floow-table-row",
                  "blocks": [
                    {
                      "type": "_floow-table-cell",
                      "settings": {
                        "bg_color": "#D0F6DF",
                        "border_radius_bottom_left": 8,
                        "border_radius_bottom_right": 8
                      }
                    },
                    {
                      "type": "_floow-table-cell"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "show_only_in_editor",
      "label": "Show Only In Editor"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#002949"
    },
    {
      "type": "range",
      "id": "border_radius",
