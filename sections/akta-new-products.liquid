<style>.akta-products-section{padding:60px 0;position:relative;background:#eeeff8;overflow:hidden;}.akta-container{max-width:1560px;margin-right:auto;margin-left:auto;padding-right:60px;padding-left:60px;position:relative;}.akta-title{font-size:20px;font-weight:600;margin:0 0 20px;}.akta-slide{height:auto;display:flex;}.akta-product-card{text-align:center;background:#fff;width:100%;}.akta-product-image{position:relative;}.akta-product-image img{width:100%;height:auto;display:block;}.akta-label{position:absolute;left:15px;top:15px;background:#87a8c2;color:#fff;padding:8px 15px;border-radius:20px;font-size:12px;font-weight:600;line-height:1;}.akta-product-info{padding:20px 10px;}.akta-product-card-title a{font-weight:500;margin:6px 0 4px;color:#000;font-size:16px;transition:all .3s;text-decoration:none;}.akta-product-price{margin-top:5px;}.akta-sale{font-weight:700;margin-top:6px;font-size:15px;}.akta-compare{color:#999;text-decoration:line-through;font-weight:500;margin-left:6px;font-size:13px;}.akta-vat{font-size:12px;color:#777;margin-top:4px;}.akta-bottom-btn{text-align:center;margin-top:35px;}.akta-view-all{display:inline-block;letter-spacing:normal;font-size:18px;background:#f98727;color:#fff;text-decoration:none;padding:12px 30px;font-weight:500;transition:all 0.3s;}.akta-{{section.id}} .splide__arrow{width:35px;height:35px;border-radius:100%;background:rgb(164 164 164 / 63%);display:flex;align-items:center;justify-content:center;cursor:pointer;border:none!important;position:absolute;top:50%;transform:translateY(-50%);z-index:10;transition:0.3s;opacity:1!important;}.akta-{{section.id}} .splide__arrow:disabled{opacity:0.3!important;}.akta-{{section.id}} .splide__arrow svg{width:25px;height:25px;color:#000;fill:none!important;}.akta-{{section.id}} .splide__arrow--prev svg{transform:scaleX(1)!important;}.akta-{{section.id}} .splide__arrow svg path{fill:none!important;}.akta-{{section.id}} .splide__arrow--prev{left:-40px!important;}.akta-{{section.id}} .splide__arrow--next{right:-40px!important;}.akta-splide .splide__list{display:flex;list-style:none;padding:0;margin:0;}.akta-splide .splide__track{overflow:hidden;}@media screen and (max-width:1279px){.akta-container{padding-right:40px;padding-left:40px;}}@media screen and (max-width:767px){.akta-container{padding-right:20px;padding-left:20px;}.akta-products-section{padding:40px 0;}.akta-{{section.id}} .splide__arrow--prev{left:-10px!important;}.akta-{{section.id}} .splide__arrow--next{right:-10px!important;}}</style>
{% for product in section.settings.products limit: 2 %}{% if product.featured_image %}<link rel="preload" as="image" href="{{ product.featured_image | image_url: width: 600 }}" imagesrcset="{{ product.featured_image | image_url: width: 300 }} 300w, {{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w" imagesizes="(max-width: 768px) 100vw, 25vw">{% endif %}{% endfor %}<section class="akta-products-section akta-{{ section.id }}"><div class="akta-container"><h2 class="akta-title">{{ section.settings.title }}</h2><div class="splide akta-splide" id="akta-splide-{{ section.id }}"><div class="splide__track"><ul class="splide__list">{% for product in section.settings.products %}<li class="splide__slide akta-slide"><div class="akta-product-card"><div class="akta-product-image"><a href="{{ product.url }}" class="akta-product-image-link"><img src="{{ product.featured_image | image_url: width: 100 }}" srcset="{{ product.featured_image | image_url: width: 100 }} 300w,{{ product.featured_image | image_url: width: 600 }} 600w,{{ product.featured_image | image_url: width: 900 }} 900w" sizes="(max-width: 768px) 100vw, 25vw" width="600" height="600" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="{% if forloop.index <= 4 %}eager{% else %}lazy{% endif %}" fetchpriority="{% if forloop.index <= 2 %}high{% else %}auto{% endif %}" decoding="{% if forloop.index <= 4 %}sync{% else %}async{% endif %}"></a><span class="akta-label">{{ section.settings.tag }}</span></div><div class="akta-product-info"><h3 class="akta-product-card-title"><a href="{{ product.url }}">{{ product.title }}</a></h3><div class="akta-product-price">{% if product.compare_at_price > product.price %}<span class="akta-sale">{{ product.price | money }}</span><span class="akta-compare">{{ product.compare_at_price | money }}</span>{% else %}<span>{{ product.price | money }}</span>{% endif %}</div>{% if section.settings.vat_text != blank %}<p class="akta-vat">{{ section.settings.vat_text }}</p>{% endif %}</div></div></li>{% endfor %}</ul></div><div class="splide__arrows"><button class="akta-nav-btn akta-prev splide__arrow splide__arrow--prev" aria-label="Previous slide"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg></button><button class="akta-nav-btn akta-next splide__arrow splide__arrow--next" aria-label="Next slide"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></button></div></div>{% if section.settings.btn_Url != blank %}<div class="akta-bottom-btn"><a href="{{ section.settings.btn_Url }}" class="akta-view-all">{{ section.settings.btn_text }}</a></div>{% endif %}</div></section><script>(function () {function initSplide() {const el = document.querySelector('#akta-splide-{{ section.id }}');if (!el || el.classList.contains('is-initialized')) return;if (typeof Splide === 'undefined') {setTimeout(initSplide, 100);return;}const splide = new Splide(el, {type             : 'slide',perPage          : 4,perMove          : 1,gap              : '16px',speed            : 500,arrows           : true,pagination       : false,lazyLoad         : false,easing           : 'cubic-bezier(0.25, 1, 0.5, 1)',waitForTransition: false,updateOnMove     : true,touchAngle       : 30,touchPower       : 600,breakpoints: {1280: {perPage: 4,gap    : 16,},1024: {perPage      : 3,gap          : 16,drag         : 'free',snap         : true,flickPower   : 400,flickMaxPages: 1,},768: {perPage      : 2,gap          : 16,drag         : 'free',snap         : true,flickPower   : 400,flickMaxPages: 1,},480: {perPage      : 1,gap          : 16,drag         : 'free',snap         : true,flickPower   : 400,flickMaxPages: 1,}}});splide.mount();el.classList.add('is-initialized');}if (document.readyState === 'loading') {document.addEventListener('DOMContentLoaded', initSplide);} else {initSplide();}document.addEventListener('shopify:section:load', function(e) {if (e.target.querySelector('#akta-splide-{{ section.id }}')) {initSplide();}});})();</script>
{% schema %}{"name":"Akta New Products Slider","settings":[{"type":"text","id":"title","label":"Section Title","default":"NEW PRODUCTS"},{"type":"header","content":"Product Settings"},{"type":"product_list","id":"products","label":"Select Products","limit":12},{"type":"header","content":"Product Tag Settings"},{"type":"text","id":"tag","label":"Product Tag Label","default":"NEW","info":"This text will appear in the blue badge on the top-left of the image."},{"type":"header","content":"Product Vat Text Settings"},{"type":"text","id":"vat_text","label":"VAT/Tax Text","default":"Including tax + shipping"},{"type":"header","content":"Button Settings"},{"type":"text","id":"btn_text","label":"Button Text","default":"ALL NEW PRODUCTS"},{"type":"url","id":"btn_Url","label":"Button URL"}],"presets":[{"name":"Akta New Products Slider","settings":{"title":"NEW PRODUCTS","tag":"NEW"}}]}{% endschema %}