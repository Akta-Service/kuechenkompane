


<style>
    #image-content-cta-{{ section.id }} {
      background: {{ section.settings.section_bg }};
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-grid {
      display: grid;
      grid-template-columns: minmax(0, 620px) minmax(0, 1fr);
      gap: 80px;
      align-items: center;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-grid.is-reversed {
      grid-template-columns: minmax(0, 1fr) minmax(0, 620px);
    }

    #image-content-cta-{{ section.id }} .image-content-cta-grid.is-reversed .image-content-cta-media {
      order: 2;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-grid.is-reversed .image-content-cta-content {
      order: 1;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-image-wrap {
      width: 100%;
      border-radius: {{ section.settings.image_radius }}px;
      overflow: hidden;
      background: #ededed;
      aspect-ratio: 1 / 1;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(180deg, #efefef 0%, #ebebeb 100%);
    }

    #image-content-cta-{{ section.id }} .image-content-cta-placeholder-inner {
      text-align: center;
      padding: 20px;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-placeholder-icon {
      width: 42px;
      height: 42px;
      color: #b3b3b3;
      display: block;
      margin: 0 auto 12px;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-placeholder-label {
      display: inline-block;
      padding: 8px 14px;
      font-size: 13px;
      line-height: 1.3;
      color: #8a8a8a;
      background: #ffffff;
      border-radius: 4px;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-heading {
      margin: 0 0 14px;
      font-size: 24px;
      line-height: 1.7;
      font-weight: 700;
      color: {{ section.settings.heading_color }};
    }

    #image-content-cta-{{ section.id }} .image-content-cta-text {
      font-size: 16px;
      line-height: 1.7;
      color: {{ section.settings.text_color }};
      margin-bottom: 26px;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-text p {
      margin: 0;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-button-wrap {
      margin-top: 0;
    }

    #image-content-cta-{{ section.id }} .image-content-cta-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      display: inline-block;
      padding: 14px 36px;
      text-decoration: none;
      font-weight: 600;
      border-radius: {{ section.settings.button_radius }}px;
      background: {{ section.settings.button_bg }};
      color: {{ section.settings.button_text_color }};
      font-size: 16px;
      line-height: 1.7;
      transition: opacity 0.2s ease;
    }

    @media screen and (max-width: 1149px) {
      #image-content-cta-{{ section.id }} {
        padding-top: {{ section.settings.mobile_padding_top }}px;
        padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
      }
      #image-content-cta-{{ section.id }} .image-content-cta-grid {
        gap: 32px;
        grid-template-columns: 1fr;
      }
      #image-content-cta-{{ section.id }} .image-content-cta-image-wrap {
        aspect-ratio: 16 / 9;
      }
    }

    @media screen and (max-width: 749px) {
      #image-content-cta-{{ section.id }} .image-content-cta-image-wrap {
        aspect-ratio: 1 / 1;
      }
    }

  </style>

<section id="image-content-cta-{{ section.id }}" class="image-content-cta-section">
  <div class="custom-container">
    <div class="image-content-cta-grid{% if section.settings.reverse_columns %} is-reversed{% endif %}">
      <div class="image-content-cta-media">
        <div class="image-content-cta-image-wrap">
          {% if section.settings.image != blank %}
            {{
              section.settings.image
              | image_url: width: 1400
              | image_tag: loading: 'lazy', alt: section.settings.heading, class: 'image-content-cta-image'
            }}
          {% else %}
            <div class="image-content-cta-placeholder">
              <div class="image-content-cta-placeholder-inner">
                <svg class="image-content-cta-placeholder-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l.409.409a2.25 2.25 0 0 0 3.182 0l2.659-2.659a2.25 2.25 0 0 1 3.182 0l1.409 1.409M3.75 3.75h16.5A1.5 1.5 0 0 1 21.75 5.25v13.5a1.5 1.5 0 0 1-1.5 1.5H3.75a1.5 1.5 0 0 1-1.5-1.5V5.25a1.5 1.5 0 0 1 1.5-1.5Zm12 4.5h.008v.008h-.008V8.25Z"/>
                </svg>
                <div class="image-content-cta-placeholder-label">No image selected</div>
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="image-content-cta-content">
        {% if section.settings.heading != blank %}
          <h2 class="image-content-cta-heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="image-content-cta-text rte">
            {{ section.settings.text }}
          </div>
        {% endif %}

        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <div class="image-content-cta-button-wrap">
            <a href="{{ section.settings.button_link }}" class="image-content-cta-button">
              {{ section.settings.button_label }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image content CTA",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left image"
    },
    {
      "type": "checkbox",
      "id": "reverse_columns",
      "label": "Reverse columns",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Das richtige Messer finden"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Nutze unsere Kaufberatung oder stöbere durch unser kuratiertes Sortiment. Bei Fragen sind wir persönlich für dich da. Ohne Verkaufsdruck, ohne Floskeln.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Zum Shop →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#eef0fb"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#2d2d2d"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#f68621"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 14
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button corner radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile Padding top",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile Padding bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Image content CTA"
    }
  ]
}
{% endschema %}