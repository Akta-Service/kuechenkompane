<section class="proof-section" id="proof-{{ section.id }}">
  {% render 'b2b-reveal' %}
  {%- if section.settings.kanji != blank -%}
    <span class="proof__kanji" aria-hidden="true">{{ section.settings.kanji }}</span>
  {%- endif -%}

  <div class="proof-wrapper">
    <div class="proof-grid">
      <div class="proof-stat" data-b2b-reveal>
        {%- if section.settings.stat != blank -%}
          <span class="proof-stat__value">{{ section.settings.stat }}</span>
        {%- endif -%}
        {%- if section.settings.stat_label != blank -%}
          <span class="proof-stat__label">{{ section.settings.stat_label | newline_to_br }}</span>
        {%- endif -%}
      </div>

      <div class="proof-content" data-b2b-reveal style="animation-delay: .1s">
        {%- if section.settings.heading != blank -%}
          <h2 class="proof-heading">{{ section.settings.heading | newline_to_br }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="proof-text">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.settings.chips != blank -%}
          <div class="proof-chips">
            {%- assign chips = section.settings.chips | split: ',' -%}
            {%- for chip in chips -%}
              <span class="proof-chip">{{ chip | strip }}</span>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <style>
    .proof-section {
      position: relative;
      background: #141109;
      padding: clamp(64px,9vw,128px) 0;
      border-top: 1px solid #ffffff1a;
      overflow: hidden;
    }

    .proof__kanji {
      position: absolute;
      top: -12%;
      right: 1%;
      font-size: min(40vw, 520px);
      line-height: 0.8;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.04);
      pointer-events: none;
      user-select: none;
    }

    .proof-wrapper {
      position: relative;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .proof-grid {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 52px;
      align-items: center;
    }

    .proof-grid > * {
      min-width: 0;
    }

    .proof-stat__value {
      display: block;
      font-weight: 800;
      font-size: clamp(54px, 10.5vw, 128px);
      line-height: .9;
      letter-spacing: -.03em;
      color: #fff;
      white-space: nowrap;
    }

    .proof-stat__label {
      display: block;
      font-weight: 500;
      font-size: 14px;
      letter-spacing: .01em;
      color: #d0c6b0;
      margin-top: 16px;
      max-width: 22ch;
      line-height: 1.5;
      white-space: normal;
    }

    .proof-heading {
      font-weight: 700;
      font-size: clamp(24px, 3vw, 34px);
      letter-spacing: -.01em;
      line-height: 1.18;
      margin: 0 0 16px;
      color: #fff;
    }

    .proof-text {
      line-height: 1.55;
      color: #b2a88f;
      font-size: clamp(15px, 1.4vw, 17px);
      max-width: 56ch;
    }

    .proof-text p {
      margin: 0 0 12px;
    }

    .proof-text p:last-child {
      margin-bottom: 0;
    }

    .proof-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 22px;
    }

    .proof-chip {
      font-size: 11px;
      letter-spacing: .13em;
      text-transform: uppercase;
      color: #d0c6b0;
      border: 1px solid #ffffff2e;
      border-radius: 999px;
      padding: 7px 13px;
    }

    @media screen and (max-width: 860px) {

      .proof-grid {
        grid-template-columns: 1fr;
        gap: 26px;
      }

    }
  </style>
</section>

{% schema %}
{
  "name": "Proof Stat",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "kanji",
      "label": "Background kanji / symbol",
      "default": "実績"
    },
    {
      "type": "text",
      "id": "stat",
      "label": "Stat value",
      "default": "30 Mio. €"
    },
    {
      "type": "textarea",
      "id": "stat_label",
      "label": "Stat label",
      "default": "Jahresumsatz mit\nunserer eigenen Marke\nKüchenkompane"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Küchenkompane ist kein Konzept\n— sondern bewiesen."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Unsere eigene Messermarke wurde von Mats mit Mitte 20 aufgebaut und macht heute rund 30 Mio. € Umsatz. Der beste Beweis, dass Fertigung, Qualität und Produkt am Markt funktionieren.</p><p>Genau diese Fertigung öffnen wir für Sie — mit Ihrem Logo, neutral oder als eigene Marke.</p>"
    },
    {
      "type": "text",
      "id": "chips",
      "label": "Chips (comma separated)",
      "default": "Eigene Marke als Referenz, Bewährte Serienqualität, Skalierbare Fertigung"
    }
  ],
  "presets": [
    {
      "name": "Proof Stat"
    }
  ]
}
{% endschema %}
