<style>.sf-image-gallery{width:100%;box-sizing:border-box}.sf-gallery-inner{display:grid;gap:2px;align-items:stretch}.sf-gallery-inner.cols-2{grid-template-columns:repeat(2,1fr)}.sf-gallery-inner.cols-3{grid-template-columns:repeat(3,1fr)}.sf-gallery-inner.cols-4{grid-template-columns:repeat(4,1fr)}.sf-gallery-inner.cols-5{grid-template-columns:repeat(5,1fr)}.sf-gallery-inner.cols-5>.sf-gallery-item:nth-child(1),.sf-gallery-inner.cols-5>.sf-gallery-item:nth-child(5){grid-row:span 2}.sf-gallery-item{margin:0;overflow:hidden;position:relative}.sf-gallery-item img{width:100%;height:100%;display:block;object-fit:cover;transition:transform .45s cubic-bezier(.2,.9,.2,1);will-change:transform;aspect-ratio:3/4}.sf-gallery-item:hover img,.sf-gallery-item:focus-within img{transform:scale(1.04)}.sf-gallery-btn{border:0;padding:0;margin:0;background:0 0;cursor:pointer;width:100%;height:100%}.sf-gallery-link{display:block;width:100%;height:100%;text-decoration:none}.sf-lightbox{position:fixed;inset:0;display:none;align-items:center;justify-content:center;z-index:8000;background:rgba(0,0,0,.85)}.sf-lightbox[aria-hidden=false]{display:flex}.sf-lightbox .sf-lb-track{max-width:1100px;max-height:86vh;width:calc(100% - 80px);overflow:hidden;position:relative;outline:0}.sf-lb-item{display:none;margin:0;width:100%;height:100%;text-align:center}.sf-lb-item img{max-width:100%;max-height:86vh;height:auto;display:inline-block;object-fit:contain}.sf-lb-item[aria-current=true]{display:block}.sf-lb-caption{margin-top:10px;color:#fff;font-size:14px;opacity:.95}.sf-lb-close,.sf-lb-prev,.sf-lb-next{position:absolute;background:0 0;border:0;color:#fff;font-size:30px;cursor:pointer;padding:10px;z-index:8100}.sf-lb-close{top:12px;right:18px;font-size:36px;line-height:1}.sf-lb-prev{left:8px;top:50%;transform:translateY(-50%)}.sf-lb-next{right:8px;top:50%;transform:translateY(-50%)}.sf-lb-prev:hover,.sf-lb-next:hover,.sf-lb-close:hover{opacity:.9}@media(min-width:768px){.sf-gallery-item[data-index="4"]{display:none}}@media(max-width:767px){.sf-gallery-inner.cols-5{grid-template-columns:repeat(3,1fr)}.sf-gallery-inner.cols-4,.sf-gallery-inner.cols-3{grid-template-columns:repeat(2,1fr)}.sf-gallery-inner.cols-2{grid-template-columns:1fr}.sf-gallery-item img{aspect-ratio:3/5}}</style>

<section id="gallery-section-{{ section.id }}" class="sf-image-gallery" aria-label="Image gallery"><div class="sf-gallery-inner {{ section.settings.columns_class }}">{% for block in section.blocks %}<figure class="sf-gallery-item" data-index="{{ forloop.index0 }}">{% if block.settings.link != blank %}<a href="{{ block.settings.link }}" class="sf-gallery-link" target="{% if block.settings.open_in_new_tab %}_blank{% else %}_self{% endif %}" rel="noopener"><img src="{{ block.settings.image | img_url: '300x400' }}" alt="{{ block.settings.alt | escape }}" loading="lazy"></a>{% else %}<button type="button" class="sf-gallery-btn" aria-label="Open image {{ forloop.index }}"><img src="{{ block.settings.image | img_url: '300x400' }}" alt="{{ block.settings.alt | escape }}" loading="lazy"></button>{% endif %}</figure>{% endfor %}</div>

{% if section.settings.enable_lightbox %}
<div id="sf-lightbox-{{ section.id }}" class="sf-lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Image preview"><button class="sf-lb-close" aria-label="Close (Esc)">&times;</button><button class="sf-lb-prev" aria-label="Previous image" tabindex="0">&#10094;</button><div class="sf-lb-track" tabindex="0">{% for block in section.blocks %}<figure class="sf-lb-item" data-index="{{ forloop.index0 }}"><img src="{{ block.settings.image | img_url: '480x480' }}" alt="{{ block.settings.alt | escape }}">{% if block.settings.caption != blank %}<figcaption class="sf-lb-caption">{{ block.settings.caption }}</figcaption>{% endif %}</figure>{% endfor %}</div><button class="sf-lb-next" aria-label="Next image" tabindex="0">&#10095;</button></div>

<script>(function(){var r=document.getElementById("gallery-section-{{ section.id }}");if(!r)return;var i=r.querySelectorAll(".sf-gallery-item"),l=document.getElementById("sf-lightbox-{{ section.id }}");if(!l)return;var b=l.querySelectorAll(".sf-lb-item"),c=l.querySelector(".sf-lb-close"),p=l.querySelector(".sf-lb-prev"),n=l.querySelector(".sf-lb-next"),o=0;function u(){b.forEach(function(e){e.removeAttribute("aria-current")});var e=l.querySelector('.sf-lb-item[data-index="'+o+'"]');e&&e.setAttribute("aria-current","true")}function s(e){o=e,u(),l.setAttribute("aria-hidden","false"),document.documentElement.style.overflow="hidden",l.querySelector(".sf-lb-track").focus()}function a(){l.setAttribute("aria-hidden","true"),document.documentElement.style.overflow=""}function d(){o=(o+1)%b.length,u()}function f(){o=(o-1+b.length)%b.length,u()}i.forEach(function(e){var t=e.querySelector(".sf-gallery-btn,.sf-gallery-link"),i=parseInt(e.getAttribute("data-index"),10);t&&t.addEventListener("click",function(e){if("a"===t.tagName.toLowerCase()&&t.getAttribute("href")&&""!==t.getAttribute("href").trim())return;e.preventDefault(),s(i)})}),c&&c.addEventListener("click",a),p&&p.addEventListener("click",f),n&&n.addEventListener("click",d),document.addEventListener("keydown",function(e){"false"===l.getAttribute("aria-hidden")&&("Escape"===e.key&&a(),"ArrowRight"===e.key&&d(),"ArrowLeft"===e.key&&f())}),l.addEventListener("click",function(e){e.target===l&&a()}),b.forEach(function(e){e.addEventListener("click",d)}),u()})();</script>
{% endif %}
</section>

{% schema %}{"name":"Image Gallery","settings":[{"type":"select","id":"columns_class","label":"Columns layout","options":[{"value":"cols-2","label":"2 columns"},{"value":"cols-3","label":"3 columns"},{"value":"cols-4","label":"4 columns"},{"value":"cols-5","label":"5 columns (hero look)"}],"default":"cols-5"},{"type":"checkbox","id":"enable_lightbox","label":"Enable lightbox (click images to open preview)","default":true}],"blocks":[{"type":"gallery_image","name":"Gallery image","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"alt","label":"Alt text"},{"type":"text","id":"caption","label":"Caption (optional)"},{"type":"url","id":"link","label":"Link (optional)"},{"type":"checkbox","id":"open_in_new_tab","label":"Open link in new tab","default":false}]}],"max_blocks":12,"presets":[{"name":"Image gallery","category":"Gallery","blocks":[{"type":"gallery_image","settings":{"image":"","alt":"Image 1"}},{"type":"gallery_image","settings":{"image":"","alt":"Image 2"}},{"type":"gallery_image","settings":{"image":"","alt":"Image 3"}},{"type":"gallery_image","settings":{"image":"","alt":"Image 4"}},{"type":"gallery_image","settings":{"image":"","alt":"Image 5"}}]}]}{% endschema %}
