
{{ 'hf-style.css' | asset_url | stylesheet_tag }}

<div class="image-slide-section">
  <div class="image-slide-container">
    <h2 class="image-slide__title">{{ section.settings.title }}</h2>
    <div class="splide image-slide__active">
      <div class="splide__track">
        <ul class="splide__list">
          {% for block in section.blocks %}
            <li class="splide__slide">
              <div class="image-item">
                {% if block.settings.slide_img != blank %}
                  <img
                    src="{{ block.settings.slide_img | image_url: width: 600 }}"
                    alt="Image"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  >
                {% endif %}
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  function initSlide() {
    var el = document.querySelector('.image-slide__active');
    if (!el || el.classList.contains('is-initialized')) return;
    if (typeof Splide === 'undefined' || !window.splide) {
      setTimeout(initSlide, 100);
      return;
    }

    new Splide(el, {
      type        : 'loop',
      autoWidth   : true,
      gap         : '20px',
      drag        : 'free',
      snap        : false,
      arrows      : false,
      pagination  : false,
      autoScroll  : {
        speed           : 1,
        pauseOnHover    : true,
        pauseOnFocus    : false,
        rewind          : false,
        reverseDirection: false,
      },
    }).mount(window.splide.Extensions);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSlide);
  } else {
    initSlide();
  }

  document.addEventListener('shopify:section:load', function(e) {
    if (e.target.querySelector('.image-slide__active')) {
      setTimeout(initSlide, 300);
    }
  });
})();
</script>

{% schema %}
{
  "name": "PDP V1 - Image Slide",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Top Title",
      "default": "Customers love our shoes!"
    }
  ],
  "blocks": [
    {
      "type": "Slider",
      "name": "Slider",
      "settings": [
        {
          "type": "image_picker",
          "id": "slide_img",
          "label": "Slider Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP V1 - Image Slide"
    }
  ]
}
{% endschema %}
